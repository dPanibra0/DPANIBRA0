---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import Hero from "../components/sections/Hero.astro";
import Microservices from "../components/sections/Microservices.astro";
import HexagonalArchitecture from "../components/sections/HexagonalArchitecture.astro";
import TechStackCompact from "../components/sections/TechStackCompact.astro";
import Experience from "../components/sections/Experience.astro";
import Projects from "../components/sections/Projects.astro";
import Contact from "../components/sections/Contact.astro";
import FloatingQuickActions from "../components/ui/FloatingQuickActions.astro";
import { getTranslations } from "../content/talento/i18n";

const lang = "es" as const;
const { content, ui } = getTranslations(lang);
---

<MainLayout title={content.meta.title} description={content.meta.description} lang={lang}>
  <Navbar nav={content.nav} ui={ui.navbar} />
  <main>
    <Hero id="inicio" hero={content.hero} />
    <Microservices id="microservicios" microservices={content.microservices} overline={content.overlines.microservices} />
    <HexagonalArchitecture id="arquitectura" hexagonal={content.hexagonal} overline={content.overlines.hexagonal} />
    <Experience id="experiencia" experience={content.experience} overline={content.overlines.experience} ui={ui.experience} />
    <Projects id="proyectos" projects={content.projects} overline={content.overlines.projects} ui={ui.projects} />
    <TechStackCompact id="stack" stack={content.stack} overline={content.overlines.stack} ui={ui.techCarousel} />
    <Contact
      id="contacto"
      contact={content.contact}
      overline={content.overlines.contact}
      ui={ui.contact}
      floatingActionsUi={ui.floatingActions}
    />
  </main>
  <FloatingQuickActions ui={ui.floatingActions} />
  <Footer footer={content.footer} nav={content.nav} />
</MainLayout>
