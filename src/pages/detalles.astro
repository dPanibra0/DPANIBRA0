---
const title = "Redirigiendo a la nueva arquitectura";
const description = "La ruta /detalles fue reemplazada por /experiencia, /proyectos y /blog.";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://davidpanibra.dev/experiencia" />
    <script is:inline>
      (() => {
        const hash = window.location.hash;
        const normalizedHash = hash.toLowerCase();
        let nextPath = "/experiencia";

        if (normalizedHash === "#blog") {
          nextPath = "/blog";
        } else if (
          normalizedHash === "#proyectos" ||
          normalizedHash.startsWith("#proyecto-")
        ) {
          nextPath = `/proyectos${hash}`;
        } else if (normalizedHash === "#contacto") {
          nextPath = "/experiencia#contacto";
        }

        window.location.replace(nextPath);
      })();
    </script>
  </head>
  <body>
    <main style="font-family: sans-serif; padding: 2rem; color: #f5f7fa; background: #090b10; min-height: 100vh;">
      <p>La ruta <code>/detalles</code> cambio.</p>
      <p>
        Usa <a href="/experiencia">/experiencia</a>, <a href="/proyectos">/proyectos</a>
        o <a href="/blog">/blog</a>.
      </p>
    </main>
  </body>
</html>
