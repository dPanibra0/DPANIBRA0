---
import MainLayout from "../../layouts/MainLayout.astro";
import Navbar from "../../components/layout/Navbar.astro";
import Footer from "../../components/layout/Footer.astro";
import Hero from "../../components/sections/Hero.astro";
import About from "../../components/sections/About.astro";
import TechStack from "../../components/sections/TechStack.astro";
import Projects from "../../components/sections/Projects.astro";
import Experience from "../../components/sections/Experience.astro";
import Process from "../../components/sections/Process.astro";
import Philosophy from "../../components/sections/Philosophy.astro";
import Contact from "../../components/sections/Contact.astro";
import { enContent } from "../../content/en";

const content = enContent;
---

<MainLayout title={content.meta.title} description={content.meta.description} lang="en">
  <Navbar nav={content.nav} lang="en" />
  <main>
    <Hero id="home" hero={content.hero} />
    <About id="about" about={content.about} overline="Professional profile" />
    <div class="divider-line"></div>
    <TechStack id="stack" stack={content.stack} overline="Core capabilities" />
    <Projects
      id="projects"
      projects={content.projects}
      overline="Business impact"
      labels={{
        problem: "Problem",
        architecture: "Architecture",
        stack: "Stack",
        challenges: "Challenges",
        solution: "Solution",
        impact: "Impact",
      }}
    />
    <Experience id="experience" experience={content.experience} overline="Professional track" />
    <Process id="process" process={content.process} overline="Delivery approach" />
    <Philosophy id="philosophy" philosophy={content.philosophy} overline="Engineering principles" />
    <Contact id="contact" contact={content.contact} overline="Direct contact" lang="en" />
  </main>
  <Footer footer={content.footer} nav={content.nav} />
</MainLayout>
