---
import { getCollection, render, type CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import Navbar from "../../components/layout/Navbar.astro";
import Contact from "../../components/sections/Contact.astro";
import Footer from "../../components/layout/Footer.astro";
import FloatingQuickActions from "../../components/ui/FloatingQuickActions.astro";
import { getTranslations } from "../../content/talento/i18n";
import { formatPostDate } from "../../content/technical-posts-data";
import { Icon } from "astro-icon/components";

export async function getStaticPaths() {
  const posts = await getCollection("technicalPosts", ({ data }) => !data.draft);

  return posts.map((post: CollectionEntry<"technicalPosts">) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const lang = "es" as const;
const { content, ui } = getTranslations(lang);
const postNav = [
  { label: "Inicio", href: "/" },
  { label: "Detalles", href: "/detalles" },
  { label: "Contacto", href: "#contacto" },
];

const { post } = Astro.props as { post: CollectionEntry<"technicalPosts"> };
const { Content } = await render(post);
const words = post.body.trim().split(/\s+/).filter(Boolean).length;
const readingTimeMinutes = Math.max(1, Math.round(words / 180));
const articleTitle = `${post.data.title} | David Panibra`;
const articlePath = `/detalles/${post.id}`;
const publishedLabel = formatPostDate(post.data.publishDate);
const updatedLabel = post.data.updatedDate ? formatPostDate(post.data.updatedDate) : null;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.publishDate).toISOString(),
  inLanguage: lang,
  mainEntityOfPage: `https://davidpanibra.dev${articlePath}`,
  image: [post.data.cover.src],
  author: {
    "@type": "Person",
    name: "David Panibra",
    url: "https://www.linkedin.com/in/david-panibra-1bb87a1a4/",
  },
  publisher: {
    "@type": "Person",
    name: "David Panibra",
  },
  articleSection: post.data.tag,
  keywords: [post.data.tag, "backend java", "microservicios", "arquitectura enterprise"],
};
---

<MainLayout
  title={articleTitle}
  description={post.data.description}
  lang={lang}
  seo={{
    type: "article",
    canonicalPath: articlePath,
    image: {
      src: post.data.cover.src,
      alt: post.data.cover.alt,
    },
    article: {
      publishedTime: post.data.publishDate.toISOString(),
      modifiedTime: (post.data.updatedDate ?? post.data.publishDate).toISOString(),
      author: "David Panibra",
      section: post.data.tag,
      tags: [post.data.tag, "Backend Java", "Microservicios"],
    },
  }}
  structuredData={structuredData}
>
  <Navbar nav={postNav} ui={ui.navbar} />

  <main class="border-t border-border/50 pt-[clamp(2.2rem,6vw,4.5rem)] pb-[clamp(3rem,8vw,5.5rem)] max-md:pt-[1.4rem]">
    <div class="container-shell grid gap-4">
      <a href="/detalles" class="inline-cta w-fit" data-reveal="up">
        <Icon name="lucide:arrow-left" class="h-3.5 w-3.5" aria-hidden="true" />
        Volver</a>

      <article
        class="card-surface overflow-hidden rounded-[1.1rem] border border-[color:color-mix(in_oklab,var(--color-border)_72%,transparent)]"
        data-reveal="up"
      >
        <header class="grid gap-[1.4rem] border-b border-[color:color-mix(in_oklab,var(--color-border)_70%,transparent)] p-[clamp(1.15rem,2vw,1.5rem)] min-[960px]:grid-cols-[minmax(0,1.05fr)_minmax(300px,0.95fr)] min-[960px]:items-end max-md:p-4">
          <div class="grid gap-[0.8rem]">
            <p class="micro-label m-0">{post.data.tag}</p>
            <h1 class="m-0 max-w-[16ch] text-[clamp(2rem,4.8vw,3.9rem)] leading-[0.98] tracking-[-0.045em] [text-wrap:balance]">
              {post.data.title}
            </h1>
            <p class="m-0 max-w-[62ch] text-[clamp(1rem,1.6vw,1.08rem)] leading-[1.72] text-muted [text-wrap:pretty]">
              {post.data.description}
            </p>

            <dl class="m-0 flex flex-wrap gap-[0.9rem] pt-[0.2rem] max-md:gap-[0.7rem]" aria-label="Metadatos del articulo">
              <div class="min-w-[140px] border-l border-[color:color-mix(in_oklab,var(--color-border)_70%,transparent)] pl-[0.8rem] max-md:min-w-0 max-md:basis-full">
                <dt class="m-0 font-[var(--font-accent)] text-[0.68rem] uppercase tracking-[0.08em] text-[#9aa8b7]">Publicado</dt>
                <dd class="mt-[0.28rem] text-[0.94rem] text-text">{publishedLabel}</dd>
              </div>
              <div class="min-w-[140px] border-l border-[color:color-mix(in_oklab,var(--color-border)_70%,transparent)] pl-[0.8rem] max-md:min-w-0 max-md:basis-full">
                <dt class="m-0 font-[var(--font-accent)] text-[0.68rem] uppercase tracking-[0.08em] text-[#9aa8b7]">Lectura</dt>
                <dd class="mt-[0.28rem] text-[0.94rem] text-text">{readingTimeMinutes} min</dd>
              </div>
              {updatedLabel && (
                <div class="min-w-[140px] border-l border-[color:color-mix(in_oklab,var(--color-border)_70%,transparent)] pl-[0.8rem] max-md:min-w-0 max-md:basis-full">
                  <dt class="m-0 font-[var(--font-accent)] text-[0.68rem] uppercase tracking-[0.08em] text-[#9aa8b7]">Actualizado</dt>
                  <dd class="mt-[0.28rem] text-[0.94rem] text-text">{updatedLabel}</dd>
                </div>
              )}
            </dl>
          </div>

          <figure class="relative m-0 aspect-[16/8] overflow-hidden rounded-[0.92rem] border border-[color:color-mix(in_oklab,var(--color-border)_70%,transparent)] bg-[color:color-mix(in_oklab,var(--color-surface)_82%,black_18%)] max-md:aspect-[16/10]">
            <img
              src={post.data.cover.src}
              alt={post.data.cover.alt}
              loading="eager"
              decoding="async"
              class="h-full w-full object-cover object-center [filter:saturate(0.88)_contrast(0.96)]"
            />
            <span class="article-cover-wash"></span>
          </figure>
        </header>

        <div class="article-prose mx-auto max-w-[76ch] px-[clamp(1.15rem,3vw,2rem)] pt-[clamp(1.35rem,3vw,2.2rem)] pb-[clamp(1.8rem,4vw,2.6rem)] max-md:px-4 max-md:pt-[1.15rem] max-md:pb-[1.6rem]">
          <Content />
        </div>
      </article>
    </div>
  </main>

  <Contact
    id="contacto"
    contact={content.contact}
    overline={content.overlines.contact}
    ui={ui.contact}
    floatingActionsUi={ui.floatingActions}
  />

  <FloatingQuickActions ui={ui.floatingActions} />

  <Footer footer={content.footer} nav={postNav} />
</MainLayout>

<style>
  .article-cover-wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(8, 12, 18, 0.08) 0%, rgba(8, 12, 18, 0.46) 100%),
      linear-gradient(120deg, rgba(77, 131, 166, 0.18) 0%, rgba(77, 131, 166, 0) 58%);
    pointer-events: none;
  }

  .article-prose :global(h2),
  .article-prose :global(h3) {
    margin: 2rem 0 0.8rem;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--color-text);
  }

  .article-prose :global(h2) {
    font-size: clamp(1.45rem, 2vw, 1.9rem);
  }

  .article-prose :global(h3) {
    font-size: clamp(1.18rem, 1.7vw, 1.4rem);
  }

  .article-prose :global(p),
  .article-prose :global(li) {
    font-size: 1.02rem;
    line-height: 1.82;
    color: color-mix(in oklab, var(--color-muted) 84%, white 16%);
  }

  .article-prose :global(p) {
    margin: 0 0 1rem;
    text-wrap: pretty;
  }

  .article-prose :global(ul),
  .article-prose :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.25rem;
  }

  .article-prose :global(li + li) {
    margin-top: 0.4rem;
  }

  .article-prose :global(code) {
    padding: 0.1rem 0.32rem;
    border: 1px solid color-mix(in oklab, var(--color-border) 72%, transparent);
    border-radius: 0.35rem;
    background: rgba(10, 15, 21, 0.8);
    font-family: var(--font-accent);
    font-size: 0.92em;
    color: #e7eff8;
  }

  .article-prose :global(strong) {
    color: var(--color-text);
  }

  @media (max-width: 767px) {
    .article-prose :global(p),
    .article-prose :global(li) {
      font-size: 0.98rem;
      line-height: 1.72;
    }
  }
</style>
