---
import DetailsProjectsPanel from "../components/details/DetailsProjectsPanel.astro";
import {
  resolveProjectCover,
  resolveTechIcon,
} from "../components/details/details-helpers";
import { getTranslations } from "../content/talento/i18n";
import DetailsLayout from "../layouts/DetailsLayout.astro";

const lang = "es" as const;
const { content, ui } = getTranslations(lang);
---

<DetailsLayout
  title="Proyectos backend Java | David Panibra"
  description="Casos reales de backend Java, integraciones, procesos batch y decisiones tecnicas aplicadas a operaciones empresariales."
  lang={lang}
  content={content}
  ui={ui}
  currentRoute="proyectos"
>
  <div class="relative mt-[0.7rem] overflow-x-clip max-md:mt-[0.6rem]">
    <DetailsProjectsPanel
      items={content.projects.items}
      overline={ui.detalles.projectsOverline}
      title={ui.detalles.projectsTitle}
      intro={ui.detalles.projectsIntro}
      projectLabels={ui.detalles.projectLabels}
      resolveTechIcon={resolveTechIcon}
      resolveProjectCover={resolveProjectCover}
    />
  </div>
</DetailsLayout>
