---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import Hero from "../components/sections/Hero.astro";
import Microservices from "../components/sections/Microservices.astro";
import HexagonalArchitecture from "../components/sections/HexagonalArchitecture.astro";
import TechStackCompact from "../components/sections/TechStackCompact.astro";
import Experience from "../components/sections/Experience.astro";
import Projects from "../components/sections/Projects.astro";
import Contact from "../components/sections/Contact.astro";
import FloatingQuickActions from "../components/ui/FloatingQuickActions.astro";
import { esContent } from "../content/talento/es";
import { enContent } from "../content/talento/en";

const content = esContent;
---

<MainLayout title={content.meta.title} description={content.meta.description} lang="es">
  <Navbar navEs={esContent.nav} navEn={enContent.nav} initialLang="es" />
  <main data-lang-main>
    <div data-lang-block="es">
    <Hero id="inicio" hero={esContent.hero} />
    <Microservices id="microservicios" microservices={esContent.microservices} overline={esContent.overlines.microservices} />
    <HexagonalArchitecture id="arquitectura" hexagonal={esContent.hexagonal} overline={esContent.overlines.hexagonal} />
    <Experience id="experiencia" experience={esContent.experience} overline={esContent.overlines.experience} />
    <Projects
      id="proyectos"
      projects={esContent.projects}
      overline={esContent.overlines.projects}
      labels={{
        problem: "Problema",
        architecture: "Arquitectura",
        stack: "Stack",
        challenges: "Desafios",
        solution: "Solucion",
        impact: "Impacto",
      }}
    />
    <TechStackCompact id="stack" stack={esContent.stack} overline={esContent.overlines.stack} />
    <Contact id="contacto" contact={esContent.contact} overline={esContent.overlines.contact} />
    </div>

    <div data-lang-block="en" hidden aria-hidden="true">
      <Hero id="home" hero={enContent.hero} />
      <Microservices id="microservices" microservices={enContent.microservices} overline={enContent.overlines.microservices} />
      <HexagonalArchitecture id="architecture" hexagonal={enContent.hexagonal} overline={enContent.overlines.hexagonal} />
      <Experience id="experience" experience={enContent.experience} overline={enContent.overlines.experience} />
      <Projects
        id="projects"
        projects={enContent.projects}
        overline={enContent.overlines.projects}
        labels={{
          problem: "Problem",
          architecture: "Architecture",
          stack: "Stack",
          challenges: "Challenges",
          solution: "Solution",
          impact: "Impact",
        }}
      />
      <TechStackCompact id="stack" stack={enContent.stack} overline={enContent.overlines.stack} />
      <Contact id="contact" contact={enContent.contact} overline={enContent.overlines.contact} />
    </div>
  </main>
  <FloatingQuickActions lang="es" />
  <div data-lang-block="es">
    <Footer footer={esContent.footer} nav={esContent.nav} />
  </div>
  <div data-lang-block="en" hidden aria-hidden="true">
    <Footer footer={enContent.footer} nav={enContent.nav} />
  </div>

  <script is:inline>
    (() => {
      const readStoredLang = (fallback) => {
        const raw = localStorage.getItem("site-lang");
        if (raw === "es" || raw === "en") return raw;
        return fallback;
      };

      const applyLanguage = (lang) => {
        document.querySelectorAll("[data-lang-block]").forEach((block) => {
          const matches = block.getAttribute("data-lang-block") === lang;
          block.toggleAttribute("hidden", !matches);
          block.setAttribute("aria-hidden", String(!matches));
        });
        document.documentElement.lang = lang;
      };

      const initial = readStoredLang("es");
      applyLanguage(initial);
      window.dispatchEvent(new CustomEvent("site-language:change", { detail: { lang: initial } }));

      window.addEventListener("site-language:change", (event) => {
        const custom = event;
        const lang = custom && custom.detail ? custom.detail.lang : null;
        if (lang !== "es" && lang !== "en") return;
        localStorage.setItem("site-lang", lang);
        applyLanguage(lang);
      });
    })();
  </script>
</MainLayout>
