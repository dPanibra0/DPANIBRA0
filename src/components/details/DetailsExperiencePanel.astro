---
interface Props {
  items: Array<{
    company: string;
    period: string;
    workMode: string;
    role: string;
    context: string;
    highlights: string[];
    technologies: string[];
    cover: { src: string; alt: string };
  }>;
}

const { items } = Astro.props;
---

<section
  id="panel-experiencia"
  role="tabpanel"
  aria-labelledby="tab-experiencia"
  class="details-panel border-t border-border/50"
  data-tab-panel="experiencia"
  data-panel-state="active"
>
  <div class="container-shell details-panel-inner">
    <div class="details-exp-frame relative" data-reveal="up" data-reveal-delay="90">
      <div class="absolute bottom-0 left-[10px] top-0 w-px bg-white/75"></div>

      <div class="space-y-14 md:space-y-20 lg:space-y-24">
        {
          items.map((item) => (
            <article
              class="exp-item relative grid gap-7 pl-10 md:pl-14 lg:grid-cols-[0.34fr_0.66fr] lg:gap-12"
              data-exp-item
            >
              <span class="exp-node absolute left-[3px] top-2 h-3.5 w-3.5 rounded-full border shadow-[0_0_0_2px_rgba(10,10,10,0.95)] md:left-[3px]" />

              <div class="space-y-2">
                <h3 class="text-[1.02rem] font-semibold leading-tight tracking-[-0.01em] text-text md:text-[26px]">{item.company}</h3>
                <p class="text-[0.82rem] leading-snug text-[#bcc6d1] md:text-[14px]">{item.period}</p>
                <p class="text-[0.86rem] leading-snug text-muted/80 md:text-[15px]">{item.workMode}</p>
              </div>

              <div class="max-w-[920px]">
                <figure class="exp-cover">
                  <img
                    src={item.cover.src}
                    alt={item.cover.alt}
                    loading="lazy"
                    decoding="async"
                    class="exp-cover-media"
                  />
                  <span class="exp-cover-wash" aria-hidden="true"></span>
                </figure>

                <h4 class="text-[21px] font-semibold leading-[1.08] tracking-[-0.02em] text-text md:text-[31px]">{item.role}</h4>
                <p class="mt-2.5 text-[15px] leading-relaxed text-muted md:text-[17px]">{item.context}</p>

                <ul class="mt-5 space-y-2.5 md:mt-6">
                  {item.highlights.map((highlight) => (
                    <li class="flex gap-3 text-[14.5px] leading-relaxed text-muted md:text-[15.5px]">
                      <span class="mt-[1px] text-muted">&#8250;</span>
                      <span>{highlight}</span>
                    </li>
                  ))}
                </ul>

                <div class="mt-5 flex flex-wrap gap-2 md:mt-6">
                  {item.technologies.map((tech) => (
                    <span
                      class="rounded-md border px-2.5 py-1 text-xs text-[#c1c9d2] md:text-sm"
                      style="background:#161616;border-color:#2a2a2a;"
                    >
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .details-panel[hidden] {
    display: none;
  }

  .details-panel[data-panel-state="active"] {
    animation: details-panel-in 240ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .details-panel-inner {
    padding-top: 1.9rem;
  }

  .details-exp-frame {
    position: relative;
    overflow: visible;
    isolation: isolate;
    border: none;
    border-radius: 0;
    padding: 0.9rem 0;
    background: transparent;
    box-shadow: none;
  }

  .exp-item {
    opacity: 0.56;
    transition: opacity 260ms ease;
  }

  .exp-cover {
    position: relative;
    overflow: hidden;
    margin-bottom: 1rem;
    border: 1px solid color-mix(in oklab, var(--color-border) 70%, transparent);
    border-radius: 0.78rem;
    aspect-ratio: 16 / 8;
    background: color-mix(in oklab, var(--color-surface) 84%, black 16%);
  }

  .exp-cover-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(0.82) contrast(0.92);
    transform: scale(1.02);
    transition:
      transform 300ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 300ms ease;
  }

  .exp-cover-wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(8, 12, 18, 0.08) 0%, rgba(8, 12, 18, 0.44) 100%),
      linear-gradient(120deg, rgba(77, 131, 166, 0.16) 0%, rgba(77, 131, 166, 0) 58%);
    pointer-events: none;
    transition: background 280ms ease;
  }

  .exp-node {
    border-color: #9aa8b8;
    background: #cdd4db;
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease;
  }

  .exp-item:hover,
  .exp-item.is-active {
    opacity: 1;
  }

  .exp-item:hover .exp-cover-media,
  .exp-item.is-active .exp-cover-media {
    filter: saturate(0.9) contrast(0.96);
    transform: scale(1.04);
  }

  .exp-item:hover .exp-cover-wash,
  .exp-item.is-active .exp-cover-wash {
    background:
      linear-gradient(180deg, rgba(8, 12, 18, 0.04) 0%, rgba(8, 12, 18, 0.36) 100%),
      linear-gradient(120deg, rgba(77, 131, 166, 0.12) 0%, rgba(77, 131, 166, 0) 60%);
  }

  .exp-item:hover .exp-node,
  .exp-item.is-active .exp-node {
    transform: scale(1.1);
    border-color: #f4f8ff;
    background: #ffffff;
    box-shadow:
      0 0 0 2px rgba(10, 10, 10, 0.95),
      0 0 10px 1px rgba(255, 255, 255, 0.76),
      0 0 20px 2px rgba(221, 233, 245, 0.42);
  }

  @keyframes details-panel-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 767px) {
    .details-panel-inner {
      padding-top: 1.25rem;
    }

    .details-exp-frame {
      padding: 0.75rem 0;
    }

    .exp-cover {
      margin-bottom: 0.82rem;
      aspect-ratio: 16 / 10;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .details-panel,
    .exp-item,
    .exp-node,
    .exp-cover-media,
    .exp-cover-wash {
      animation: none;
      transition: none;
    }
  }
</style>
