---
import { Icon } from "astro-icon/components";

interface Props {
  items: Array<{
    company: string;
    period: string;
    workMode: string;
    role: string;
    context: string;
    highlights: string[];
    technologies: string[];
    cover: { src: string; alt: string };
  }>;
  resolveTechIcon: (tech: string) => string;
}

const { items, resolveTechIcon } = Astro.props as Props;

interface EmphasisSegment {
  text: string;
  emphasized: boolean;
}

const parseInlineEmphasis = (text: string): EmphasisSegment[] =>
  text
    .split(/(\*\*[^*]+\*\*)/g)
    .filter(Boolean)
    .map((segment) => {
      const emphasized = segment.startsWith("**") && segment.endsWith("**");

      return {
        text: emphasized ? segment.slice(2, -2) : segment,
        emphasized,
      };
    });
---

<section
  class="details-panel border-t border-border/50"
>
  <div class="container-shell pt-[1.25rem] md:pt-[1.9rem]">
    <div class="relative isolate overflow-visible border-none bg-transparent py-3 shadow-none md:py-[0.9rem]">
      <div class="absolute bottom-0 left-[10px] top-0 w-px bg-white/75"></div>

      <div class="space-y-14 md:space-y-20 lg:space-y-24" data-reveal-group data-reveal-stagger-mobile="70" data-reveal-stagger-desktop="56">
        {
          items.map((item) => (
            <article
              class="exp-item relative grid gap-7 pl-10 opacity-[0.88] transition-[opacity,transform] duration-[260ms] ease-out md:pl-14 md:opacity-[0.78] lg:grid-cols-[0.34fr_0.66fr] lg:gap-12"
              data-exp-card
              data-exp-item
              data-reveal="up"
            >
              <span class="exp-node absolute left-[3px] top-2 h-3.5 w-3.5 rounded-full border shadow-[0_0_0_2px_rgba(10,10,10,0.95)] md:left-[3px]" />

              <div class="space-y-2">
                <h3 class="text-[1.02rem] font-semibold leading-tight tracking-[-0.01em] text-text md:text-[26px]">{item.company}</h3>
                <p class="text-[0.82rem] leading-snug text-[#bcc6d1] md:text-[14px]">{item.period}</p>
                <p class="text-[0.86rem] leading-snug text-muted/80 md:text-[15px]">{item.workMode}</p>
              </div>

              <div class="max-w-[920px]">
                <figure class="exp-cover relative mb-[0.82rem] aspect-[16/10] overflow-hidden rounded-[0.78rem] border md:mb-4 md:aspect-[16/8]">
                  <img
                    src={item.cover.src}
                    alt={item.cover.alt}
                    loading="lazy"
                    decoding="async"
                    class="exp-cover-media h-full w-full object-cover object-center"
                  />
                  <span class="exp-cover-wash" aria-hidden="true"></span>
                </figure>

                <h4 class="text-[21px] font-semibold leading-[1.08] tracking-[-0.02em] text-text md:text-[31px]">{item.role}</h4>
                <p class="mt-2.5 text-[15px] leading-relaxed text-muted md:text-[17px]">
                  {parseInlineEmphasis(item.context).map((segment) =>
                    segment.emphasized ? <strong class="font-semibold text-text">{segment.text}</strong> : segment.text,
                  )}
                </p>

                <ul class="mt-5 space-y-2.5 md:mt-6">
                  {item.highlights.map((highlight) => (
                    <li class="flex gap-3 text-[14.5px] leading-relaxed text-muted md:text-[15.5px]">
                      <span class="mt-[1px] text-muted">&#8250;</span>
                      <span>
                        {parseInlineEmphasis(highlight).map((segment) =>
                          segment.emphasized ? <strong class="font-semibold text-text">{segment.text}</strong> : segment.text,
                        )}
                      </span>
                    </li>
                  ))}
                </ul>

                <div class="mt-5 flex flex-wrap gap-2 md:mt-6">
                  {item.technologies.map((tech) => (
                    <span
                      class="stack-card__chip selectable-chip exp-tech-chip cursor-default px-2 py-1 text-[10px] font-medium uppercase tracking-[0.08em] pointer-events-none select-none transition-none"
                      aria-label={tech}
                    >
                      <Icon name={resolveTechIcon(tech)} class="h-3.5 w-3.5" aria-hidden="true" />
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <div class="mt-10 flex flex-wrap gap-3" data-reveal="up" data-reveal-delay="130">
      <Icon name="lucide:arrow-left" class="h-3.5 w-3.5" aria-hidden="true" />
      <a href="/#experiencia" class="inline-cta text-xs md:text-sm">Ir a experiencia</a>
    </div>
  </div>
</section>

<style>
  .exp-cover {
    border: 1px solid color-mix(in oklab, var(--color-border) 70%, transparent);
    background: color-mix(in oklab, var(--color-surface) 84%, black 16%);
  }

  .exp-cover-media {
    filter: saturate(0.82) contrast(0.92);
    transform: translate3d(0, var(--exp-parallax-y, 0px), 0) scale(1.02);
    transition:
      transform 300ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 300ms ease;
  }

  .exp-cover-wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(8, 12, 18, 0.08) 0%, rgba(8, 12, 18, 0.44) 100%),
      linear-gradient(120deg, rgba(77, 131, 166, 0.16) 0%, rgba(77, 131, 166, 0) 58%);
    pointer-events: none;
    transition: background 280ms ease;
  }

  .exp-node {
    border-color: #9aa8b8;
    background: #cdd4db;
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease;
  }

  .exp-tech-chip {
    border-color: color-mix(in oklab, var(--color-border) 76%, transparent);
    background: color-mix(in oklab, var(--color-surface) 82%, black 18%);
    color: color-mix(in oklab, var(--color-muted) 92%, white 8%);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .exp-item:hover,
  .exp-item.is-active {
    opacity: 1;
    transform: translate3d(0, -2px, 0);
  }

  .exp-item:hover .exp-cover-media,
  .exp-item.is-active .exp-cover-media {
    filter: saturate(0.98) contrast(1);
    transform: translate3d(0, var(--exp-parallax-y, 0px), 0) scale(1.06);
  }

  .exp-item:hover .exp-cover-wash,
  .exp-item.is-active .exp-cover-wash {
    background:
      linear-gradient(180deg, rgba(8, 12, 18, 0.02) 0%, rgba(8, 12, 18, 0.3) 100%),
      linear-gradient(120deg, rgba(77, 131, 166, 0.2) 0%, rgba(77, 131, 166, 0) 62%);
  }

  .exp-item:hover .exp-node,
  .exp-item.is-active .exp-node {
    transform: scale(1.16);
    border-color: #f4f8ff;
    background: #ffffff;
    box-shadow:
      0 0 0 2px rgba(10, 10, 10, 0.95),
      0 0 14px 2px rgba(255, 255, 255, 0.82),
      0 0 26px 4px rgba(221, 233, 245, 0.54);
  }

  @media (prefers-reduced-motion: reduce) {
    .details-panel,
    .exp-item,
    .exp-node,
    .exp-cover-media,
    .exp-cover-wash {
      animation: none;
      transition: none;
    }
  }
</style>
