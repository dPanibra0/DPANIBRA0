---
import { Icon } from "astro-icon/components";

interface ProjectCover {
  src: string;
  alt: string;
}

interface ProjectItem {
  title: string;
  architecture: string;
  stack: string;
  problem: string;
  solution: string;
  challenges: string;
  impact: string;
}

interface Props {
  items: ProjectItem[];
  projectLabels: {
    problem: string;
    solution: string;
    challenges: string;
    impact: string;
  };
  resolveTechIcon: (tech: string) => string;
  resolveProjectCover: (index: number) => ProjectCover;
}

const { items, projectLabels, resolveTechIcon, resolveProjectCover } = Astro.props;
---

<section
  id="panel-proyectos"
  role="tabpanel"
  aria-labelledby="tab-proyectos"
  class="details-panel details-panel-projects border-t border-border/50"
  data-tab-panel="proyectos"
  data-panel-state="inactive"
  hidden
>
  <div class="container-shell details-panel-inner">
    <div class="project-list grid gap-5 md:gap-6" data-reveal-group data-reveal-stagger-mobile="64" data-reveal-stagger-desktop="54">
      {
        items.map((project, index) => {
          const cover = resolveProjectCover(index);

          return (
            <article id={`proyecto-${index + 1}`} class="project-details border border-border/70 p-5 md:p-7" data-reveal="up">
              <div class="project-details-grid">
                <header class="project-hero">
                  <div class="flex flex-wrap items-start justify-between gap-4">
                    <h3 class="max-w-[900px] text-[1.35rem] font-semibold tracking-[-0.02em] text-text md:text-[2.05rem]">{project.title}</h3>
                    <span class="project-kind-badge">Caso aplicado</span>
                  </div>
                  <figure class="project-cover mt-5" aria-hidden="true">
                    <img
                      src={cover.src}
                      alt={cover.alt}
                      loading="lazy"
                      decoding="async"
                      class="project-cover-media"
                    />
                    <span class="project-cover-wash" aria-hidden="true"></span>
                  </figure>
                  <p class="mt-4 text-[0.96rem] leading-relaxed text-muted md:text-[1.03rem]">{project.architecture}</p>
                </header>

                <div class="project-side">
                  <div class="project-tech" aria-label={`Tecnologias clave de ${project.title}`}>
                    <ul class="project-tech-list" role="list">
                      {project.stack.split(",").map((tech) => {
                        const label = tech.trim();

                        return (
                          <li class="hex-tech-badge" role="listitem" aria-label={label} title={label}>
                            <Icon name={resolveTechIcon(label)} class="hex-tech-icon" aria-hidden="true" />
                          </li>
                        );
                      })}
                    </ul>
                  </div>

                  <dl class="project-facts">
                    <div>
                      <dt class="micro-label">{projectLabels.problem}</dt>
                      <dd class="mt-1 text-[15px] leading-relaxed text-muted md:text-base">{project.problem}</dd>
                    </div>
                    <div>
                      <dt class="micro-label">{projectLabels.solution}</dt>
                      <dd class="mt-1 text-[15px] leading-relaxed text-muted md:text-base">{project.solution}</dd>
                    </div>
                    <div>
                      <dt class="micro-label">{projectLabels.challenges}</dt>
                      <dd class="mt-1 text-[15px] leading-relaxed text-muted md:text-base">{project.challenges}</dd>
                    </div>
                    <div>
                      <dt class="micro-label">{projectLabels.impact}</dt>
                      <dd class="mt-1 text-[15px] leading-relaxed text-muted md:text-base">{project.impact}</dd>
                    </div>
                  </dl>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .details-panel[hidden] {
    display: none;
  }

  .details-panel[data-panel-state="active"] {
    animation: details-panel-in 240ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .details-panel-inner {
    padding-top: 1.9rem;
  }

  .details-panel-projects .details-panel-inner {
    padding-top: 0.9rem;
  }

  .project-details {
    position: relative;
    overflow: hidden;
    background: transparent;
    transition:
      border-color 260ms ease,
      box-shadow 360ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 360ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-details::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(112deg, rgba(89, 123, 150, 0.12) 0%, rgba(89, 123, 150, 0) 42%);
    opacity: 0;
    transition: opacity 260ms ease;
  }

  .project-kind-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    padding: 0.34rem 0.68rem;
    border: 1px solid color-mix(in oklab, var(--color-border) 58%, rgba(232, 241, 249, 0.48));
    border-radius: 999px;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--color-text) 90%, #e5eef8);
    background: transparent;
  }

  .project-kind-badge::before {
    content: "";
    width: 0.34rem;
    height: 0.34rem;
    border-radius: 999px;
    background: rgba(231, 240, 249, 0.86);
    box-shadow: 0 0 8px rgba(231, 240, 249, 0.46);
  }

  .project-details-grid {
    display: grid;
    gap: 1.65rem;
  }

  .project-side {
    display: grid;
    gap: 1.1rem;
    align-content: start;
  }

  .project-list {
    margin-top: 0.5rem;
  }

  .project-cover {
    position: relative;
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--color-border) 72%, transparent);
    border-radius: 0.8rem;
    aspect-ratio: 16 / 7;
    background: color-mix(in oklab, var(--color-surface) 82%, black 18%);
  }

  .project-cover-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(0.84) contrast(0.9);
    transform: scale(1.02);
    transition:
      transform 300ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 300ms ease;
  }

  .project-cover-wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(8, 12, 18, 0.08) 0%, rgba(8, 12, 18, 0.42) 100%),
      linear-gradient(110deg, rgba(77, 131, 166, 0.14) 0%, rgba(77, 131, 166, 0) 62%);
    pointer-events: none;
    transition: background 280ms ease;
  }

  .project-facts {
    display: grid;
    gap: 1rem;
  }

  .project-facts > div {
    border-left: 1px solid color-mix(in oklab, var(--color-border) 70%, transparent);
    padding-left: 0.9rem;
  }

  .project-tech {
    position: relative;
    border: 1px solid color-mix(in oklab, var(--color-border) 70%, transparent);
    border-radius: 0.8rem;
    padding: 0.9rem;
    background: color-mix(in oklab, var(--color-surface) 87%, black 13%);
  }

  .project-tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.72rem;
  }

  .hex-tech-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.2rem;
    height: 2.8rem;
    border: 1.4px solid rgba(234, 242, 250, 0.9);
    background: color-mix(in oklab, var(--color-surface) 76%, black 24%);
    clip-path: polygon(25% 5%, 75% 5%, 100% 50%, 75% 95%, 25% 95%, 0 50%);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.08),
      0 12px 24px -16px rgba(209, 224, 238, 0.62);
    transition:
      border-color 180ms ease,
      background-color 220ms ease,
      box-shadow 220ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hex-tech-icon {
    width: 1.36rem;
    height: 1.36rem;
    color: #f4f8ff;
  }

  @media (hover: hover) and (pointer: fine) {
    .project-details:hover,
    .project-details:focus-within {
      box-shadow: 0 22px 36px -24px rgba(203, 221, 238, 0.48);
      transform: translateY(-3px);
    }

    .hex-tech-badge:hover,
    .hex-tech-badge:focus-within {
      transform: translateY(-1px);
      border-color: rgba(241, 248, 255, 0.98);
    }
  }

  .hex-tech-badge:focus-within,
  .project-details:focus-within {
    outline: 2px solid rgba(77, 131, 166, 0.72);
    outline-offset: 3px;
  }

  @media (min-width: 1024px) {
    .project-details-grid {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.25fr);
      align-items: start;
      gap: 2.25rem;
    }

    .project-side {
      gap: 1.35rem;
    }

    .project-tech {
      padding: 1.08rem;
    }

    .project-facts {
      gap: 1.05rem;
    }
  }

  @keyframes details-panel-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 767px) {
    .details-panel-inner {
      padding-top: 1.25rem;
    }

    .project-details {
      padding: 1.1rem;
    }

    .project-facts > div {
      padding-left: 0.7rem;
    }

    .project-list {
      margin-top: 0.2rem;
    }

    .project-cover {
      aspect-ratio: 16 / 9;
    }

    .project-tech {
      padding: 0.7rem;
    }

    .project-tech-list {
      gap: 0.56rem;
    }

    .hex-tech-badge {
      width: 2.7rem;
      height: 2.36rem;
    }

    .hex-tech-icon {
      width: 1.12rem;
      height: 1.12rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .details-panel,
    .project-details,
    .project-details::before,
    .hex-tech-badge,
    .project-cover-media,
    .project-cover-wash {
      animation: none;
      transition: none;
    }
  }
</style>
