---
import { Icon } from "astro-icon/components";
import { getProjectDetailId } from "../../utils/project-detail";

interface ProjectCover {
  src: string;
  alt: string;
}

interface ProjectItem {
  title: string;
  summary?: string;
  liveUrl?: string;
  statusBadge?: {
    label: string;
    tone?: "blue" | "neutral";
  };
  architecture: string;
  stack: string;
  problem: string;
  solution: string;
  challenges: string;
  impact: string;
}

interface Props {
  items: ProjectItem[];
  overline: string;
  title: string;
  intro: string;
  projectLabels: {
    problem: string;
    architecture: string;
    solution: string;
    challenges: string;
    impact: string;
    liveSite: string;
  };
  resolveTechIcon: (tech: string) => string;
  resolveProjectCover: (index: number) => ProjectCover;
}

const { items, overline, title, intro, projectLabels, resolveTechIcon, resolveProjectCover } = Astro.props as Props;

const projectSummariesByIndex = [
  "Integracion de Sistemas",
  "Procesamiento masivo",
  "Landing + app + backend",
  "Trazabilidad en tiempo real",
] as const;

const resolveProjectSummary = (project: ProjectItem, index: number) => {
  return projectSummariesByIndex[index] ?? project.architecture;
};

const getBadgeToneClass = (tone?: "blue" | "neutral") => {
  return tone === "blue" ? "project-kind-badge--blue" : "project-kind-badge--neutral";
};
---

<section
  class="details-panel border-t border-border/50"
>
  <div class="container-shell pt-[0.9rem] md:pt-[1.9rem]">
    <header class="mb-4 grid max-w-[74ch] gap-[0.62rem] md:mb-[1.55rem] md:gap-[0.7rem]" data-reveal="up">
      <p class="micro-label">{overline}</p>
      <h2 class="m-0 text-balance text-[clamp(1.7rem,4vw,2.5rem)] font-[620] leading-[1.04] tracking-[-0.038em] text-text">{title}</h2>
      <p class="m-0 max-w-[62ch] text-pretty text-[clamp(0.98rem,1.7vw,1.08rem)] leading-[1.68] text-muted">{intro}</p>
    </header>

    <div class="mt-[0.14rem] grid gap-6 md:mt-2 md:gap-7" data-reveal-group data-reveal-stagger-mobile="64" data-reveal-stagger-desktop="54">
      {
        items.map((project: ProjectItem, index: number) => {
          const cover = resolveProjectCover(index);
          const projectSummary = resolveProjectSummary(project, index);
          const isReversed = index % 2 === 1;
          const liveSiteLabel = project.liveUrl
            ? new URL(project.liveUrl).hostname.replace(/^www\./, "")
            : null;

          return (
            <article
              id={getProjectDetailId(project, index)}
              class={`project-details relative grid gap-[1.1rem] overflow-hidden bg-transparent p-[1.08rem] opacity-90 transition-opacity duration-[260ms] ease-out md:p-7 md:opacity-80 ${isReversed ? "project-details--reversed" : ""}`}
              data-reveal="up"
              data-project-item
              data-project-detail-anchor
              data-project-summary={projectSummary}
              tabindex="-1"
            >
              <div class={`grid gap-[1.95rem] lg:items-start lg:gap-10 ${isReversed ? "lg:grid-cols-[minmax(0,1.25fr)_minmax(0,0.95fr)]" : "lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.25fr)]"}`}>
                <header class={`grid gap-4 ${isReversed ? "lg:col-start-2 lg:row-start-1" : ""}`}>
                  <div class="flex flex-wrap items-start justify-between gap-x-[1.15rem] gap-y-[0.9rem]">
                    <h3 class="project-title m-0 max-w-[900px] text-balance text-[clamp(1.34rem,3.6vw,2.06rem)] font-[620] leading-[1.16] tracking-[-0.024em] text-text transition-[color,text-shadow] duration-[240ms] ease-out">
                      {project.title}
                    </h3>
                    <div class="flex flex-wrap justify-end gap-[0.55rem]">
                      <span class="project-kind-badge project-kind-badge--neutral inline-flex items-center gap-[0.38rem] rounded-full px-[0.68rem] py-[0.34rem] text-[0.6rem] font-semibold uppercase tracking-[0.09em]">
                        Caso aplicado
                      </span>
                      {project.statusBadge ? (
                        <span
                          class={`project-kind-badge inline-flex items-center gap-[0.38rem] rounded-full px-[0.68rem] py-[0.34rem] text-[0.6rem] font-semibold uppercase tracking-[0.09em] ${getBadgeToneClass(project.statusBadge.tone)}`}
                        >
                          {project.statusBadge.label}
                        </span>
                      ) : null}
                    </div>
                  </div>
                  <figure class="project-cover relative aspect-[16/9] overflow-hidden rounded-[0.8rem] border md:aspect-[16/7]" aria-hidden="true">
                    <img
                      src={cover.src}
                      alt={cover.alt}
                      loading="lazy"
                      decoding="async"
                      class="project-cover-media h-full w-full object-cover object-center"
                    />
                    <span class="project-cover-wash" aria-hidden="true"></span>
                  </figure>
                  {project.summary ? (
                    <p class="project-summary m-0 max-w-[58ch] text-pretty text-[clamp(1rem,1.9vw,1.14rem)] font-medium leading-[1.55] text-[color:color-mix(in_oklab,var(--color-text)_92%,#eaf2fb)]">
                      {project.summary}
                    </p>
                  ) : null}
                  <div class="grid gap-[0.38rem]">
                    <span class="micro-label project-architecture-label tracking-[0.085em]">{projectLabels.architecture}</span>
                    <p class="project-architecture m-0 max-w-[66ch] text-pretty text-[clamp(0.96rem,1.65vw,1.04rem)] font-[430] leading-[1.7] tracking-[0.002em] text-muted transition-colors duration-[240ms] ease-out">
                      {project.architecture}
                    </p>
                  </div>
                  {project.liveUrl ? (
                    <div class="flex flex-wrap items-center gap-x-4 gap-y-3">
                      <span class="micro-label project-link-label tracking-[0.085em]">{projectLabels.liveSite}</span>
                      <a
                        href={project.liveUrl}
                        class="project-live-link inline-flex items-center gap-[0.38rem] text-[0.92rem] leading-[1.4] text-[color:color-mix(in_oklab,var(--color-text)_90%,#eef6ff)] transition-[color,transform] duration-[220ms] ease-out"
                        target="_blank"
                        rel="noreferrer"
                      >
                        <span>{liveSiteLabel}</span>
                        <Icon name="lucide:arrow-up-right" class="h-[0.95rem] w-[0.95rem] transition-transform duration-[220ms] ease-out" aria-hidden="true" />
                      </a>
                    </div>
                  ) : null}
                </header>

                <div class={`grid content-start gap-[1.08rem] lg:gap-[1.45rem] ${isReversed ? "lg:col-start-1 lg:row-start-1" : ""}`}>
                  <div class="project-impact-callout grid gap-[0.45rem] rounded-[0.85rem] border px-[1.05rem] py-4">
                    <span class="micro-label project-impact-label tracking-[0.085em]">{projectLabels.impact}</span>
                    <p class="project-impact-copy m-0 max-w-[34ch] text-pretty text-[clamp(0.94rem,1.55vw,1.02rem)] leading-[1.62] text-[color:color-mix(in_oklab,var(--color-text)_88%,#e6effa)]">
                      {project.impact}
                    </p>
                  </div>

                  <dl class="grid gap-[1.08rem] lg:gap-[1.12rem]">
                    <div class="project-fact-item grid gap-[0.42rem] border-l pl-[0.72rem] md:pl-[0.92rem]">
                      <dt class="micro-label project-fact-label tracking-[0.075em]">{projectLabels.problem}</dt>
                      <dd class="project-fact-value m-0 max-w-[52ch] text-pretty text-[clamp(0.92rem,1.5vw,1rem)] leading-[1.66] tracking-[0.001em] text-muted transition-colors duration-[220ms] ease-out">
                        {project.problem}
                      </dd>
                    </div>
                    <div class="project-fact-item grid gap-[0.42rem] border-l pl-[0.72rem] md:pl-[0.92rem]">
                      <dt class="micro-label project-fact-label tracking-[0.075em]">{projectLabels.challenges}</dt>
                      <dd class="project-fact-value m-0 max-w-[52ch] text-pretty text-[clamp(0.92rem,1.5vw,1rem)] leading-[1.66] tracking-[0.001em] text-muted transition-colors duration-[220ms] ease-out">
                        {project.challenges}
                      </dd>
                    </div>
                    <div class="project-fact-item grid gap-[0.42rem] border-l pl-[0.72rem] md:pl-[0.92rem]">
                      <dt class="micro-label project-fact-label tracking-[0.075em]">{projectLabels.solution}</dt>
                      <dd class="project-fact-value m-0 max-w-[52ch] text-pretty text-[clamp(0.92rem,1.5vw,1rem)] leading-[1.66] tracking-[0.001em] text-muted transition-colors duration-[220ms] ease-out">
                        {project.solution}
                      </dd>
                    </div>
                  </dl>

                  <div
                    class="project-tech relative flex w-full max-w-full flex-wrap items-center justify-between gap-x-[0.84rem] gap-y-[0.72rem] rounded-[0.8rem] border p-[0.72rem] transition-[border-color,background-color] duration-[220ms] ease-out md:p-[0.9rem] lg:p-[1.08rem]"
                    aria-label={`Tecnologias clave de ${project.title}`}
                  >
                    <div
                      class={`project-tech-meta flex min-h-[1.45rem] basis-full items-center ${isReversed ? "justify-start text-left md:justify-end md:text-right" : "justify-start text-left"} md:min-h-[1.6rem] md:flex-[0_1_18ch]`}
                      aria-hidden="true"
                    >
                      <span
                        class={`project-tech-summary inline-flex min-w-0 max-w-full items-center text-left text-[clamp(0.74rem,1.28vw,0.86rem)] font-[560] uppercase leading-[1.22] tracking-[0.035em] text-[color:color-mix(in_oklab,var(--color-text)_82%,#d8e6f6)] transition-[color,opacity,transform] duration-[170ms] ease-out md:min-w-[min(18ch,100%)] md:leading-[1.3] ${isReversed ? "md:justify-end md:text-right" : "md:justify-start"}`}
                        data-tech-label
                      >
                        {projectSummary}
                      </span>
                    </div>
                    <ul
                      class={`project-tech-list flex basis-full flex-wrap items-center gap-x-[0.72rem] gap-y-[0.52rem] justify-start md:gap-y-[0.68rem] ${isReversed ? "md:order-1 md:mr-auto md:basis-auto md:flex-1 md:justify-start" : "md:ml-auto md:basis-auto md:flex-1 md:justify-end"}`}
                      role="list"
                    >
                      {project.stack.split(",").map((tech: string) => {
                        const label = tech.trim();

                        return (
                          <li
                            class="hex-tech-badge inline-flex h-[2.36rem] w-[2.7rem] items-center justify-center md:h-[2.8rem] md:w-[3.2rem]"
                            role="listitem"
                            aria-label={label}
                            title={label}
                            tabindex="0"
                            data-tech-name={label}
                          >
                            <Icon name={resolveTechIcon(label)} class="h-[1.12rem] w-[1.12rem] text-[#f4f8ff] md:h-[1.36rem] md:w-[1.36rem]" aria-hidden="true" />
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>

    <div class="mt-10 flex flex-wrap gap-3" data-reveal="up" data-reveal-delay="130">
      <Icon name="lucide:arrow-left" class="h-3.5 w-3.5" aria-hidden="true" />
      <a href="/#proyectos" class="inline-cta text-xs md:text-sm">Ir a proyectos</a>
    </div>
  </div>
</section>

<style>
  .project-details:hover,
  .project-details.is-active {
    opacity: 1;
  }

  .project-kind-badge {
    white-space: nowrap;
  }

  .project-kind-badge::before {
    content: "";
    width: 0.34rem;
    height: 0.34rem;
    border-radius: 999px;
  }

  .project-kind-badge--neutral {
    border: 1px solid color-mix(in oklab, var(--color-border) 58%, rgba(232, 241, 249, 0.48));
    color: color-mix(in oklab, var(--color-text) 90%, #e5eef8);
    background: transparent;
  }

  .project-kind-badge--neutral::before {
    background: rgba(231, 240, 249, 0.86);
    box-shadow: 0 0 8px rgba(231, 240, 249, 0.46);
  }

  .project-kind-badge--blue {
    border: 1px solid rgba(143, 202, 255, 0.42);
    color: #edf7ff;
    background: linear-gradient(135deg, rgba(35, 105, 184, 0.92), rgba(25, 84, 152, 0.84));
    box-shadow: 0 18px 28px -20px rgba(26, 88, 157, 0.9);
  }

  .project-kind-badge--blue::before {
    background: #a9d5ff;
    box-shadow: 0 0 10px rgba(169, 213, 255, 0.8);
  }

  .project-cover {
    border: 1px solid color-mix(in oklab, var(--color-border) 72%, transparent);
    background: color-mix(in oklab, var(--color-surface) 82%, black 18%);
  }

  .project-cover-media {
    filter: saturate(0.84) contrast(0.9);
    transform: scale(1.02);
    transition:
      transform 300ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 300ms ease;
  }

  .project-cover-wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(8, 12, 18, 0.08) 0%, rgba(8, 12, 18, 0.42) 100%),
      linear-gradient(110deg, rgba(77, 131, 166, 0.14) 0%, rgba(77, 131, 166, 0) 62%);
    pointer-events: none;
    transition: background 280ms ease;
  }

  .project-impact-callout {
    border: 1px solid color-mix(in oklab, var(--color-border) 64%, rgba(233, 243, 252, 0.26));
    background:
      linear-gradient(135deg, rgba(230, 239, 248, 0.06), rgba(230, 239, 248, 0.01)),
      color-mix(in oklab, var(--color-surface) 88%, black 12%);
  }

  .project-fact-item {
    border-left-color: color-mix(in oklab, var(--color-border) 70%, transparent);
  }

  .project-tech {
    border-color: color-mix(in oklab, var(--color-border) 70%, transparent);
    background: color-mix(in oklab, var(--color-surface) 87%, black 13%);
  }

  .project-tech-summary {
    will-change: opacity, transform;
  }

  .project-tech-summary.is-switching {
    opacity: 0;
    transform: translateY(-0.12rem);
  }

  .hex-tech-badge {
    border: 1.4px solid rgba(234, 242, 250, 0.9);
    background: color-mix(in oklab, var(--color-surface) 76%, black 24%);
    clip-path: polygon(25% 5%, 75% 5%, 100% 50%, 75% 95%, 25% 95%, 0 50%);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.08),
      0 12px 24px -16px rgba(209, 224, 238, 0.62);
    transition:
      border-color 180ms ease,
      background-color 220ms ease,
      box-shadow 220ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project-details.is-active .project-title {
    color: color-mix(in oklab, var(--color-text) 99%, #f5f9ff);
    text-shadow: 0 4px 26px rgba(218, 230, 244, 0.2);
  }

  .project-details.is-active .project-kind-badge,
  .project-details.is-active .project-fact-label,
  .project-details.is-active .project-tech-summary,
  .project-details.is-active .project-architecture-label,
  .project-details.is-active .project-impact-label,
  .project-details.is-active .project-link-label,
  .project-details.is-active .project-live-link {
    color: color-mix(in oklab, var(--color-text) 98%, #f2f8ff);
  }

  .project-details.is-active .project-summary,
  .project-details.is-active .project-architecture,
  .project-details.is-active .project-fact-value {
    color: color-mix(in oklab, var(--color-muted) 58%, #e4eefb);
  }

  .project-details.is-active .project-impact-copy {
    color: color-mix(in oklab, var(--color-text) 90%, #f3f8ff);
  }

  .project-details.is-active .project-impact-callout {
    border-color: color-mix(in oklab, var(--color-border) 34%, rgba(233, 243, 252, 0.82));
    background:
      linear-gradient(135deg, rgba(236, 244, 251, 0.1), rgba(236, 244, 251, 0.02)),
      color-mix(in oklab, var(--color-surface) 82%, black 18%);
  }

  .project-details.is-active .project-fact-item {
    border-left-color: color-mix(in oklab, var(--color-border) 38%, rgba(231, 241, 251, 0.84));
  }

  .project-details.is-active .project-tech {
    border-color: color-mix(in oklab, var(--color-border) 36%, rgba(233, 243, 252, 0.8));
    background: color-mix(in oklab, var(--color-surface) 75%, black 25%);
  }

  .project-details.is-active .hex-tech-badge {
    border-color: rgba(244, 250, 255, 0.98);
    background: color-mix(in oklab, var(--color-surface) 70%, black 30%);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.16),
      0 14px 28px -14px rgba(218, 233, 248, 0.76);
  }

  .project-details.is-active .hex-tech-badge svg {
    color: #fbfdff;
  }

  @media (hover: hover) and (pointer: fine) {
    .project-cover:hover .project-cover-media,
    .project-details:hover .project-cover-media,
    .project-details.is-active .project-cover-media,
    .project-cover:focus-within .project-cover-media {
      transform: scale(1.06);
      filter: saturate(0.96) contrast(0.95);
    }

    .project-cover:hover .project-cover-wash,
    .project-details:hover .project-cover-wash,
    .project-details.is-active .project-cover-wash,
    .project-cover:focus-within .project-cover-wash {
      background:
        linear-gradient(180deg, rgba(8, 12, 18, 0.02) 0%, rgba(8, 12, 18, 0.28) 100%),
        linear-gradient(110deg, rgba(77, 131, 166, 0.2) 0%, rgba(77, 131, 166, 0) 62%);
    }

    .hex-tech-badge:hover,
    .hex-tech-badge:focus-within {
      transform: translateY(-1px);
      border-color: rgba(241, 248, 255, 0.98);
    }

    .project-live-link:hover,
    .project-live-link:focus-visible {
      color: #f5faff;
    }

    .project-live-link:hover svg,
    .project-live-link:focus-visible svg {
      transform: translate3d(2px, -2px, 0);
    }
  }

  .project-live-link:focus-visible {
    outline: 2px solid rgba(77, 131, 166, 0.72);
    outline-offset: 4px;
    border-radius: 0.35rem;
  }

  .hex-tech-badge:focus-within {
    outline: 2px solid rgba(77, 131, 166, 0.72);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .details-panel,
    .project-details,
    .hex-tech-badge,
    .project-cover-media,
    .project-cover-wash,
    .project-tech-summary {
      animation: none;
      transition: none;
    }
  }
</style>

<script>
  const initProjectTechSummarySwap = () => {
    const panels = document.querySelectorAll(".project-details[data-project-summary]");

    panels.forEach((panel) => {
      if (!(panel instanceof HTMLElement) || panel.dataset.techSummaryReady === "true") {
        return;
      }

      const summary = panel.dataset.projectSummary ?? "";
      const label = panel.querySelector("[data-tech-label]");
      const badges = panel.querySelectorAll("[data-tech-name]");

      if (!(label instanceof HTMLElement) || badges.length === 0) {
        return;
      }

      label.textContent = summary;
      let animationTimer = 0;

      const setLabel = (value: string) => {
        if (label.textContent === value) {
          return;
        }

        if (animationTimer) {
          window.clearTimeout(animationTimer);
          animationTimer = 0;
        }

        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        if (reduceMotion) {
          label.classList.remove("is-switching");
          label.textContent = value;
          return;
        }

        label.classList.add("is-switching");

        animationTimer = window.setTimeout(() => {
          label.textContent = value;
          label.classList.remove("is-switching");
          animationTimer = 0;
        }, 180);
      };

      const resetLabel = () => {
        setLabel(summary);
      };

      badges.forEach((badge) => {
        if (!(badge instanceof HTMLElement)) {
          return;
        }

        const techName = badge.dataset.techName ?? summary;

        badge.addEventListener("mouseenter", () => setLabel(techName));
        badge.addEventListener("focus", () => setLabel(techName));
        badge.addEventListener("mouseleave", resetLabel);
        badge.addEventListener("blur", resetLabel);
      });

      panel.dataset.techSummaryReady = "true";
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initProjectTechSummarySwap, { once: true });
  } else {
    initProjectTechSummarySwap();
  }
</script>
