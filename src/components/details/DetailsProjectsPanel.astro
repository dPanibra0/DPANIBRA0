---
import { Icon } from "astro-icon/components";
import { getProjectDetailId } from "../../utils/project-detail";

interface ProjectCover {
  src: string;
  alt: string;
}

interface ProjectItem {
  title: string;
  architecture: string;
  stack: string;
  problem: string;
  solution: string;
  challenges: string;
  impact: string;
}

interface Props {
  items: ProjectItem[];
  projectLabels: {
    problem: string;
    solution: string;
    challenges: string;
    impact: string;
  };
  resolveTechIcon: (tech: string) => string;
  resolveProjectCover: (index: number) => ProjectCover;
}

const { items, projectLabels, resolveTechIcon, resolveProjectCover } = Astro.props;

const projectSummariesByIndex = [
  "Integracion de Sistemas",
  "Procesamiento masivo",
  "Automatizacion operativa",
  "Trazabilidad en tiempo real",
] as const;

const resolveProjectSummary = (project: ProjectItem, index: number) => {
  return projectSummariesByIndex[index] ?? project.architecture;
};
---

<section
  id="panel-proyectos"
  role="tabpanel"
  aria-labelledby="tab-proyectos"
  class="details-panel details-panel-projects border-t border-border/50"
  data-tab-panel="proyectos"
  data-panel-state="inactive"
  hidden
>
  <div class="container-shell details-panel-inner">
    <div class="project-list grid gap-6 md:gap-7" data-reveal-group data-reveal-stagger-mobile="64" data-reveal-stagger-desktop="54">
      {
        items.map((project, index) => {
          const cover = resolveProjectCover(index);
          const projectSummary = resolveProjectSummary(project, index);

          return (
            <article
              id={getProjectDetailId(project, index)}
              class={`project-details p-5 md:p-7 ${index % 2 === 1 ? "project-details--reversed" : ""}`}
              data-reveal="up"
              data-project-item
              data-project-detail-anchor
              data-project-summary={projectSummary}
              tabindex="-1"
            >
              <div class="project-details-grid">
                <header class="project-hero">
                  <div class="project-heading-row">
                    <h3 class="project-title">{project.title}</h3>
                    <span class="project-kind-badge">Caso aplicado</span>
                  </div>
                  <figure class="project-cover" aria-hidden="true">
                    <img
                      src={cover.src}
                      alt={cover.alt}
                      loading="lazy"
                      decoding="async"
                      class="project-cover-media"
                    />
                    <span class="project-cover-wash" aria-hidden="true"></span>
                  </figure>
                  <p class="project-architecture">{project.architecture}</p>
                </header>

                <div class="project-side">
                  <dl class="project-facts">
                    <div>
                      <dt class="micro-label project-fact-label">{projectLabels.problem}</dt>
                      <dd class="project-fact-value">{project.problem}</dd>
                    </div>
                    <div>
                      <dt class="micro-label project-fact-label">{projectLabels.solution}</dt>
                      <dd class="project-fact-value">{project.solution}</dd>
                    </div>
                    <div>
                      <dt class="micro-label project-fact-label">{projectLabels.challenges}</dt>
                      <dd class="project-fact-value">{project.challenges}</dd>
                    </div>
                    <div>
                      <dt class="micro-label project-fact-label">{projectLabels.impact}</dt>
                      <dd class="project-fact-value">{project.impact}</dd>
                    </div>
                  </dl>

                  <div
                    class={`project-tech ${index % 2 === 1 ? "project-tech--reversed" : ""}`}
                    aria-label={`Tecnologias clave de ${project.title}`}
                  >
                    <div class="project-tech-meta" aria-hidden="true">
                      <span class="project-tech-summary" data-tech-label>{projectSummary}</span>
                    </div>
                    <ul class="project-tech-list" role="list">
                      {project.stack.split(",").map((tech) => {
                        const label = tech.trim();

                        return (
                          <li
                            class="hex-tech-badge"
                            role="listitem"
                            aria-label={label}
                            title={label}
                            tabindex="0"
                            data-tech-name={label}
                          >
                            <Icon name={resolveTechIcon(label)} class="hex-tech-icon" aria-hidden="true" />
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>

    <div class="mt-10 flex flex-wrap gap-3" data-reveal="up" data-reveal-delay="130">
      <Icon name="lucide:arrow-left" class="h-3.5 w-3.5" aria-hidden="true" />
      <a href="/#proyectos" class="inline-cta text-xs md:text-sm">Ir a proyectos</a>
    </div>
  </div>
</section>

<style>
  .details-panel[hidden] {
    display: none;
  }

  .details-panel-inner {
    padding-top: 1.9rem;
  }

  .details-panel-projects .details-panel-inner {
    padding-top: 0.9rem;
  }

  .project-details {
    position: relative;
    overflow: hidden;
    background: transparent;
    display: grid;
    gap: 1.1rem;
    opacity: 0.68;
    transition: opacity 260ms ease;
  }

  .project-details:hover,
  .project-details.is-active {
    opacity: 1;
  }

  .project-kind-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    padding: 0.34rem 0.68rem;
    border: 1px solid color-mix(in oklab, var(--color-border) 58%, rgba(232, 241, 249, 0.48));
    border-radius: 999px;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--color-text) 90%, #e5eef8);
    background: transparent;
  }

  .project-kind-badge::before {
    content: "";
    width: 0.34rem;
    height: 0.34rem;
    border-radius: 999px;
    background: rgba(231, 240, 249, 0.86);
    box-shadow: 0 0 8px rgba(231, 240, 249, 0.46);
  }

  .project-details-grid {
    display: grid;
    gap: 1.8rem;
  }

  .project-hero {
    display: grid;
    gap: 1rem;
  }

  .project-heading-row {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.9rem 1.15rem;
  }

  .project-title {
    max-width: 900px;
    margin: 0;
    text-wrap: balance;
    font-size: clamp(1.34rem, 3.6vw, 2.06rem);
    font-weight: 620;
    line-height: 1.16;
    letter-spacing: -0.024em;
    color: var(--color-text);
    transition: color 240ms ease, text-shadow 260ms ease;
  }

  .project-architecture {
    margin: 0;
    max-width: 72ch;
    text-wrap: pretty;
    font-size: clamp(0.96rem, 1.65vw, 1.04rem);
    font-weight: 430;
    line-height: 1.7;
    letter-spacing: 0.002em;
    color: var(--color-muted);
    transition: color 240ms ease;
  }

  .project-side {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .project-list {
    margin-top: 0.5rem;
  }

  .project-cover {
    position: relative;
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--color-border) 72%, transparent);
    border-radius: 0.8rem;
    aspect-ratio: 16 / 7;
    background: color-mix(in oklab, var(--color-surface) 82%, black 18%);
  }

  .project-cover-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(0.84) contrast(0.9);
    transform: scale(1.02);
    transition:
      transform 300ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 300ms ease;
  }

  .project-cover-wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(8, 12, 18, 0.08) 0%, rgba(8, 12, 18, 0.42) 100%),
      linear-gradient(110deg, rgba(77, 131, 166, 0.14) 0%, rgba(77, 131, 166, 0) 62%);
    pointer-events: none;
    transition: background 280ms ease;
  }

  .project-facts {
    display: grid;
    gap: 1.08rem;
  }

  .project-facts > div {
    border-left: 1px solid color-mix(in oklab, var(--color-border) 70%, transparent);
    padding-left: 0.92rem;
    display: grid;
    gap: 0.42rem;
  }

  .project-fact-label {
    letter-spacing: 0.075em;
    transition: color 220ms ease;
  }

  .project-fact-value {
    margin: 0;
    text-wrap: pretty;
    font-size: clamp(0.92rem, 1.5vw, 1rem);
    line-height: 1.66;
    letter-spacing: 0.001em;
    color: var(--color-muted);
    transition: color 220ms ease;
  }

  .project-tech {
    position: relative;
    width: 100%;
    max-width: 100%;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.72rem 0.84rem;
    border: 1px solid color-mix(in oklab, var(--color-border) 70%, transparent);
    border-radius: 0.8rem;
    padding: 0.9rem;
    background: color-mix(in oklab, var(--color-surface) 87%, black 13%);
    transition: border-color 220ms ease, background-color 220ms ease;
  }

  .project-tech-meta {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    min-height: 1.6rem;
    flex: 0 1 18ch;
    margin-bottom: 0;
  }

  .project-tech-summary {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    min-width: min(18ch, 100%);
    margin: 0;
    text-align: left;
    font-size: clamp(0.74rem, 1.28vw, 0.86rem);
    font-weight: 560;
    line-height: 1.3;
    letter-spacing: 0.035em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--color-text) 82%, #d8e6f6);
    transition: color 220ms ease;
  }

  .project-tech-summary {
    transition:
      opacity 170ms ease,
      transform 170ms ease;
    will-change: opacity, transform;
  }

  .project-tech-summary.is-switching {
    opacity: 0;
    transform: translateY(-0.12rem);
  }

  .project-tech-list {
    display: flex;
    flex: 1 1 18rem;
    flex-wrap: wrap;
    gap: 0.68rem 0.72rem;
    align-items: center;
    justify-content: flex-end;
    margin-inline-start: auto;
  }

  .project-tech--reversed .project-tech-meta {
    order: 2;
    justify-content: flex-end;
    text-align: right;
  }

  .project-tech--reversed .project-tech-summary {
    justify-content: flex-end;
    text-align: right;
  }

  .project-tech--reversed .project-tech-list {
    order: 1;
    justify-content: flex-start;
    margin-inline-start: 0;
    margin-inline-end: auto;
  }

  .hex-tech-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.2rem;
    height: 2.8rem;
    border: 1.4px solid rgba(234, 242, 250, 0.9);
    background: color-mix(in oklab, var(--color-surface) 76%, black 24%);
    clip-path: polygon(25% 5%, 75% 5%, 100% 50%, 75% 95%, 25% 95%, 0 50%);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.08),
      0 12px 24px -16px rgba(209, 224, 238, 0.62);
    transition:
      border-color 180ms ease,
      background-color 220ms ease,
      box-shadow 220ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project-details.is-active .project-title {
    color: color-mix(in oklab, var(--color-text) 99%, #f5f9ff);
    text-shadow: 0 4px 26px rgba(218, 230, 244, 0.2);
  }

  .project-details.is-active .project-kind-badge,
  .project-details.is-active .project-fact-label,
  .project-details.is-active .project-tech-summary {
    color: color-mix(in oklab, var(--color-text) 98%, #f2f8ff);
  }

  .project-details.is-active .project-architecture,
  .project-details.is-active .project-fact-value {
    color: color-mix(in oklab, var(--color-muted) 58%, #e4eefb);
  }

  .project-details.is-active .project-facts > div {
    border-left-color: color-mix(in oklab, var(--color-border) 38%, rgba(231, 241, 251, 0.84));
  }

  .project-details.is-active .project-tech {
    border-color: color-mix(in oklab, var(--color-border) 36%, rgba(233, 243, 252, 0.8));
    background: color-mix(in oklab, var(--color-surface) 75%, black 25%);
  }

  .project-details.is-active .hex-tech-badge {
    border-color: rgba(244, 250, 255, 0.98);
    background: color-mix(in oklab, var(--color-surface) 70%, black 30%);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.16),
      0 14px 28px -14px rgba(218, 233, 248, 0.76);
  }

  .project-details.is-active .hex-tech-icon {
    color: #fbfdff;
  }

  .hex-tech-icon {
    width: 1.36rem;
    height: 1.36rem;
    color: #f4f8ff;
  }

  @media (hover: hover) and (pointer: fine) {
    .project-cover:hover .project-cover-media,
    .project-details:hover .project-cover-media,
    .project-details.is-active .project-cover-media,
    .project-cover:focus-within .project-cover-media {
      transform: scale(1.06);
      filter: saturate(0.96) contrast(0.95);
    }

    .project-cover:hover .project-cover-wash,
    .project-details:hover .project-cover-wash,
    .project-details.is-active .project-cover-wash,
    .project-cover:focus-within .project-cover-wash {
      background:
        linear-gradient(180deg, rgba(8, 12, 18, 0.02) 0%, rgba(8, 12, 18, 0.28) 100%),
        linear-gradient(110deg, rgba(77, 131, 166, 0.2) 0%, rgba(77, 131, 166, 0) 62%);
    }

    .hex-tech-badge:hover,
    .hex-tech-badge:focus-within {
      transform: translateY(-1px);
      border-color: rgba(241, 248, 255, 0.98);
    }
  }

  .hex-tech-badge:focus-within {
    outline: 2px solid rgba(77, 131, 166, 0.72);
    outline-offset: 3px;
  }

  @media (min-width: 1024px) {
    .project-details-grid {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.25fr);
      align-items: start;
      gap: 2.4rem;
    }

    .project-details--reversed .project-details-grid {
      grid-template-columns: minmax(0, 1.25fr) minmax(0, 0.95fr);
    }

    .project-details--reversed .project-hero {
      grid-column: 2;
      grid-row: 1;
    }

    .project-details--reversed .project-side {
      grid-column: 1;
      grid-row: 1;
    }

    .project-side {
      gap: 1.45rem;
    }

    .project-tech {
      padding: 1.08rem;
    }

    .project-facts {
      gap: 1.12rem;
    }
  }

  @media (max-width: 767px) {
    .details-panel-inner {
      padding-top: 1.25rem;
    }

    .project-details {
      padding: 1.08rem;
    }

    .project-facts > div {
      padding-left: 0.72rem;
    }

    .project-list {
      margin-top: 0.14rem;
    }

    .project-cover {
      aspect-ratio: 16 / 9;
    }

    .project-tech {
      padding: 0.72rem;
    }

    .project-tech-meta {
      min-height: 1.45rem;
      flex-basis: 100%;
      order: 1;
      justify-content: flex-start;
      text-align: left;
    }

    .project-tech-summary {
      max-width: 100%;
      line-height: 1.22;
    }

    .project-tech-list {
      flex-basis: 100%;
      gap: 0.52rem;
      order: 2;
      justify-content: flex-start;
      margin-inline: 0;
    }

    .hex-tech-badge {
      width: 2.7rem;
      height: 2.36rem;
    }

    .hex-tech-icon {
      width: 1.12rem;
      height: 1.12rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .details-panel,
    .project-details,
    .hex-tech-badge,
    .project-cover-media,
    .project-cover-wash,
    .project-tech-summary {
      animation: none;
      transition: none;
    }
  }
</style>

<script>
  const initProjectTechSummarySwap = () => {
    const panels = document.querySelectorAll(".project-details[data-project-summary]");

    panels.forEach((panel) => {
      if (!(panel instanceof HTMLElement) || panel.dataset.techSummaryReady === "true") {
        return;
      }

      const summary = panel.dataset.projectSummary ?? "";
      const label = panel.querySelector("[data-tech-label]");
      const badges = panel.querySelectorAll("[data-tech-name]");

      if (!(label instanceof HTMLElement) || badges.length === 0) {
        return;
      }

      label.textContent = summary;
      let animationTimer = 0;

      const setLabel = (value: string) => {
        if (label.textContent === value) {
          return;
        }

        if (animationTimer) {
          window.clearTimeout(animationTimer);
          animationTimer = 0;
        }

        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        if (reduceMotion) {
          label.classList.remove("is-switching");
          label.textContent = value;
          return;
        }

        label.classList.add("is-switching");

        animationTimer = window.setTimeout(() => {
          label.textContent = value;
          label.classList.remove("is-switching");
          animationTimer = 0;
        }, 180);
      };

      const resetLabel = () => {
        setLabel(summary);
      };

      badges.forEach((badge) => {
        if (!(badge instanceof HTMLElement)) {
          return;
        }

        const techName = badge.dataset.techName ?? summary;

        badge.addEventListener("mouseenter", () => setLabel(techName));
        badge.addEventListener("focus", () => setLabel(techName));
        badge.addEventListener("mouseleave", resetLabel);
        badge.addEventListener("blur", resetLabel);
      });

      panel.dataset.techSummaryReady = "true";
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initProjectTechSummarySwap, { once: true });
  } else {
    initProjectTechSummarySwap();
  }
</script>
