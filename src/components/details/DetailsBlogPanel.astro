---
interface BlogPost {
  tag: string;
  title: string;
  context: string;
  content: string;
  status: string;
}

interface BlogCover {
  src: string;
  alt: string;
}

interface Props {
  blogOverline: string;
  blogTitle: string;
  blogIntro: string;
  blogPosts: BlogPost[];
  resolveBlogCover: (index: number) => BlogCover;
}

const { blogOverline, blogTitle, blogIntro, blogPosts, resolveBlogCover } = Astro.props as Props;
---

<section
  id="panel-blog"
  role="tabpanel"
  aria-labelledby="tab-blog"
  class="details-panel border-t border-border/50"
  data-tab-panel="blog"
  data-panel-state="inactive"
  hidden
>
  <div class="container-shell details-panel-inner">
    <header class="blog-intro" data-reveal="up">
      <p class="micro-label">{blogOverline}</p>
      <h2 class="blog-intro-title">{blogTitle}</h2>
      <p class="blog-intro-copy">{blogIntro}</p>
    </header>

    <div class="grid gap-6 md:grid-cols-2" data-reveal-group data-reveal-stagger-mobile="60" data-reveal-stagger-desktop="50">
      {
        blogPosts.map((post, index) => {
          const cover = resolveBlogCover(index);

          return (
            <article class="blog-card card-surface border border-border/65 p-6 md:p-7" data-reveal="up" tabindex="0">
              <figure class="blog-card-cover" aria-hidden="true">
                <img src={cover.src} alt={cover.alt} loading="lazy" decoding="async" class="blog-card-cover-media" />
                <span class="blog-card-cover-wash"></span>
              </figure>

              <div class="blog-card-meta">
                <p class="micro-label blog-card-tag">{post.tag}</p>
                <span class="blog-card-status">{post.status}</span>
              </div>

              <h3 class="blog-card-title">{post.title}</h3>
              <p class="blog-card-context">{post.context}</p>
              <p class="blog-card-content">{post.content}</p>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .details-panel[hidden] {
    display: none;
  }

  .details-panel-inner {
    padding-top: 1.9rem;
  }

  .blog-intro {
    display: grid;
    gap: 0.7rem;
    max-width: 72ch;
    margin-bottom: 1.5rem;
  }

  .blog-intro-title {
    margin: 0;
    text-wrap: balance;
    font-size: clamp(1.7rem, 4vw, 2.4rem);
    font-weight: 620;
    line-height: 1.05;
    letter-spacing: -0.036em;
    color: var(--color-text);
  }

  .blog-intro-copy {
    margin: 0;
    max-width: 60ch;
    text-wrap: pretty;
    font-size: clamp(0.98rem, 1.7vw, 1.06rem);
    line-height: 1.68;
    color: var(--color-muted);
  }

  .blog-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    gap: 0.85rem;
    border-radius: 0.95rem;
    transition: border-color 220ms ease, box-shadow 220ms ease, transform 220ms ease;
  }

  .blog-card-cover {
    position: relative;
    overflow: hidden;
    margin-bottom: 0.15rem;
    border: 1px solid color-mix(in oklab, var(--color-border) 70%, transparent);
    border-radius: 0.72rem;
    aspect-ratio: 16 / 8;
    background: color-mix(in oklab, var(--color-surface) 82%, black 18%);
  }

  .blog-card-cover-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(0.86) contrast(0.94);
    transition: filter 220ms ease;
  }

  .blog-card-cover-wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(8, 12, 18, 0.08) 0%, rgba(8, 12, 18, 0.44) 100%),
      linear-gradient(120deg, rgba(77, 131, 166, 0.16) 0%, rgba(77, 131, 166, 0) 58%);
    pointer-events: none;
  }

  .blog-card-tag {
    margin: 0;
    letter-spacing: 0.1em;
  }

  .blog-card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem 0.9rem;
  }

  .blog-card-title {
    margin: 0;
    font-size: clamp(1.2rem, 0.96rem + 0.75vw, 1.7rem);
    font-weight: 620;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--color-text);
    text-wrap: balance;
  }

  .blog-card-context {
    margin: 0;
    padding-left: 0.85rem;
    border-left: 1px solid color-mix(in oklab, var(--color-border) 70%, transparent);
    font-size: 0.93rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-muted) 74%, var(--color-text) 26%);
  }

  .blog-card-content {
    margin: 0;
    max-width: 58ch;
    font-size: 0.95rem;
    line-height: 1.74;
    color: var(--color-muted);
    text-wrap: pretty;
  }

  .blog-card-status {
    display: inline-flex;
    align-items: center;
    gap: 0.36rem;
    margin: 0;
    padding: 0.26rem 0.6rem;
    border: 1px solid color-mix(in oklab, var(--color-border) 68%, transparent);
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 560;
    letter-spacing: 0.045em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--color-text) 84%, #eaf2fb);
    background: color-mix(in oklab, var(--color-surface) 88%, black 12%);
  }

  .blog-card-status::before {
    content: "";
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: rgba(231, 240, 249, 0.86);
    box-shadow: 0 0 8px rgba(231, 240, 249, 0.36);
  }

  .blog-card:focus-visible {
    border-color: color-mix(in srgb, var(--color-border) 60%, var(--color-text) 40%);
    box-shadow: 0 12px 24px -24px rgba(7, 13, 19, 0.32);
    transform: translateY(-2px);
    outline: 2px solid color-mix(in srgb, var(--color-text) 34%, transparent);
    outline-offset: 2px;
  }

  .blog-card:focus-visible .blog-card-cover-media {
    filter: saturate(0.9) contrast(0.96);
  }

  .blog-card:focus-visible .blog-card-title {
    color: color-mix(in srgb, var(--color-text) 90%, black 10%);
  }

  @media (hover: hover) and (pointer: fine) {
    .blog-card:hover {
      border-color: color-mix(in srgb, var(--color-border) 62%, var(--color-text) 38%);
      box-shadow: 0 12px 24px -24px rgba(7, 13, 19, 0.32);
      transform: translateY(-2px);
    }

    .blog-card:hover .blog-card-cover-media {
      filter: saturate(0.9) contrast(0.96);
    }

    .blog-card:hover .blog-card-title {
      color: color-mix(in srgb, var(--color-text) 90%, black 10%);
    }
  }

  @media (max-width: 767px) {
    .details-panel-inner {
      padding-top: 1.25rem;
    }

    .blog-intro {
      gap: 0.62rem;
      margin-bottom: 1rem;
    }

    .blog-card {
      padding: 1.15rem;
      gap: 0.75rem;
    }

    .blog-card-cover {
      aspect-ratio: 16 / 9;
    }

    .blog-card-context,
    .blog-card-content {
      font-size: 0.92rem;
      line-height: 1.58;
    }

    .blog-card-context {
      padding-left: 0.72rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .details-panel {
      animation: none;
      transition: none;
    }

    .blog-card {
      transition: none;
      transform: none;
    }

    .blog-card-cover-media {
      transition: none;
      transform: none;
    }
  }
</style>
