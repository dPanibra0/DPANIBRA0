---
interface BlogPost {
  tag: string;
  title: string;
  excerpt: string;
  status: string;
  href: string;
}

interface Props {
  blogOverline: string;
  blogTitle: string;
  blogIntro: string;
  blogPosts: BlogPost[];
  backLabel: string;
  backToTopLabel: string;
}

const { blogOverline, blogTitle, blogIntro, blogPosts, backLabel, backToTopLabel } = Astro.props;
---

<section
  id="panel-blog"
  role="tabpanel"
  aria-labelledby="tab-blog"
  class="details-panel section-space border-t border-border/50"
  data-tab-panel="blog"
  data-panel-state="inactive"
  hidden
>
  <div class="container-shell details-panel-inner">
    <p class="micro-label mb-5" data-reveal="up">{blogOverline}</p>
    <h2 class="max-w-[860px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]" data-reveal="up">
      {blogTitle}
    </h2>
    <p class="mt-6 max-w-[860px] text-base leading-relaxed text-muted md:text-lg" data-reveal="up" data-reveal-delay="70">
      {blogIntro}
    </p>

    <div class="mt-10 grid gap-5 md:grid-cols-3" data-reveal-group data-reveal-stagger-mobile="60" data-reveal-stagger-desktop="50">
      {
        blogPosts.map((post) => (
          <article class="card-surface border border-border/70 p-5 md:p-6" data-reveal="up">
            <p class="micro-label">{post.tag}</p>
            <h3 class="mt-3 text-[20px] font-semibold leading-tight tracking-[-0.02em] text-text md:text-2xl">{post.title}</h3>
            <p class="mt-3 text-[15px] leading-relaxed text-muted md:text-base">{post.excerpt}</p>
            <div class="mt-6 flex items-center justify-between gap-4 border-t border-border/60 pt-4">
              <span class="text-xs text-muted/90">{post.status}</span>
              <a href={post.href} class="inline-cta text-[11px] md:text-xs">Explorar contexto</a>
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-12 flex flex-wrap gap-4" data-reveal="up" data-reveal-delay="140">
      <a href="/#experiencia" class="inline-cta text-xs md:text-sm">
        <span aria-hidden="true">&larr;</span>
        <span>{backLabel}</span>
      </a>
      <a href="/#inicio" class="inline-cta text-xs md:text-sm">{backToTopLabel}</a>
    </div>
  </div>
</section>

<style>
  .details-panel[hidden] {
    display: none;
  }

  .details-panel[data-panel-state="active"] {
    animation: details-panel-in 240ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .details-panel-inner {
    padding-top: 1.9rem;
  }

  @keyframes details-panel-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 767px) {
    .details-panel-inner {
      padding-top: 1.25rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .details-panel {
      animation: none;
      transition: none;
    }
  }
</style>
