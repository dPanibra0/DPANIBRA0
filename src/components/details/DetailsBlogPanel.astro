---
import type { TechnicalPostSummary } from "../../content/technical-posts-data";
import { formatPostDate } from "../../content/technical-posts-data";

interface Props {
  blogOverline: string;
  blogTitle: string;
  blogIntro: string;
  blogLabels: {
    readArticle: string;
    published: string;
    readingTime: string;
    article: string;
    available: string;
    postsCount: string;
  };
  blogPosts: TechnicalPostSummary[];
}

const { blogOverline, blogTitle, blogIntro, blogLabels, blogPosts } = Astro.props as Props;
const publishedPostsCount = blogPosts.length;
const featuredTags = Array.from(new Set(blogPosts.map((post) => post.tag))).slice(0, 3);
---

<section
  id="panel-blog"
  role="tabpanel"
  aria-labelledby="tab-blog"
  class="details-panel border-t border-border/50"
  data-tab-panel="blog"
  data-panel-state="inactive"
  hidden
>
  <div class="container-shell pt-[1.9rem] max-md:pt-[1.25rem]">
    <header class="mb-[1.35rem] grid max-w-[72ch] gap-[0.7rem] max-md:mb-4 max-md:gap-[0.62rem]" data-reveal="up">
      <p class="micro-label">{blogOverline}</p>
      <h2 class="m-0 text-[clamp(1.7rem,4vw,2.4rem)] font-[620] leading-[1.05] tracking-[-0.036em] text-text [text-wrap:balance]">
        {blogTitle}
      </h2>
      <p class="m-0 max-w-[60ch] text-[clamp(0.98rem,1.7vw,1.06rem)] leading-[1.68] text-muted [text-wrap:pretty]">
        {blogIntro}
      </p>
    </header>

    <div
      class="card-surface mb-6 flex items-center justify-between gap-4 rounded-[0.95rem] border border-[color:color-mix(in_oklab,var(--color-border)_72%,transparent)] px-[1.15rem] py-4 max-md:mb-4 max-md:flex-col max-md:items-start"
      data-reveal="up"
    >
      <div>
        <p class="m-0 font-[var(--font-accent)] text-[0.72rem] uppercase tracking-[0.09em] text-[#9eabb9]">{blogLabels.article}</p>
        <p class="mt-[0.2rem] text-base font-[560] tracking-[-0.01em] text-text">
          {publishedPostsCount} {blogLabels.postsCount}
        </p>
      </div>

      <div class="flex flex-wrap justify-end gap-[0.45rem] max-md:justify-start" aria-label={blogLabels.available}>
        {featuredTags.map((tag) => (
          <span class="inline-flex items-center rounded-full border border-[color:color-mix(in_oklab,var(--color-border)_70%,transparent)] bg-[rgba(12,18,24,0.7)] px-[0.62rem] py-[0.28rem] font-[var(--font-accent)] text-[0.68rem] uppercase tracking-[0.04em] text-[#d9e3ee]">
            {tag}
          </span>
        ))}
      </div>
    </div>

    <div class="grid gap-6 md:grid-cols-2" data-reveal-group data-reveal-stagger-mobile="60" data-reveal-stagger-desktop="50">
      {
        blogPosts.map((post) => (
          <article class="blog-card card-surface min-h-full overflow-hidden rounded-[0.95rem] border border-border/65" data-reveal="up">
            <a href={post.href} class="blog-card-link flex min-h-full flex-col" aria-label={`${blogLabels.readArticle}: ${post.title}`}>
              <figure class="relative m-0 aspect-[16/8] overflow-hidden bg-[color:color-mix(in_oklab,var(--color-surface)_82%,black_18%)] max-md:aspect-[16/9]" aria-hidden="true">
                <img
                  src={post.cover.src}
                  alt={post.cover.alt}
                  loading="lazy"
                  decoding="async"
                  class="blog-card-cover-media"
                />
                <span class="blog-card-cover-wash"></span>
              </figure>

              <div class="grid gap-[0.9rem] px-[1.2rem] pt-[1.1rem] pb-[1.25rem] max-md:gap-[0.82rem] max-md:p-4">
                <div class="flex flex-wrap items-center justify-between gap-x-[0.9rem] gap-y-[0.5rem]">
                  <p class="micro-label m-0 tracking-[0.1em]">{post.tag}</p>
                  <span class="blog-card-status inline-flex items-center gap-[0.36rem] rounded-full border border-[color:color-mix(in_oklab,var(--color-border)_68%,transparent)] bg-[color:color-mix(in_oklab,var(--color-surface)_88%,black_12%)] px-[0.6rem] py-[0.26rem] text-[0.68rem] font-[560] uppercase tracking-[0.045em] text-[color:color-mix(in_oklab,var(--color-text)_84%,#eaf2fb)]">
                    {blogLabels.available}
                  </span>
                </div>

                <h3 class="m-0 text-[clamp(1.2rem,0.96rem+0.75vw,1.7rem)] font-[620] leading-[1.12] tracking-[-0.02em] text-text [text-wrap:balance]">
                  {post.title}
                </h3>
                <p class="m-0 max-w-[58ch] text-[0.95rem] leading-[1.74] text-muted [text-wrap:pretty] max-md:text-[0.92rem] max-md:leading-[1.58]">
                  {post.description}
                </p>

                <dl class="grid grid-cols-2 gap-[0.8rem] pt-[0.1rem] max-md:grid-cols-1 max-md:gap-[0.7rem]">
                  <div class="border-l border-[color:color-mix(in_oklab,var(--color-border)_70%,transparent)] pl-[0.78rem]">
                    <dt class="m-0 font-[var(--font-accent)] text-[0.66rem] uppercase tracking-[0.08em] text-[#9aa8b7]">
                      {blogLabels.published}
                    </dt>
                    <dd class="mt-[0.28rem] text-[0.9rem] leading-[1.4] text-text">{formatPostDate(post.publishDate)}</dd>
                  </div>
                  <div class="border-l border-[color:color-mix(in_oklab,var(--color-border)_70%,transparent)] pl-[0.78rem]">
                    <dt class="m-0 font-[var(--font-accent)] text-[0.66rem] uppercase tracking-[0.08em] text-[#9aa8b7]">
                      {blogLabels.readingTime}
                    </dt>
                    <dd class="mt-[0.28rem] text-[0.9rem] leading-[1.4] text-text">{post.readingTimeMinutes} min</dd>
                  </div>
                </dl>

                <span class="inline-cta mt-[0.15rem] w-fit">
                  {blogLabels.readArticle}
                </span>
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .details-panel[hidden] {
    display: none;
  }

  .blog-card {
    transition: border-color 220ms ease, box-shadow 220ms ease, transform 220ms ease;
  }

  .blog-card-cover-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(0.86) contrast(0.94);
    transition: filter 220ms ease, transform 220ms ease;
  }

  .blog-card-cover-wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(8, 12, 18, 0.08) 0%, rgba(8, 12, 18, 0.46) 100%),
      linear-gradient(120deg, rgba(77, 131, 166, 0.16) 0%, rgba(77, 131, 166, 0) 58%);
    pointer-events: none;
  }

  .blog-card-status::before {
    content: "";
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: rgba(231, 240, 249, 0.86);
    box-shadow: 0 0 8px rgba(231, 240, 249, 0.36);
  }

  .blog-card-link:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--color-text) 34%, transparent);
    outline-offset: -2px;
  }

  .blog-card:focus-within,
  .blog-card:hover {
    border-color: color-mix(in srgb, var(--color-border) 62%, var(--color-text) 38%);
    box-shadow: 0 12px 24px -24px rgba(7, 13, 19, 0.32);
    transform: translateY(-2px);
  }

  .blog-card:focus-within .blog-card-cover-media,
  .blog-card:hover .blog-card-cover-media {
    filter: saturate(0.92) contrast(0.98);
    transform: scale(1.02);
  }

  @media (prefers-reduced-motion: reduce) {
    .details-panel,
    .blog-card,
    .blog-card-cover-media {
      animation: none;
      transition: none;
      transform: none;
    }
  }
</style>
