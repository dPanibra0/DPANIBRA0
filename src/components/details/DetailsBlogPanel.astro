---
import type { TechnicalPostSummary } from "../../content/technical-posts-data";
import { formatPostDate } from "../../content/technical-posts-data";

interface Props {
  blogOverline: string;
  blogTitle: string;
  blogIntro: string;
  blogLabels: {
    readArticle: string;
    published: string;
    readingTime: string;
    article: string;
    available: string;
    postsCount: string;
  };
  blogPosts: TechnicalPostSummary[];
}

const { blogOverline, blogTitle, blogIntro, blogLabels, blogPosts } = Astro.props as Props;
const publishedPostsCount = blogPosts.length;
const featuredTags = Array.from(new Set(blogPosts.map((post) => post.tag))).slice(0, 3);
---

<section
  id="panel-blog"
  role="tabpanel"
  aria-labelledby="tab-blog"
  class="details-panel border-t border-border/50"
  data-tab-panel="blog"
  data-panel-state="inactive"
  hidden
>
  <div class="container-shell details-panel-inner">
    <header class="blog-intro" data-reveal="up">
      <p class="micro-label">{blogOverline}</p>
      <h2 class="blog-intro-title">{blogTitle}</h2>
      <p class="blog-intro-copy">{blogIntro}</p>
    </header>

    <div class="blog-hub-band card-surface" data-reveal="up">
      <div>
        <p class="blog-hub-kicker">{blogLabels.article}</p>
        <p class="blog-hub-value">{publishedPostsCount} {blogLabels.postsCount}</p>
      </div>

      <div class="blog-hub-tags" aria-label={blogLabels.available}>
        {featuredTags.map((tag) => <span class="blog-hub-tag">{tag}</span>)}
      </div>
    </div>

    <div class="grid gap-6 md:grid-cols-2" data-reveal-group data-reveal-stagger-mobile="60" data-reveal-stagger-desktop="50">
      {
        blogPosts.map((post) => (
          <article class="blog-card card-surface border border-border/65" data-reveal="up">
            <a href={post.href} class="blog-card-link" aria-label={`${blogLabels.readArticle}: ${post.title}`}>
              <figure class="blog-card-cover" aria-hidden="true">
                <img src={post.cover.src} alt={post.cover.alt} loading="lazy" decoding="async" class="blog-card-cover-media" />
                <span class="blog-card-cover-wash"></span>
              </figure>

              <div class="blog-card-body">
                <div class="blog-card-meta">
                  <p class="micro-label blog-card-tag">{post.tag}</p>
                  <span class="blog-card-status">{blogLabels.available}</span>
                </div>

                <h3 class="blog-card-title">{post.title}</h3>
                <p class="blog-card-content">{post.description}</p>

                <dl class="blog-card-details">
                  <div>
                    <dt>{blogLabels.published}</dt>
                    <dd>{formatPostDate(post.publishDate)}</dd>
                  </div>
                  <div>
                    <dt>{blogLabels.readingTime}</dt>
                    <dd>{post.readingTimeMinutes} min</dd>
                  </div>
                </dl>

                <span class="inline-cta blog-card-cta">
                  {blogLabels.readArticle}
                </span>
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .details-panel[hidden] {
    display: none;
  }

  .details-panel-inner {
    padding-top: 1.9rem;
  }

  .blog-intro {
    display: grid;
    gap: 0.7rem;
    max-width: 72ch;
    margin-bottom: 1.35rem;
  }

  .blog-intro-title {
    margin: 0;
    text-wrap: balance;
    font-size: clamp(1.7rem, 4vw, 2.4rem);
    font-weight: 620;
    line-height: 1.05;
    letter-spacing: -0.036em;
    color: var(--color-text);
  }

  .blog-intro-copy {
    margin: 0;
    max-width: 60ch;
    text-wrap: pretty;
    font-size: clamp(0.98rem, 1.7vw, 1.06rem);
    line-height: 1.68;
    color: var(--color-muted);
  }

  .blog-hub-band {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding: 1rem 1.15rem;
    border: 1px solid color-mix(in oklab, var(--color-border) 72%, transparent);
    border-radius: 0.95rem;
  }

  .blog-hub-kicker,
  .blog-hub-value {
    margin: 0;
  }

  .blog-hub-kicker {
    font-family: var(--font-accent);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: #9eabb9;
  }

  .blog-hub-value {
    margin-top: 0.2rem;
    font-size: 1rem;
    font-weight: 560;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }

  .blog-hub-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.45rem;
  }

  .blog-hub-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.28rem 0.62rem;
    border: 1px solid color-mix(in oklab, var(--color-border) 70%, transparent);
    border-radius: 999px;
    background: rgba(12, 18, 24, 0.7);
    font-family: var(--font-accent);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #d9e3ee;
  }

  .blog-card {
    min-height: 100%;
    border-radius: 0.95rem;
    overflow: hidden;
    transition: border-color 220ms ease, box-shadow 220ms ease, transform 220ms ease;
  }

  .blog-card-link {
    display: flex;
    min-height: 100%;
    flex-direction: column;
  }

  .blog-card-cover {
    position: relative;
    overflow: hidden;
    margin: 0;
    aspect-ratio: 16 / 8;
    background: color-mix(in oklab, var(--color-surface) 82%, black 18%);
  }

  .blog-card-cover-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(0.86) contrast(0.94);
    transition: filter 220ms ease, transform 220ms ease;
  }

  .blog-card-cover-wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(8, 12, 18, 0.08) 0%, rgba(8, 12, 18, 0.46) 100%),
      linear-gradient(120deg, rgba(77, 131, 166, 0.16) 0%, rgba(77, 131, 166, 0) 58%);
    pointer-events: none;
  }

  .blog-card-body {
    display: grid;
    gap: 0.9rem;
    padding: 1.1rem 1.2rem 1.25rem;
  }

  .blog-card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem 0.9rem;
  }

  .blog-card-tag {
    margin: 0;
    letter-spacing: 0.1em;
  }

  .blog-card-status {
    display: inline-flex;
    align-items: center;
    gap: 0.36rem;
    margin: 0;
    padding: 0.26rem 0.6rem;
    border: 1px solid color-mix(in oklab, var(--color-border) 68%, transparent);
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 560;
    letter-spacing: 0.045em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--color-text) 84%, #eaf2fb);
    background: color-mix(in oklab, var(--color-surface) 88%, black 12%);
  }

  .blog-card-status::before {
    content: "";
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: rgba(231, 240, 249, 0.86);
    box-shadow: 0 0 8px rgba(231, 240, 249, 0.36);
  }

  .blog-card-title {
    margin: 0;
    font-size: clamp(1.2rem, 0.96rem + 0.75vw, 1.7rem);
    font-weight: 620;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--color-text);
    text-wrap: balance;
  }

  .blog-card-content {
    margin: 0;
    max-width: 58ch;
    font-size: 0.95rem;
    line-height: 1.74;
    color: var(--color-muted);
    text-wrap: pretty;
  }

  .blog-card-details {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin: 0;
    padding-top: 0.1rem;
  }

  .blog-card-details div {
    padding-left: 0.78rem;
    border-left: 1px solid color-mix(in oklab, var(--color-border) 70%, transparent);
  }

  .blog-card-details dt,
  .blog-card-details dd {
    margin: 0;
  }

  .blog-card-details dt {
    font-family: var(--font-accent);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #9aa8b7;
  }

  .blog-card-details dd {
    margin-top: 0.28rem;
    font-size: 0.9rem;
    line-height: 1.4;
    color: var(--color-text);
  }

  .blog-card-cta {
    margin-top: 0.15rem;
    width: fit-content;
  }

  .blog-card-link:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--color-text) 34%, transparent);
    outline-offset: -2px;
  }

  .blog-card:focus-within,
  .blog-card:hover {
    border-color: color-mix(in srgb, var(--color-border) 62%, var(--color-text) 38%);
    box-shadow: 0 12px 24px -24px rgba(7, 13, 19, 0.32);
    transform: translateY(-2px);
  }

  .blog-card:focus-within .blog-card-cover-media,
  .blog-card:hover .blog-card-cover-media {
    filter: saturate(0.92) contrast(0.98);
    transform: scale(1.02);
  }

  @media (max-width: 767px) {
    .details-panel-inner {
      padding-top: 1.25rem;
    }

    .blog-intro {
      gap: 0.62rem;
      margin-bottom: 1rem;
    }

    .blog-hub-band {
      align-items: flex-start;
      flex-direction: column;
      margin-bottom: 1rem;
    }

    .blog-hub-tags {
      justify-content: flex-start;
    }

    .blog-card-cover {
      aspect-ratio: 16 / 9;
    }

    .blog-card-body {
      padding: 1rem;
      gap: 0.82rem;
    }

    .blog-card-content {
      font-size: 0.92rem;
      line-height: 1.58;
    }

    .blog-card-details {
      grid-template-columns: 1fr;
      gap: 0.7rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .details-panel,
    .blog-card,
    .blog-card-cover-media {
      animation: none;
      transition: none;
      transform: none;
    }
  }
</style>
