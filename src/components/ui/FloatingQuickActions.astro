---
import { Icon } from "astro-icon/components";
import type { PortfolioUiTranslations } from "../../content/types";

interface Props {
  ui: PortfolioUiTranslations["floatingActions"];
}

const { ui } = Astro.props;

const contactHref = "#contacto";
---

<aside
  class="pointer-events-none fixed bottom-5 right-4 z-50 sm:bottom-6 sm:right-6"
  aria-label={ui.ariaLabel}
  data-floating-actions
>
  <div
    class="pointer-events-none flex translate-y-2 flex-col items-center gap-2 rounded-2xl border border-white/10 p-2 opacity-0 backdrop-blur-md transition duration-300  shadow-md"
    data-floating-actions-panel
    aria-hidden="true" 
  >
    <a
      href="https://www.linkedin.com/in/david-panibra-1bb87a1a4/"
      target="_blank"
      rel="noopener noreferrer"
      class="fq-action rounded-full"
      aria-label={ui.linkedin}
    >
      <Icon name="simple-icons:linkedin" class="h-4 w-4" aria-hidden="true" />
    </a>
    <a
      href="https://github.com/dPanibra0"
      target="_blank"
      rel="noopener noreferrer"
      class="fq-action rounded-full"
      aria-label={ui.github}
    >
      <Icon name="simple-icons:github" class="h-4 w-4" aria-hidden="true" />
    </a>
    <a href="mailto:dpanibra0@gmail.com" class="fq-action rounded-full" aria-label={ui.email}>
      <Icon name="simple-icons:gmail" class="h-4 w-4" aria-hidden="true" />
    </a>
    <a href={contactHref} class="fq-action rounded-full" data-contact-action aria-label={ui.contact}>
      <Icon name="lucide:message-circle" class="h-4 w-4" aria-hidden="true" />
    </a>
    <button
      type="button"
      class="fq-action fq-action-scroll border border-white/10 rounded-full"
      data-scroll-top
      aria-label={ui.scrollTop}
    >
      <span class="fq-scroll-icon-wrap" aria-hidden="true">
        <span class="fq-scroll-icon fq-scroll-icon-primary">
          <Icon name="lucide:arrow-up" class="h-4 w-4" aria-hidden="true" />
        </span>
        <span class="fq-scroll-icon fq-scroll-icon-secondary">
          <Icon name="lucide:arrow-up" class="h-4 w-4" aria-hidden="true" />
        </span>
      </span>
    </button>
  </div>
</aside>

<style>
  .fq-action {
    display: inline-flex;
    height: 2.25rem;
    width: 2.25rem;
    align-items: center;
    justify-content: center;
    background: #0a0a0a;
    color: rgb(236, 239, 244);
    transition: transform 180ms ease, border-color 180ms ease, background-color 180ms ease, color 180ms ease;
  }

  .fq-action-scroll {
    overflow: hidden;
  }

  .fq-scroll-icon-wrap {
    position: relative;
    display: inline-flex;
    height: 1rem;
    width: 1rem;
    align-items: center;
    justify-content: center;
  }

  .fq-scroll-icon {
    position: absolute;
    inset: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 230ms cubic-bezier(0.22, 1, 0.36, 1), opacity 230ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .fq-scroll-icon-secondary {
    transform: translateY(120%);
    opacity: 0;
  }

  @media (hover: hover) and (pointer: fine) {
    .fq-action-scroll:hover .fq-scroll-icon-primary {
      transform: translateY(-120%);
      opacity: 0;
      transition: transform 200ms cubic-bezier(0.25, 1, 0.5, 1), opacity 200ms linear;
    }

    .fq-action-scroll:hover .fq-scroll-icon-secondary {
      transform: translateY(0);
      opacity: 1;
      transition-delay: 90ms;
    }

    .fq-action-scroll:not(:hover) .fq-scroll-icon-primary,
    .fq-action-scroll:not(:hover) .fq-scroll-icon-secondary {
      transition-duration: 0ms;
      transition-delay: 0ms;
    }

  }

  .fq-action:hover {
    transform: translateY(-1px);
    
  }

  .fq-action:active {
    transform: translateY(0);
  }

  .fq-action:focus-visible {
    outline: 2px solid rgba(77, 131, 166, 0.95);
    outline-offset: 2px;
  }


  @media (max-width: 640px) {
    .fq-action {
      height: 2.125rem;
      width: 2.125rem;
    }
  }
</style>

<script is:inline define:vars={{ contactLabel: ui.contact }}>
  const floatingActions = document.querySelector("[data-floating-actions]");
  const floatingActionsPanel = floatingActions?.querySelector("[data-floating-actions-panel]");
  const scrollTopButton = floatingActions?.querySelector("[data-scroll-top]");
  const contactAction = floatingActions?.querySelector("[data-contact-action]");
  const footer = document.querySelector("footer");

  if (contactAction) {
    contactAction.setAttribute("href", "#contacto");
    contactAction.setAttribute("aria-label", contactLabel);
  }

  const setPanelVisible = (visible) => {
    if (!floatingActionsPanel) return;
    floatingActionsPanel.classList.toggle("opacity-0", !visible);
    floatingActionsPanel.classList.toggle("translate-y-2", !visible);
    floatingActionsPanel.classList.toggle("pointer-events-none", !visible);
    floatingActionsPanel.classList.toggle("pointer-events-auto", visible);
    floatingActionsPanel.setAttribute("aria-hidden", String(!visible));
  };

  const updateFloatingVisibility = () => {
    if (!floatingActions || !floatingActionsPanel) return;

    const viewportHeight = window.innerHeight;
    const maxScroll = Math.max(document.documentElement.scrollHeight - viewportHeight, 1);
    const progress = window.scrollY / maxScroll;
    const nearPageEnd = progress >= 0.86;
    setPanelVisible(nearPageEnd);

    const baseOffset = window.matchMedia("(min-width: 640px)").matches ? 24 : 20;
    let extraOffset = 0;

    if (footer) {
      const footerTop = footer.getBoundingClientRect().top;
      if (footerTop < viewportHeight) {
        extraOffset = viewportHeight - footerTop + 16;
      }
    }

    floatingActions.style.bottom = `${baseOffset + extraOffset}px`;
  };


  updateFloatingVisibility();
  window.addEventListener("scroll", updateFloatingVisibility, { passive: true });
  window.addEventListener("resize", updateFloatingVisibility);

  if (scrollTopButton) {
    scrollTopButton.addEventListener("click", () => {
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      window.scrollTo({ top: 0, behavior: prefersReducedMotion ? "auto" : "smooth" });
    });
  }

</script>
