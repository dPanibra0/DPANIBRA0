---
import { Icon } from "astro-icon/components";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;

const labels =
  lang === "es"
    ? {
        linkedin: "Abrir perfil de LinkedIn",
        github: "Abrir perfil de GitHub",
        email: "Enviar correo",
        contact: "Ir a contacto",
        scrollTop: "Volver arriba",
      }
    : {
        linkedin: "Open LinkedIn profile",
        github: "Open GitHub profile",
        email: "Send email",
        contact: "Go to contact section",
        scrollTop: "Back to top",
      };

const contactHref = lang === "es" ? "#contacto" : "#contact";
---

<aside
  class="pointer-events-none fixed bottom-5 right-4 z-50 sm:bottom-6 sm:right-6"
  aria-label="Quick actions"
  data-floating-actions
  data-initial-lang={lang}
>
  <div
    class="pointer-events-none flex translate-y-2 flex-col items-center gap-2 rounded-2xl border border-white/10 p-2 opacity-0 backdrop-blur-md shadow-[0_20px_40px_-24px_rgba(0,0,0,0.85)] transition duration-300"
    data-floating-actions-panel
    aria-hidden="true"
  >
    <a
      href="https://www.linkedin.com/in/david-panibra-1bb87a1a4/"
      target="_blank"
      rel="noopener noreferrer"
      class="fq-action"
      aria-label={labels.linkedin}
    >
      <Icon name="simple-icons:linkedin" class="h-4 w-4" aria-hidden="true" />
    </a>
    <a
      href="https://github.com/dPanibra0"
      target="_blank"
      rel="noopener noreferrer"
      class="fq-action"
      aria-label={labels.github}
    >
      <Icon name="simple-icons:github" class="h-4 w-4" aria-hidden="true" />
    </a>
    <a href="mailto:dpanibra0@gmail.com" class="fq-action" aria-label={labels.email}>
      <Icon name="simple-icons:gmail" class="h-4 w-4" aria-hidden="true" />
    </a>
    <a href={contactHref} class="fq-action" data-contact-action aria-label={labels.contact}>
      <Icon name="lucide:message-circle" class="h-4 w-4" aria-hidden="true" />
    </a>
    <button
      type="button"
      class="fq-action fq-action-scroll border border-white/10"
      data-scroll-top
      aria-label={labels.scrollTop}
    >
      <span class="fq-scroll-icon-wrap" aria-hidden="true">
        <span class="fq-scroll-icon fq-scroll-icon-primary">
          <Icon name="lucide:arrow-up" class="h-4 w-4" aria-hidden="true" />
        </span>
        <span class="fq-scroll-icon fq-scroll-icon-secondary">
          <Icon name="lucide:arrow-up" class="h-4 w-4" aria-hidden="true" />
        </span>
      </span>
    </button>
  </div>
</aside>

<style>
  .fq-action {
    display: inline-flex;
    height: 2.25rem;
    width: 2.25rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(20, 22, 26, 0.334), rgba(12, 14, 17, 0.95));
    color: rgb(236, 239, 244);
    transition: transform 180ms ease, border-color 180ms ease, background-color 180ms ease, color 180ms ease;
  }

  .fq-action-scroll {
    overflow: hidden;
  }

  .fq-scroll-icon-wrap {
    position: relative;
    display: inline-flex;
    height: 1rem;
    width: 1rem;
    align-items: center;
    justify-content: center;
  }

  .fq-scroll-icon {
    position: absolute;
    inset: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 230ms cubic-bezier(0.22, 1, 0.36, 1), opacity 230ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .fq-scroll-icon-secondary {
    transform: translateY(120%);
    opacity: 0;
  }

  @media (hover: hover) and (pointer: fine) {
    .fq-action-scroll:hover .fq-scroll-icon-primary {
      transform: translateY(-120%);
      opacity: 0;
      transition: transform 200ms cubic-bezier(0.25, 1, 0.5, 1), opacity 200ms linear;
    }

    .fq-action-scroll:hover .fq-scroll-icon-secondary {
      transform: translateY(0);
      opacity: 1;
      transition-delay: 90ms;
    }

    .fq-action-scroll:not(:hover) .fq-scroll-icon-primary,
    .fq-action-scroll:not(:hover) .fq-scroll-icon-secondary {
      transition-duration: 0ms;
      transition-delay: 0ms;
    }

  }

  .fq-action:hover {
    transform: translateY(-1px);
    border-color: rgba(77, 131, 166, 0.8);
    background: linear-gradient(180deg, rgba(31, 41, 53, 0.96), rgba(17, 24, 33, 0.96));
  }

  .fq-action:active {
    transform: translateY(0);
  }

  .fq-action:focus-visible {
    outline: 2px solid rgba(77, 131, 166, 0.95);
    outline-offset: 2px;
  }


  @media (max-width: 640px) {
    .fq-action {
      height: 2.125rem;
      width: 2.125rem;
    }
  }
</style>

<script>
  const floatingActions = document.querySelector("[data-floating-actions]") as HTMLElement | null;
  const floatingActionsPanel = floatingActions?.querySelector("[data-floating-actions-panel]") as HTMLElement | null;
  const scrollTopButton = floatingActions?.querySelector("[data-scroll-top]") as HTMLButtonElement | null;
  const contactAction = floatingActions?.querySelector("[data-contact-action]") as HTMLAnchorElement | null;
  const footer = document.querySelector("footer") as HTMLElement | null;

  const langLabels = {
    es: {
      nextText: "EN",
      languageAria: "Cambiar idioma a ingles",
      contactAria: "Ir a contacto",
      contactHref: "#contacto",
    },
    en: {
      nextText: "ES",
      languageAria: "Switch language to Spanish",
      contactAria: "Go to contact section",
      contactHref: "#contact",
    },
  } as const;

  const readStoredLang = (fallback: "es" | "en") => {
    const raw = localStorage.getItem("site-lang");
    if (raw === "es" || raw === "en") return raw;
    return fallback;
  };

  const applyLanguageUi = (nextLang: "es" | "en") => {
    const state = langLabels[nextLang];

    if (contactAction) {
      contactAction.setAttribute("href", state.contactHref);
      contactAction.setAttribute("aria-label", state.contactAria);
    }

    document.documentElement.lang = nextLang;
  };

  const applyLanguageBlocks = (nextLang: "es" | "en") => {
    document.querySelectorAll("[data-lang-block]").forEach((block) => {
      const matches = block.getAttribute("data-lang-block") === nextLang;
      block.toggleAttribute("hidden", !matches);
      block.setAttribute("aria-hidden", String(!matches));
    });
  };

  const setPanelVisible = (visible: boolean) => {
    if (!floatingActionsPanel) return;
    floatingActionsPanel.classList.toggle("opacity-0", !visible);
    floatingActionsPanel.classList.toggle("translate-y-2", !visible);
    floatingActionsPanel.classList.toggle("pointer-events-none", !visible);
    floatingActionsPanel.classList.toggle("pointer-events-auto", visible);
    floatingActionsPanel.setAttribute("aria-hidden", String(!visible));
  };

  const updateFloatingVisibility = () => {
    if (!floatingActions || !floatingActionsPanel) return;

    const viewportHeight = window.innerHeight;
    const maxScroll = Math.max(document.documentElement.scrollHeight - viewportHeight, 1);
    const progress = window.scrollY / maxScroll;
    const nearPageEnd = progress >= 0.86;
    setPanelVisible(nearPageEnd);

    const baseOffset = window.matchMedia("(min-width: 640px)").matches ? 24 : 20;
    let extraOffset = 0;

    if (footer) {
      const footerTop = footer.getBoundingClientRect().top;
      if (footerTop < viewportHeight) {
        extraOffset = viewportHeight - footerTop + 16;
      }
    }

    floatingActions.style.bottom = `${baseOffset + extraOffset}px`;
  };


  updateFloatingVisibility();
  window.addEventListener("scroll", updateFloatingVisibility, { passive: true });
  window.addEventListener("resize", updateFloatingVisibility);

  if (scrollTopButton) {
    scrollTopButton.addEventListener("click", () => {
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      window.scrollTo({ top: 0, behavior: prefersReducedMotion ? "auto" : "smooth" });
    });
  }

  const initialLang = floatingActions?.dataset.initialLang === "en" ? "en" : "es";
  const activeLang = readStoredLang(initialLang);
  applyLanguageUi(activeLang);
  applyLanguageBlocks(activeLang);

  window.addEventListener("site-language:change", (event) => {
    const custom = event as CustomEvent<{ lang?: string }>;
    const nextLang = custom.detail?.lang;
    if (nextLang !== "es" && nextLang !== "en") return;
    localStorage.setItem("site-lang", nextLang);
    applyLanguageUi(nextLang);
    applyLanguageBlocks(nextLang);
  });
</script>
