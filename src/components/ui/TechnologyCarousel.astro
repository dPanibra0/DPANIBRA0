---
import { Icon } from "astro-icon/components";
import type { PortfolioUiTranslations } from "../../content/types";

interface Props {
  ui: PortfolioUiTranslations["techCarousel"];
  technologies: Array<{
    label: string;
    icon: string;
  }>;
  direction?: "forward" | "reverse";
  emphasis?: "primary" | "secondary";
  compact?: boolean;
  mobileOnly?: boolean;
  decorative?: boolean;
}

const {
  ui,
  technologies,
  direction = "forward",
  emphasis = "primary",
  compact = false,
  mobileOnly = false,
  decorative = false,
} = Astro.props as Props;
---

<div
  class:list={[
    "tech-marquee",
    direction === "reverse" && "tech-marquee--reverse",
    emphasis === "secondary" && "tech-marquee--secondary",
    compact && "tech-marquee--compact",
    mobileOnly && "tech-marquee--mobile-only",
  ]}
  data-reveal="up"
  aria-hidden={decorative ? "true" : undefined}
  aria-label={decorative ? undefined : ui.ariaLabel}
>
  <div class="tech-marquee__viewport">
    <div class="tech-marquee__track" role="list">
      {
        [0, 1].map((groupIndex) => (
          <div class="tech-marquee__group" aria-hidden={groupIndex === 1 ? "true" : undefined}>
            {technologies.map((technology) => (
              <div
                class="tech-hex"
                role={decorative ? undefined : "listitem"}
                aria-label={decorative ? undefined : technology.label}
                title={decorative ? undefined : technology.label}
              >
                <Icon name={technology.icon} class="tech-hex__icon" aria-hidden="true" />
              </div>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .tech-marquee {
    --tech-gap: 1.2rem;
    --tech-duration: 44s;
    --tech-hex-width: 4.5rem;
    --tech-hex-height: 3.95rem;
    --tech-icon-size: 1.45rem;
    --tech-border: rgba(255, 255, 255, 0.78);
    --tech-surface: rgba(255, 255, 255, 0.02);
    --tech-icon-color: #ffffff;
    position: relative;
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0, black 8%, black 92%, transparent 100%);
  }

  .tech-marquee__viewport {
    width: 100%;
    overflow: hidden;
  }

  .tech-marquee__track {
    display: flex;
    width: max-content;
    align-items: center;
    animation: stack-marquee var(--tech-duration) linear infinite;
    will-change: transform;
  }

  .tech-marquee--reverse .tech-marquee__track {
    animation-direction: reverse;
  }

  .tech-marquee--secondary {
    --tech-duration: 68s;
    --tech-border: rgba(167, 176, 187, 0.18);
    --tech-surface: rgba(255, 255, 255, 0.01);
    --tech-icon-color: rgba(190, 199, 209, 0.48);
    filter: saturate(0.82);
    opacity: 0.72;
  }

  .tech-marquee--compact {
    --tech-gap: 0.7rem;
    --tech-hex-width: 3rem;
    --tech-hex-height: 2.62rem;
    --tech-icon-size: 0.98rem;
  }

  .tech-marquee--mobile-only {
    display: block;
  }

  .tech-marquee__group {
    display: flex;
    align-items: center;
    gap: var(--tech-gap);
    padding-right: var(--tech-gap);
    flex-shrink: 0;
  }

  .tech-hex {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--tech-hex-width);
    height: var(--tech-hex-height);
    border: 1px solid var(--tech-border);
    background: var(--tech-surface);
    clip-path: polygon(25% 5%, 75% 5%, 100% 50%, 75% 95%, 25% 95%, 0 50%);
    flex: 0 0 auto;
  }

  .tech-hex__icon {
    width: var(--tech-icon-size);
    height: var(--tech-icon-size);
    color: var(--tech-icon-color);
  }

  @keyframes stack-marquee {
    from {
      transform: translate3d(0, 0, 0);
    }

    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  @media (max-width: 48rem) {
    .tech-hex {
      width: calc(var(--tech-hex-width) * 0.8444);
      height: calc(var(--tech-hex-height) * 0.8354);
    }

    .tech-marquee {
      --tech-gap: 0.9rem;
    }

    .tech-marquee--compact {
      --tech-gap: 0.55rem;
    }

    .tech-hex__icon {
      width: calc(var(--tech-icon-size) * 0.8621);
      height: calc(var(--tech-icon-size) * 0.8621);
    }
  }

  @media (min-width: 48.001rem) {
    .tech-marquee--mobile-only {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tech-marquee {
      mask-image: none;
      overflow-x: auto;
      scrollbar-width: thin;
    }

    .tech-marquee__viewport {
      width: max-content;
      min-width: 100%;
      overflow: visible;
    }

    .tech-marquee__track {
      animation: none;
    }

    .tech-marquee__group:last-child {
      display: none;
    }

    .tech-marquee--secondary {
      display: none;
    }
  }
</style>
