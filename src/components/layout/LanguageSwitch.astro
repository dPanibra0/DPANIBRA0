---
interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const isSpanish = lang === "es";
---

<div class="inline-flex items-center rounded-full border border-border bg-surface/70 p-1 text-xs font-semibold text-muted">
  <a
    href="/"
    class:list={["rounded-full px-3 py-1 transition", isSpanish && "bg-accent text-white"]}
    aria-current={isSpanish ? "page" : undefined}
  >
    ES
  </a>
  <a
    href="/en"
    class:list={["rounded-full px-3 py-1 transition", !isSpanish && "bg-accent text-white"]}
    aria-current={!isSpanish ? "page" : undefined}
  >
    EN
  </a>
</div>
