---
import type { PortfolioContent } from "../../content/types";

interface Props {
  id: string;
  philosophy: PortfolioContent["philosophy"];
  overline: string;
}

const { id, philosophy, overline } = Astro.props;
---

<section id={id} class="section-space border-t border-border/50">
  <div class="container-shell pt-8 md:pt-12">
    <div class="text-center">
      <p class="micro-label mb-5">{overline}</p>
      <h2 class="mx-auto max-w-[860px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]">
        {philosophy.headingPrimary}
        <br />
        <span class="text-muted">{philosophy.headingSecondary}</span>
      </h2>
      <p class="mx-auto mt-7 max-w-[900px] text-base leading-relaxed text-muted md:text-lg">{philosophy.intro}</p>
    </div>

    <div class="mt-12 overflow-hidden rounded-2xl border border-border/60 bg-black/20">
      <div class="grid md:grid-cols-2 xl:grid-cols-3">
        {
          philosophy.principles.map((item, index) => (
            <article class="border-b border-border/60 p-7 md:border-r md:[&:nth-child(2n)]:border-r-0 md:[&:nth-child(n+5)]:border-b-0 xl:min-h-[280px] xl:[&:nth-child(2n)]:border-r xl:[&:nth-child(3n)]:border-r-0 xl:[&:nth-child(n+4)]:border-b-0 hover:bg-stone-300/10">
              <div class="mb-8 mt-2 h-6 w-6 text-[#9ea8b4]">
                {item.icon === "domain" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M4 20h16"></path>
                    <path d="M6 20V8h12v12"></path>
                    <path d="M9 12h2"></path>
                    <path d="M13 12h2"></path>
                    <path d="M9 16h6"></path>
                  </svg>
                )}
                {item.icon === "code" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="m8 17-4-5 4-5"></path>
                    <path d="m16 7 4 5-4 5"></path>
                    <path d="m13.5 4-3 16"></path>
                  </svg>
                )}
                {item.icon === "shield" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M12 3l6 2.4v6.1c0 4.1-2.4 7.7-6 9.5-3.6-1.8-6-5.4-6-9.5V5.4L12 3Z"></path>
                  </svg>
                )}
                {item.icon === "scale" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M4 18h16"></path>
                    <path d="M6 18v-4l4-2 4 1 4-3"></path>
                  </svg>
                )}
                {item.icon === "resilience" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M3 12h4l2.2-4.5L12 16l2.4-5 2.2 1.7H21"></path>
                  </svg>
                )}
                {item.icon === "global" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <circle cx="12" cy="12" r="7"></circle>
                    <path d="M5 12h14"></path>
                    <path d="M12 6a5 5 0 0 0-5 5c0 2.5 1.6 4.1 3.5 5.5"></path>
                    <path d="M12 18c2-1.4 5-3.2 5-7a5 5 0 0 0-5-5"></path>
                  </svg>
                )}
              </div>
              <h3 class="text-lg font-semibold tracking-[-0.02em] text-text md:text-xl">{item.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-muted md:text-base">{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
