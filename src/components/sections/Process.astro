---
import type { PortfolioContent } from "../../content/types";
import { Icon } from "astro-icon/components";

interface Props {
  id: string;
  process: PortfolioContent["process"];
  overline: string;
}

const { id, process, overline } = Astro.props;

const iconByIndex = ["search", "grid", "code", "pulse"];
const processIconMap: Record<(typeof iconByIndex)[number], string> = {
  search: "lucide:search",
  grid: "lucide:layout-grid",
  code: "lucide:code",
  pulse: "lucide:activity",
};
---

<section id={id} class="section-space border-t border-border/50">
  <div class="container-shell pt-8 md:pt-12">
    <p class="micro-label mb-5" data-reveal="up">{overline}</p>
    <h2 class="max-w-[760px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]" data-reveal="up">
      {process.headingPrimary}
      <br />
      <span class="text-muted">{process.headingSecondary}</span>
    </h2>
    <p class="mt-7 max-w-[820px] text-base leading-relaxed text-muted md:text-lg" data-reveal="up">{process.intro}</p>

    <div class="mt-12 overflow-hidden rounded-2xl border border-border/60 bg-black/20" data-reveal="zoom" data-reveal-delay="80">
      <div
        class="grid md:grid-cols-2 xl:grid-cols-4"
        data-reveal-group
        data-reveal-stagger-mobile="78"
        data-reveal-stagger-desktop="58"
      >
        {
          process.steps.map((step, index) => (
            <article
              class="group relative border-b border-border/60 p-7 md:border-r md:[&:nth-child(2n)]:border-r-0 xl:min-h-[360px] xl:border-b-0 xl:[&:nth-child(2n)]:border-r xl:[&:nth-child(4n)]:border-r-0 hover:bg-stone-300/10"
              data-reveal="up"
            >
              <p class="text-6xl font-bold leading-none tracking-[-0.04em] text-white/[0.1] md:text-7xl md:my-8">
                {String(index + 1).padStart(2, "0")}
              </p>

              <div class="mt-10 h-5 w-5 text-[#9ea8b4]">
                <Icon name={processIconMap[iconByIndex[index]]} class="h-5 w-5" aria-hidden="true" />
              </div>

              <h3 class="mt-6 text-lg font-semibold tracking-[-0.02em] text-text md:text-xl">{step.title}</h3>
              <p class="mt-4 text-sm leading-relaxed text-muted md:text-base">{step.description}</p>

              {index < process.steps.length - 1 && (
                <span class="absolute -right-4 top-1/2 z-10 hidden h-8 w-8 -translate-y-1/2 items-center justify-center rounded-full border border-border/70 bg-bg text-muted xl:inline-flex">
                  ›
                </span>
              )}
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
