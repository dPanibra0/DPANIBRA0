---
import { Icon } from "astro-icon/components";
import type { PortfolioContent, PortfolioUiTranslations } from "../../content/types";
import { imagenesBlob } from "../../content/imagenes-blob";

interface Props {
  id: string;
  projects: PortfolioContent["projects"];
  overline: string;
  ui: PortfolioUiTranslations["projects"];
}

const { id, projects, overline, ui } = Astro.props;

const deriveTeaser = (project: (typeof projects.items)[number]) => {
  const source = project.problem || project.impact || project.solution;
  if (!source) {
    return "Caso empresarial con foco en continuidad operativa.";
  }

  const clean = source.replace(/\s+/g, " ").trim();
  const sentence = clean.split(".")[0]?.trim() || clean;

  if (sentence.length <= 110) {
    return sentence.endsWith(".") ? sentence : `${sentence}.`;
  }

  return `${sentence.slice(0, 107).trimEnd()}...`;
};

const fallbackProject: (typeof projects.items)[number] = {
  title: ui.fallbackProject.title,
  impact: ui.fallbackProject.impact,
  stack: ui.fallbackProject.stack,
  problem: "",
  architecture: "",
  challenges: "",
  solution: "",
};

const visibleProjects = [...projects.items];
while (visibleProjects.length < 3) {
  visibleProjects.push(fallbackProject);
}

const projectImages = [...imagenesBlob.proyectos];
---

<section id={id} class="section-space border-t border-border/50">
  <div class="container-shell pt-8 md:pt-12">
    <p class="micro-label mb-5" data-reveal="up">{overline}</p>
      <h2 class="max-w-[780px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]" data-reveal="up">
      {ui.headingTop}
      <br />
      <span class="text-muted">{ui.headingBottom}</span>
    </h2>
    <p class="mt-7 max-w-[860px] text-base leading-relaxed text-muted md:text-lg" data-reveal="up">{projects.intro}</p>

    <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3" data-reveal-group data-reveal-stagger-mobile="72" data-reveal-stagger-desktop="54">
      {
        visibleProjects.map((project, index) => {
          const detailsHref = "/detalles#proyectos";
          const imageSrc = projectImages[index] ?? projectImages[projectImages.length - 1];
          const teaser = deriveTeaser(project);
          const stackItems = project.stack
            .split(",")
            .map((tech) => tech.trim())
            .filter(Boolean)
            .slice(0, 3);

          return (
          <article class="project-card group flex h-full flex-col overflow-hidden rounded-sm border border-border/65" data-reveal="up">
            <div class="relative h-[210px] overflow-hidden border-b border-border/50">
              <img src={imageSrc} alt={project.title} class="project-image h-full w-full object-cover object-center" loading="lazy" />
              <div class="project-image-overlay absolute inset-0"></div>
            </div>

            <div class="project-card-body flex grow flex-col p-5 md:p-6">
              <h3 class="text-lg font-semibold leading-tight text-text">{project.title}</h3>
              <p class="mt-3 text-[15px] leading-relaxed text-text/88">{teaser}</p>
              <p class="mt-4 text-sm leading-relaxed text-muted">{project.impact}</p>

              <div class="mt-5 flex flex-wrap gap-2">
                {
                  stackItems.map((tech) => (
                    <span class="stack-chip border border-border/80 bg-surface/35 px-2.5 py-1 text-[10px] font-medium uppercase tracking-[0.1em] text-muted/95 md:text-[11px]">
                      {tech}
                    </span>
                  ))
                }
              </div>
            </div>

            <div class="project-card-footer mt-auto flex w-full items-center justify-between gap-4 border-t border-border/50 px-5 py-4 md:px-6">
              <span class="text-[10px] font-medium uppercase tracking-[0.14em] text-muted/85 md:text-[11px]">
                {ui.sectionTags[index] ?? ui.sectionTags[0]}
              </span>
              <a
                href="/detalles#proyectos"
                class="inline-cta project-link text-[11px] md:text-xs"
              >
                <span>{ui.detailsLabel}</span>
                <Icon name="lucide:arrow-right" class="h-3.5 w-3.5" aria-hidden="true" />
              </a>
            </div>
          </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .project-card-body,
  .project-card-footer {
    background: transparent;
  }

  .project-image {
    transition: transform 420ms ease;
  }

  .project-card:hover .project-image {
    transform: scale(1.03);
  }

  .project-image-overlay {
    background: linear-gradient(to top, rgba(10, 10, 10, 0.38), rgba(10, 10, 10, 0.1));
  }

  .project-link:focus-visible {
    outline-offset: 4px;
  }

  .project-card:hover .project-link,
  .project-card:focus-within .project-link {
    color: color-mix(in oklab, var(--color-text) 88%, white);
  }

  .project-card:hover .project-link::after,
  .project-card:focus-within .project-link::after {
    transform: scaleX(1);
    background: color-mix(in oklab, var(--color-text) 90%, white);
  }

  @media (prefers-reduced-motion: reduce) {
    .project-image,
    .project-link {
      transition: none;
    }

    .project-card:hover .project-image {
      transform: none;
    }
  }
</style>
