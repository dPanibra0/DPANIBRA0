---
import { Icon } from "astro-icon/components";
import type { PortfolioContent, PortfolioUiTranslations } from "../../content/types";

interface Props {
  id: string;
  projects: PortfolioContent["projects"];
  overline: string;
  ui: PortfolioUiTranslations["projects"];
}

const { id, projects, overline, ui } = Astro.props;

const fallbackProject: (typeof projects.items)[number] = {
  title: ui.fallbackProject.title,
  impact: ui.fallbackProject.impact,
  stack: ui.fallbackProject.stack,
  problem: "",
  architecture: "",
  challenges: "",
  solution: "",
};

const visibleProjects = [...projects.items];
while (visibleProjects.length < 3) {
  visibleProjects.push(fallbackProject);
}

const projectImages = ["/images/proyecto-01.png", "/images/proyecto-02.jpg", "/images/proyecto-03.jpg"];
const projectIcons = ["lucide:boxes", "lucide:shield-check", "lucide:compass"];
---

<section id={id} class="section-space border-t border-border/50">
  <div class="container-shell pt-8 md:pt-12">
    <p class="micro-label mb-5" data-reveal="up">{overline}</p>
      <h2 class="max-w-[780px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]" data-reveal="up">
      {ui.headingTop}
      <br />
      <span class="text-muted">{ui.headingBottom}</span>
    </h2>
    <p class="mt-7 max-w-[860px] text-base leading-relaxed text-muted md:text-lg" data-reveal="up">{projects.intro}</p>

    <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-3" data-reveal-group data-reveal-stagger-mobile="72" data-reveal-stagger-desktop="54">
      {
        visibleProjects.map((project, index) => {
          const isFallbackCard = index >= projects.items.length;
          const detailsHref = isFallbackCard ? "/detalles" : `/detalles#proyecto-${index + 1}`;
          const imageSrc = projectImages[index] ?? projectImages[projectImages.length - 1];
          const iconName = projectIcons[index] ?? "lucide:folder-open-dot";

          return (
          <article class="group flex h-full flex-col overflow-hidden border border-border/60 bg-surface/95" data-reveal="up">
            <div class="relative h-[220px] overflow-hidden">
              <img src={imageSrc} alt={project.title} class="h-full w-full object-cover object-center opacity-55" loading="lazy" />
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_12%_20%,rgba(77,131,166,0.32),transparent_35%)]"></div>
              <div class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-b from-transparent via-surface/90 to-[#0a0a0a]"></div>
              <span class="absolute left-4 top-4 inline-flex max-w-[88%] items-center gap-2 border border-border/70 bg-surface/75 px-3 py-1.5 text-[10px] font-medium uppercase tracking-[0.16em] text-text/90 backdrop-blur-sm md:text-[11px]">
                <Icon name={iconName} class="h-3.5 w-3.5 shrink-0 text-[#ffffff]" aria-hidden="true" />
                <span class="truncate">{project.title}</span>
              </span>
            </div>

            <div class="flex grow flex-col p-5 md:p-6 ">
              <p class="text-[15px] font-medium leading-relaxed text-text/92 md:text-base">{project.impact}</p>

              <div class="mt-5 flex flex-wrap gap-2">
                {project.stack.split(",").slice(0, 4).map((tech) => <span class="border border-border/80 bg-surface/35 px-2.5 py-1 text-[10px] font-medium uppercase tracking-[0.1em] text-muted/95 md:text-[11px]">{tech.trim()}</span>)}
              </div>
            </div>

            <div class="footer-card-proyect-background mt-auto flex w-full items-center justify-between gap-4 border-t border-border/50 bg-surface/80 px-5 py-4 md:px-6">
                <span class="text-[10px] font-medium uppercase tracking-[0.14em] text-muted/85 md:text-[11px]">
                {ui.sectionTags[index] ?? ui.sectionTags[0]}
              </span>
              <a
                href={detailsHref}
                class="inline-cta text-[11px] text-white/96 group-hover:text-white md:text-xs"
              >
                {ui.detailsLabel} →
              </a>
            </div>
          </article>
          );
        })
      }
    </div>
  </div>
</section>
