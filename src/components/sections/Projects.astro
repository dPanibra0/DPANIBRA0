---
import type { PortfolioContent } from "../../content/types";

interface Props {
  id: string;
  projects: PortfolioContent["projects"];
  overline: string;
  labels: {
    problem: string;
    architecture: string;
    stack: string;
    challenges: string;
    solution: string;
    impact: string;
  };
}

const { id, projects, overline, labels } = Astro.props;
const isEnglish = projects.title.toLowerCase().includes("featured");

const headlineTop = isEnglish ? "Featured" : "Decisiones técnicas con";
const headlineBottom = isEnglish ? "enterprise project architecture" : "impacto empresarial real";

const metricLabels = isEnglish
  ? ["Latency reduction", "Production uptime", "Response window"]
  : ["Reduccion latencia", "Uptime alcanzado", "Tiempo de respuesta"];

const metricValues = [
  ["84%", "99.9%", "5s→800ms"],
  ["67%", "99.8%", "2.4h→55m"],
];

const sectionTags = isEnglish
  ? ["Logistics · Microservices", "Finance · Batch"]
  : ["Logistica · Microservicios", "Finanzas · Batch"];
---

<section id={id} class="section-space border-t border-border/50">
  <div class="container-shell pt-8 md:pt-12">
    <p class="micro-label mb-5">{overline}</p>
    <h2 class="max-w-[780px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]">
      {headlineTop}
      <br />
      <span class="text-muted">{headlineBottom}</span>
    </h2>
    <p class="mt-7 max-w-[860px] text-base leading-relaxed text-muted md:text-lg">{projects.intro}</p>

    <div class="mt-12 space-y-6">
      {
        projects.items.map((project, index) => (
          <article class="overflow-hidden rounded-2xl border border-border/60 bg-black/20">
            <div class="relative h-[240px] overflow-hidden md:h-[300px] lg:h-[340px]">
              <img src="/images/hero-real.png" alt={project.title} class="h-full w-full object-cover object-center opacity-55" loading="lazy" />
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_12%_20%,rgba(77,131,166,0.32),transparent_35%)]"></div>
              <div class="project-image-fade pointer-events-none absolute inset-x-0 bottom-0 h-20 md:h-24"></div>
              <span class="absolute left-4 top-4 rounded-full border border-border/80 bg-black/35 px-3 py-1 text-xs text-muted">{sectionTags[index] ?? sectionTags[0]}</span>
            </div>

            <div class="grid gap-6 p-6 md:p-7 lg:grid-cols-[1.45fr_0.55fr]">
              <div>
                <h3 class="text-xl font-semibold tracking-[-0.02em] text-text md:text-2xl">{project.title}</h3>
                <p class="mt-3 max-w-[900px] text-sm leading-relaxed text-muted md:text-base">{project.impact}</p>

                <div class="mt-6 flex flex-wrap gap-2.5">
                  {project.stack.split(",").map((tech) => <span class="rounded-md border border-border/80 bg-surface/30 px-2.5 py-1.5 text-xs text-muted">{tech.trim()}</span>)}
                </div>
              </div>

                <div class="space-y-3 text-xs text-muted md:text-sm">
                {metricLabels.map((label, metricIndex) => <div class="flex items-center justify-between border-b border-border/40 pb-2">
                  <span>{label}</span>
                  <span class="text-text">{metricValues[index]?.[metricIndex] ?? metricValues[0][metricIndex]}</span>
                </div>)}
              </div>
            </div>

            <details class="project-details">
              <summary class="flex cursor-pointer list-none items-center gap-2 px-6 py-4 text-sm font-medium text-muted transition hover:text-text md:px-8">
                <span class="details-open-label">{isEnglish ? "Hide details" : "Ocultar detalles"}</span>
                <span class="details-closed-label">{isEnglish ? "Show details" : "Ver detalles"}</span>
                <span class="details-arrow text-base">⌃</span>
              </summary>

              <div class="grid gap-6 p-6 md:p-7 lg:grid-cols-2">
                <div>
                  <p class="micro-label mb-4">{labels.problem}</p>
                  <p class="text-sm leading-relaxed text-muted md:text-base">{project.problem}</p>

                  <p class="micro-label mb-4 mt-8">{labels.architecture}</p>
                  <p class="text-sm leading-relaxed text-muted md:text-base">{project.architecture}</p>
                </div>

                <div>
                  <p class="micro-label mb-4">{labels.solution}</p>
                  <ul class="space-y-3">
                    {project.solution.split(",").map((item) => <li class="flex gap-3 text-sm leading-relaxed text-muted md:text-base">
                      <span class="text-muted">✓</span>
                      <span>{item.trim()}</span>
                    </li>)}
                  </ul>
                </div>
              </div>
            </details>
          </article>
        ))
      }
    </div>
  </div>
</section>
