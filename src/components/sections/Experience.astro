---
import type { PortfolioContent } from "../../content/types";

interface Props {
  id: string;
  experience: PortfolioContent["experience"];
  overline: string;
}

const { id, experience, overline } = Astro.props;
const detailsHref = "/detalles";
const detailsLabel = "Ver mas detalle";

const getFinalDate = (period: string) => {
  const fragments = period
    .split("-")
    .map((part) => part.trim())
    .filter(Boolean);

  if (!fragments.length) return period;
  return fragments[fragments.length - 1] ?? period;
};
---

<section id={id} class="section-space border-t border-border/50">
  <div class="container-shell pt-8 md:pt-12">
    <p class="micro-label mb-5" data-reveal="up">{overline}</p>
    <h2 class="max-w-[860px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]" data-reveal="up">
      {experience.headingPrimary}
      <br />
      <span class="text-muted">{experience.headingSecondary}</span>
    </h2>

    <div class="exp-timeline mt-12 md:mt-14" data-reveal="up" data-reveal-delay="90">
      <div class="exp-rail" aria-hidden="true"></div>
      <div class="exp-list">
        {
          experience.items.map((item) => {
            const context = (item as { context?: string }).context ?? "";

            return (
            <article
              class="exp-item"
              data-exp-item
            >
              <span class="exp-node" aria-hidden="true"></span>
              <div class="exp-meta pr-2">
                <h3 class="text-[18px] font-semibold tracking-[-0.015em] text-text md:text-[20px]">{item.role}</h3>
                <p class="mt-1 text-sm uppercase tracking-[0.1em] text-muted/80">{item.company}</p>
                {context && <p class="mt-2 text-xs leading-relaxed text-muted/85 md:text-sm">{context}</p>}
                <p class="mt-3 text-xs font-medium uppercase tracking-[0.12em] text-muted/70">{getFinalDate(item.period)}</p>
              </div>
            </article>
            );
          })
        }
      </div>
    </div>

    <div class="mt-10 md:mt-12" data-reveal="up" data-reveal-delay="120">
      <a href={detailsHref} class="exp-cta inline-flex items-center gap-2 text-sm font-medium text-text md:text-base">
        <span>{detailsLabel}</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .exp-timeline {
    position: relative;
  }

  .exp-rail {
    position: absolute;
    left: 0;
    top: 14px;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, rgba(92, 108, 124, 0.2), rgba(106, 145, 175, 0.65), rgba(92, 108, 124, 0.2));
  }

  .exp-list {
    display: grid;
    gap: 0.9rem;
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .exp-item {
    position: relative;
    min-height: 150px;
    padding: 1rem 0.35rem 0.75rem 0;
    opacity: 0.44;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .exp-item:first-child {
    opacity: 1;
  }

  .exp-node {
    position: absolute;
    left: 1rem;
    top: 0.55rem;
    width: 0.62rem;
    height: 0.62rem;
    border: 1px solid #bfd0de;
    border-radius: 999px;
    background: #eef4fb;
    box-shadow: 0 0 0 3px rgba(8, 10, 13, 0.95);
    transition: transform 180ms ease;
  }

  .exp-item:hover,
  .exp-item:focus-within {
    opacity: 1;
  }

  .exp-item:hover .exp-node,
  .exp-item:focus-within .exp-node {
    transform: scale(1.08);
  }

  .exp-list:hover .exp-item {
    opacity: 0.34;
  }

  .exp-list:hover .exp-item:hover,
  .exp-list:hover .exp-item:focus-within {
    opacity: 1;
  }

  .exp-cta {
    text-decoration: underline;
    text-decoration-color: rgba(163, 180, 196, 0.6);
    text-underline-offset: 3px;
  }

  .exp-cta:hover,
  .exp-cta:focus-visible {
    text-decoration-color: rgba(226, 235, 246, 0.95);
  }

  @media (min-width: 768px) {
    .exp-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.1rem;
    }

    .exp-item {
      min-height: 170px;
      padding-right: 0.8rem;
    }
  }

  @media (min-width: 1120px) {
    .exp-list {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (max-width: 767px) {
    .exp-rail {
      top: 0.5rem;
      left: 0.6rem;
      width: 1px;
      height: calc(100% - 1rem);
      background: linear-gradient(180deg, rgba(92, 108, 124, 0.25), rgba(106, 145, 175, 0.7), rgba(92, 108, 124, 0.25));
    }

    .exp-item {
      margin-left: 1.5rem;
      padding-top: 1rem;
    }

    .exp-node {
      left: -1.2rem;
      top: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .exp-item,
    .exp-node {
      transition: none;
    }
  }
</style>
