---
import type { PortfolioContent, PortfolioUiTranslations } from "../../content/types";
import { Icon } from "astro-icon/components";

interface Props {
  id: string;
  experience: PortfolioContent["experience"];
  overline: string;
  ui: PortfolioUiTranslations["experience"];
}

const { id, experience, overline, ui } = Astro.props;
const detailsHref = "/experiencia";
const detailsLabel = ui.detailsLabel;
const companyAccentMap: Record<string, string> = {
  LATAMTECH: "#eef4fb",
  "NTT DATA": "#6eb6ff",
  MULTIPLICA: "#ffb06b",
  "ALMA SOFTWARE": "#8bd3a7",
};

const getFinalDate = (period: string) => {
  const fragments = period
    .split("-")
    .map((part) => part.trim())
    .filter(Boolean);

  if (!fragments.length) return period;
  return fragments[fragments.length - 1] ?? period;
};
---

<section id={id} class="section-space border-t border-border/50">
  <div class="container-shell pt-8 md:pt-12">
    <p class="micro-label mb-5" data-reveal="up">{overline}</p>
    <h2 class="max-w-[860px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]" data-reveal="up">
      {experience.headingPrimary}
      <br />
      <span class="text-muted">{experience.headingSecondary}</span>
    </h2>

    <div class="exp-timeline mt-12 md:mt-14" data-reveal="up" data-reveal-delay="90">
      <div class="exp-rail" aria-hidden="true"></div>
      <div class="exp-list">
        {
          experience.items.map((item) => {
            const context = (item as { context?: string }).context ?? "";

            return (
            <article
              class="exp-item"
              data-exp-item
              style={`--exp-company-color: ${companyAccentMap[item.company] ?? "#eef4fb"};`}
            >
              <span class="exp-node" aria-hidden="true"></span>
              <div class="exp-meta pr-2">
                <h3 class="text-[18px] font-semibold tracking-[-0.015em] text-text md:text-[20px]">{item.role}</h3>
                <p class="mt-1 text-sm uppercase tracking-[0.1em] text-muted/80">
                  <span class="exp-company-name">{item.company}</span>
                </p>
                {context && <p class="mt-2 text-xs leading-relaxed text-muted/85 md:text-sm">{context}</p>}
                <p class="micro-label mt-3 text-xs font-medium uppercase tracking-[0.12em] text-muted/70">{getFinalDate(item.period)}</p>
              </div>
            </article>
            );
          })
        }
      </div>
    </div>

    <div class="exp-footer mt-10 md:mt-12" data-reveal="up" data-reveal-delay="120">
      <a href={detailsHref} class="inline-cta exp-cta text-xs md:text-sm">
        <span>{detailsLabel}</span>
        <Icon name="lucide:arrow-right" class="h-3.5 w-3.5" aria-hidden="true" />
      </a>
    </div>
  </div>
</section>

<style>
  .exp-timeline {
    position: relative;
  }

  .exp-rail {
    position: absolute;
    left: 0;
    top: 14px;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, rgba(92, 108, 124, 0.2), rgba(106, 145, 175, 0.65), rgba(92, 108, 124, 0.2));
  }

  .exp-list {
    display: grid;
    gap: 0.9rem;
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .exp-item {
    position: relative;
    min-height: 150px;
    padding: 1rem 0.35rem 0.75rem 0;
    opacity: 0.44;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .exp-company-name {
    color: rgba(167, 176, 187, 0.8);
    transition: color 180ms ease;
  }

  .exp-node {
    position: absolute;
    left: 1rem;
    top: 0.55rem;
    width: 0.62rem;
    height: 0.62rem;
    border: 1px solid #bfd0de;
    border-radius: 999px;
    background: #eef4fb;
    box-shadow: 0 0 0 3px rgba(8, 10, 13, 0.95);
    transition: transform 180ms ease;
  }

  .exp-item[data-mobile-active="true"] .exp-company-name {
    color: var(--exp-company-color, #eef4fb);
  }

  .exp-item[data-mobile-active="true"] .exp-node {
    transform: scale(1.08);
  }

  .exp-item[data-mobile-active="true"] {
    opacity: 1;
  }

  @media (min-width: 768px) {
    .exp-item:first-child {
      opacity: 1;
    }

    .exp-item:first-child .exp-company-name {
      color: var(--exp-company-color, #eef4fb);
    }

    .exp-item:first-child .exp-node {
      transform: scale(1.08);
    }
  }

  @media (min-width: 768px) {
    .exp-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.1rem;
    }

    .exp-item {
      min-height: 170px;
      padding-right: 0.8rem;
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .exp-item:hover,
    .exp-item:focus-within {
      opacity: 1;
    }

    .exp-item:hover .exp-company-name,
    .exp-item:focus-within .exp-company-name {
      color: var(--exp-company-color, #eef4fb);
    }

    .exp-item:hover .exp-node,
    .exp-item:focus-within .exp-node {
      transform: scale(1.08);
    }

    .exp-list:hover .exp-item {
      opacity: 0.34;
    }

    .exp-list:hover .exp-item:hover,
    .exp-list:hover .exp-item:focus-within {
      opacity: 1;
    }

    .exp-timeline:hover + .exp-footer .exp-cta,
    .exp-timeline:focus-within + .exp-footer .exp-cta {
      color: color-mix(in oklab, var(--color-text) 88%, white);
    }

    .exp-timeline:hover + .exp-footer .exp-cta::after,
    .exp-timeline:focus-within + .exp-footer .exp-cta::after {
      transform: scaleX(1);
      background: color-mix(in oklab, var(--color-text) 90%, white);
    }
  }

  @media (min-width: 1120px) {
    .exp-list {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (max-width: 767px) {
    .exp-rail {
      top: 0.5rem;
      left: 0.6rem;
      width: 1px;
      height: calc(100% - 1rem);
      background: linear-gradient(180deg, rgba(92, 108, 124, 0.25), rgba(106, 145, 175, 0.7), rgba(92, 108, 124, 0.25));
    }

    .exp-item {
      margin-left: 1.5rem;
      padding-top: 1rem;
    }

    .exp-node {
      left: -1.2rem;
      top: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .exp-item,
    .exp-node,
    .exp-company-name {
      transition: none;
    }
  }
</style>

<script>
  (() => {
    const mobileViewport = window.matchMedia("(max-width: 767px)");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const items = Array.from(document.querySelectorAll("[data-exp-item]"));

    if (!items.length) return;

    let ticking = false;

    const clearActive = () => {
      items.forEach((item) => item.removeAttribute("data-mobile-active"));
    };

    const setActive = (nextItem) => {
      items.forEach((item) => {
        if (item === nextItem) {
          item.setAttribute("data-mobile-active", "true");
        } else {
          item.removeAttribute("data-mobile-active");
        }
      });
    };

    const getMidpointItem = () => {
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
      const viewportMidpoint = viewportHeight / 2;
      const activationRadius = Math.min(viewportHeight * 0.12, 88);

      let closestItem = null;
      let closestDistance = Number.POSITIVE_INFINITY;

      items.forEach((item) => {
        if (!(item instanceof HTMLElement)) return;

        const rect = item.getBoundingClientRect();
        const itemCenter = rect.top + rect.height / 2;
        const distance = Math.abs(itemCenter - viewportMidpoint);

        if (distance < closestDistance) {
          closestDistance = distance;
          closestItem = item;
        }
      });

      if (!(closestItem instanceof HTMLElement) || closestDistance > activationRadius) {
        return null;
      }

      return closestItem;
    };

    const updateActive = () => {
      ticking = false;

      if (!mobileViewport.matches || reducedMotion.matches) {
        clearActive();
        return;
      }

      const nextItem = getMidpointItem();
      if (!nextItem) {
        clearActive();
        return;
      }

      setActive(nextItem);
    };

    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateActive);
    };

    updateActive();
    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);
    mobileViewport.addEventListener("change", requestUpdate);
    reducedMotion.addEventListener("change", requestUpdate);
  })();
</script>
