---
import type { PortfolioContent } from "../../content/types";

interface Props {
  id: string;
  experience: PortfolioContent["experience"];
  overline: string;
}

const { id, experience, overline } = Astro.props;
const isEnglish = experience.title.toLowerCase().includes("professional");

const headlineTop = isEnglish ? "Career in" : "Historial en entornos";
const headlineBottom = isEnglish ? "high-impact corporate environments" : "corporativos de alto impacto";
---

<section id={id} class="section-space border-t border-border/50">
  <div class="container-shell pt-8 md:pt-12">
    <p class="micro-label mb-5">{overline}</p>
    <h2 class="max-w-[860px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]">
      {headlineTop}
      <br />
      <span class="text-muted">{headlineBottom}</span>
    </h2>

    <div class="relative mt-14 md:mt-16">
      <div class="absolute bottom-3 left-4 top-3 w-px bg-border/90"></div>

      <div class="space-y-24 md:space-y-28">
        {
          experience.items.map((item) => (
            <article class="exp-reveal relative pl-10 md:pl-14" data-exp-item>
              <span class="absolute left-[9px] top-5 h-3.5 w-3.5 rounded-full border border-accent-strong/70 bg-accent md:left-[10px]"></span>

              <div class="max-w-[960px] rounded-2xl border border-border/50 bg-black/12 px-6 py-6 transition duration-200 hover:border-accent/40 md:px-8 md:py-7">
                <p class="text-sm font-medium tracking-[0.01em] text-[#bcc6d1] md:text-[15px]">{item.period}</p>
                <h3 class="mt-2 text-[22px] font-semibold leading-tight tracking-[-0.02em] text-text md:text-[24px]">{item.role}</h3>
                <p class="mt-2 text-lg font-medium text-text/90">{item.company}</p>
                <p class="mt-3 text-base leading-relaxed text-muted">{item.context}</p>

                <ul class="mt-5 space-y-2.5">
                  {
                    item.highlights.slice(0, 4).map((highlight) => (
                      <li class="flex gap-3 text-[15px] leading-relaxed text-muted md:text-base">
                        <span class="mt-[2px] text-accent-strong">•</span>
                        <span>{highlight}</span>
                      </li>
                    ))
                  }
                </ul>

                <div class="mt-5 flex flex-wrap gap-2">
                  {
                    item.technologies.map((tech) => (
                      <span class="rounded-md border px-2.5 py-1 text-xs text-[#c1c9d2] md:text-sm" style="background:#161616;border-color:#2a2a2a;">
                        {tech}
                      </span>
                    ))
                  }
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .exp-reveal {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 360ms ease, transform 360ms ease;
  }

  .exp-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .exp-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const items = Array.from(document.querySelectorAll("[data-exp-item]"));
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (reduceMotion) {
    items.forEach((item) => item.classList.add("is-visible"));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2, rootMargin: "0px 0px -10% 0px" },
    );

    items.forEach((item) => observer.observe(item));
  }
</script>
