---
import type { PortfolioContent } from "../../content/types";

interface Props {
  id: string;
  experience: PortfolioContent["experience"];
  overline: string;
}

const { id, experience, overline } = Astro.props;
const isEnglish = experience.title.toLowerCase().includes("professional");

const headlineTop = isEnglish ? "Career in" : "Historial en entornos";
const headlineBottom = isEnglish ? "high-impact corporate environments" : "corporativos de alto impacto";
---

<section id={id} class="section-space border-t border-border/50">
  <div class="container-shell pt-8 md:pt-12">
    <p class="micro-label mb-5">{overline}</p>
    <h2 class="max-w-[860px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]">
      {headlineTop}
      <br />
      <span class="text-muted">{headlineBottom}</span>
    </h2>

    <div class="relative mt-14 md:mt-16">
      <div class="absolute bg-gray-300  bottom-2 left-[10px] top-2 w-px bg-gradient-to-b from-accent/70 via-accent-strong/45 to-accent/70"></div>

      <div class="space-y-24 md:space-y-28">
        {
          experience.items.map((item, index) => {
            const context = (item as { context?: string }).context ?? "";
            const technologies = (item as { technologies?: string[] }).technologies ?? [];

            return (
            <article
              class="exp-item relative grid gap-8 pl-10 md:pl-14 lg:grid-cols-[0.34fr_0.66fr] lg:gap-14"
              data-exp-item
            >
              <span class="exp-segment pointer-events-none absolute bottom-2 left-[10px] top-2 w-px"></span>
              <span class="exp-node absolute left-[3px] top-2 h-3.5 w-3.5 rounded-full border shadow-[0_0_0_2px_rgba(10,10,10,0.95)] md:left-[3px]"></span>

              <div class="space-y-2">
                <h3 class="text-lg font-semibold tracking-[-0.01em] text-text md:text-[28px]">{item.company}</h3>
                <p class="text-sm text-[#bcc6d1] md:text-[15px]">{item.period}</p>
                <p class="text-sm text-muted/80 md:text-base">
                  {isEnglish ? (index === 0 ? "Full-time · Remote" : "Full-time · On-site") : index === 0 ? "Full-time · Remoto" : "Full-time · Presencial"}
                </p>
              </div>

              <div class="max-w-[920px]">
                <h4 class="text-[22px] font-semibold tracking-[-0.02em] text-text md:text-3xl">{item.role}</h4>
                {context && <p class="mt-3 text-base leading-relaxed text-muted">{context}</p>}

                <ul class="mt-6 space-y-3">
                  {
                    item.highlights.slice(0, 4).map((highlight) => (
                      <li class="flex gap-3 text-[15px] leading-relaxed text-muted md:text-base">
                        <span class="mt-[1px] text-muted">›</span>
                        <span>{highlight}</span>
                      </li>
                    ))
                  }
                </ul>

                <div class="mt-6 flex flex-wrap gap-2">
                  {technologies.map((tech) => (
                    <span class="rounded-md border px-2.5 py-1 text-xs text-[#c1c9d2] md:text-sm" style="background:#161616;border-color:#2a2a2a;">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </article>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<style>
  .exp-item {
    opacity: 0.4;
    transition: opacity 300ms ease;
  }

  .exp-node {
    border-color: #9aa8b8;
    background: #cdd4db;
    transition: transform 180ms ease, background-color 180ms ease, border-color 180ms ease;
  }

  .exp-segment {
    background: rgba(77, 131, 166, 0.55);
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .exp-item:hover,
  .exp-item.is-active {
    opacity: 1;
  }

  .exp-item:hover .exp-segment,
  .exp-item.is-active .exp-segment {
    opacity: 1;
  }

  .exp-item:hover .exp-node,
  .exp-item.is-active .exp-node {
    transform: scale(1.1);
    border-color: #d8e3ee;
    background: #f6f8fb;
  }
</style>

<script>
  const items = Array.from(document.querySelectorAll("[data-exp-item]"));

  if (items.length) {
    let ticking = false;

    const updateActiveItem = () => {
      const triggerY = window.innerHeight * 0.45;
      let activeItem = null;
      let nearest = Number.POSITIVE_INFINITY;

      for (const item of items) {
        const rect = item.getBoundingClientRect();
        const containsTrigger = rect.top <= triggerY && rect.bottom >= triggerY;

        if (containsTrigger) {
          activeItem = item;
          break;
        }

        const center = rect.top + rect.height / 2;
        const distance = Math.abs(center - triggerY);
        if (distance < nearest) {
          nearest = distance;
          activeItem = item;
        }
      }

      items.forEach((item) => item.classList.toggle("is-active", item === activeItem));
      ticking = false;
    };

    const onScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(updateActiveItem);
        ticking = true;
      }
    };

    updateActiveItem();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
  }
</script>
