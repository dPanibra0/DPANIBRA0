                        <ellipse data-observable-ring="ring_3" cx="160" cy="120" rx="104" ry="76" stroke-width="1.15" />
                      </g>
                      <g stroke="currentColor" stroke-width="1.1" opacity="0.78">
                        <line data-observable-spoke="north" x1="160" y1="44" x2="160" y2="76" />
                        <line data-observable-spoke="east" x1="252" y1="120" x2="220" y2="120" />
                        <line data-observable-spoke="south" x1="160" y1="196" x2="160" y2="164" />
