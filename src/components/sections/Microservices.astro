                      <g data-resilient-node="node_a"><polygon points="96,84 122,99 122,129 96,144 70,129 70,99" /></g>
                      <g data-resilient-node="node_b"><polygon points="160,84 186,99 186,129 160,144 134,129 134,99" /></g>
                      <g data-resilient-node="node_c"><polygon points="224,84 250,99 250,129 224,144 198,129 198,99" /></g>
                      <g data-resilient-node="node_d"><polygon points="128,136 154,151 154,181 128,196 102,181 102,151" /></g>
                      <g data-resilient-node="node_e"><polygon points="192,136 218,151 218,181 192,196 166,181 166,151" /></g>
                    </g>
                    <g stroke="currentColor" stroke-width="1.1" opacity="0.65" pointer-events="none">
                      <line data-resilient-link="link_fg" x1="128" y1="62" x2="192" y2="62" />
                      <line data-resilient-link="link_fa" x1="128" y1="62" x2="96" y2="114" />
                      <line data-resilient-link="link_bf" x1="160" y1="114" x2="128" y2="62" />
                      <line data-resilient-link="link_gb" x1="192" y1="62" x2="160" y2="114" />
                      <line data-resilient-link="link_gc" x1="192" y1="62" x2="224" y2="114" />
                      <line data-resilient-link="link_ab" x1="96" y1="114" x2="160" y2="114" />
                      <line data-resilient-link="link_bc" x1="160" y1="114" x2="224" y2="114" />
                      <line data-resilient-link="link_bd" x1="160" y1="114" x2="128" y2="166" />
                      <line data-resilient-link="link_be" x1="160" y1="114" x2="192" y2="166" />
                      <line data-resilient-link="link_ad" x1="96" y1="114" x2="128" y2="166" />
                      <line data-resilient-link="link_ce" x1="224" y1="114" x2="192" y2="166" />
                      <line data-resilient-link="link_de" x1="128" y1="166" x2="192" y2="166" />
                    </g>
                    <g data-resilient-hover-indicator stroke="#d98a8a" fill="none" stroke-width="1.4" opacity="0">
                      <polygon points="160,84 186,99 186,129 160,144 134,129 134,99" />
                      <line x1="147" y1="101" x2="173" y2="127" />
                      <line x1="173" y1="101" x2="147" y2="127" />
                    </g>
                    <g stroke="#d98a8a" fill="none" stroke-width="1.8" opacity="0" data-resilient-fail-mark="node_f"><line x1="115" y1="49" x2="141" y2="75" /><line x1="141" y1="49" x2="115" y2="75" /></g>
                    <g stroke="#d98a8a" fill="none" stroke-width="1.8" opacity="0" data-resilient-fail-mark="node_g"><line x1="179" y1="49" x2="205" y2="75" /><line x1="205" y1="49" x2="179" y2="75" /></g>
                    <g stroke="#d98a8a" fill="none" stroke-width="1.8" opacity="0" data-resilient-fail-mark="node_a"><line x1="83" y1="101" x2="109" y2="127" /><line x1="109" y1="101" x2="83" y2="127" /></g>
                    <g stroke="#d98a8a" fill="none" stroke-width="1.8" opacity="0" data-resilient-fail-mark="node_b"><line x1="147" y1="101" x2="173" y2="127" /><line x1="173" y1="101" x2="147" y2="127" /></g>
                    <g stroke="#d98a8a" fill="none" stroke-width="1.8" opacity="0" data-resilient-fail-mark="node_c"><line x1="211" y1="101" x2="237" y2="127" /><line x1="237" y1="101" x2="211" y2="127" /></g>
                    <g stroke="#d98a8a" fill="none" stroke-width="1.8" opacity="0" data-resilient-fail-mark="node_d"><line x1="115" y1="153" x2="141" y2="179" /><line x1="141" y1="153" x2="115" y2="179" /></g>
                    <g stroke="#d98a8a" fill="none" stroke-width="1.8" opacity="0" data-resilient-fail-mark="node_e"><line x1="179" y1="153" x2="205" y2="179" /><line x1="205" y1="153" x2="179" y2="179" /></g>
                  </svg>
                )
              }
               {
                 concept === "observable" && (
                  <svg viewBox="0 0 320 220" class="micro-diagram" role="group" aria-label="Observable: activar pulso radial desde el centro" data-anim-svg="observable" aria-busy="false">
