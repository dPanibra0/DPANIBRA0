---
interface Props {
  id: string;
  microservices: {
    headingPrimary: string;
    headingSecondary: string;
    intro: string;
    pillars: Array<{
      title: string;
      description: string;
    }>;
  };
  overline: string;
}

const { id, microservices, overline } = Astro.props as Props;

const figureLabels = ["FIG 0.2", "FIG 0.3", "FIG 0.4"];
const figureConcepts = ["scalable", "resilient", "observable"];
---

<section id={id} class="section-space border-t border-border/50">
  <div class="container-shell pt-8 md:pt-12">
    <p class="micro-label mb-5" data-reveal="up">{overline}</p>
    <h2 class="max-w-[860px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]" data-reveal="up">
      {microservices.headingPrimary}
      <br />
      <span class="text-muted">{microservices.headingSecondary}</span>
    </h2>
    <p class="mt-6 max-w-[760px] text-base leading-relaxed text-muted md:text-lg" data-reveal="up">{microservices.intro}</p>

    <div class="mt-9 md:mt-10">
      <div
        class="micro-grid md:grid md:grid-cols-3"
        data-reveal-group
        data-reveal-stagger-mobile="66"
        data-reveal-stagger-desktop="52"
      >
        {
          microservices.pillars.map((pillar, index) => (
            <article class="micro-card border-b border-border/40 p-5 md:border-b-0 md:px-7 md:py-6" data-reveal="up">
            <p class="micro-card-label text-[12px] uppercase tracking-[0.12em] text-muted/60">{figureLabels[index] ?? "FIG"}</p>
            <div class="micro-figure mt-4" aria-hidden="true">
              {
                (figureConcepts[index] ?? "") === "scalable" && (
                  <svg viewBox="0 0 320 220" class="micro-diagram" role="presentation">
                    <g stroke="currentColor" fill="none" stroke-width="1.6">
                      <polygon points="160,48 186,63 186,93 160,108 134,93 134,63" />
                      <polygon points="112,76 138,91 138,121 112,136 86,121 86,91" />
                      <polygon points="208,76 234,91 234,121 208,136 182,121 182,91" />
                      <polygon points="160,104 186,119 186,149 160,164 134,149 134,119" />
                      <polygon points="64,104 90,119 90,149 64,164 38,149 38,119" opacity="0.75" />
                      <polygon points="256,104 282,119 282,149 256,164 230,149 230,119" opacity="0.75" />
                    </g>
                    <g stroke="currentColor" stroke-width="1.1" opacity="0.6">
                      <line x1="112" y1="106" x2="160" y2="78" />
                      <line x1="208" y1="106" x2="160" y2="78" />
                      <line x1="160" y1="136" x2="112" y2="106" />
                      <line x1="160" y1="136" x2="208" y2="106" />
                      <line x1="64" y1="134" x2="112" y2="106" />
                      <line x1="256" y1="134" x2="208" y2="106" />
                    </g>
                  </svg>
                )
              }
              {
                (figureConcepts[index] ?? "") === "resilient" && (
                  <svg viewBox="0 0 320 220" class="micro-diagram" role="presentation">
                    <g stroke="currentColor" fill="none" stroke-width="1.6">
                      <polygon points="96,84 122,99 122,129 96,144 70,129 70,99" />
                      <polygon points="160,84 186,99 186,129 160,144 134,129 134,99" />
                      <polygon points="224,84 250,99 250,129 224,144 198,129 198,99" />
                      <polygon points="128,132 154,147 154,177 128,192 102,177 102,147" />
                      <polygon points="192,132 218,147 218,177 192,192 166,177 166,147" />
                    </g>
                    <g stroke="currentColor" stroke-width="1.1" opacity="0.65">
                      <line x1="96" y1="114" x2="160" y2="114" />
                      <line x1="160" y1="114" x2="224" y2="114" />
                      <line x1="160" y1="114" x2="128" y2="162" />
                      <line x1="160" y1="114" x2="192" y2="162" />
                    </g>
                    <g stroke="#d98a8a" fill="none" stroke-width="1.6" opacity="0.9">
                      <polygon points="272,44 294,57 294,83 272,96 250,83 250,57" />
                      <line x1="251" y1="58" x2="293" y2="82" />
                      <line x1="293" y1="58" x2="251" y2="82" />
                    </g>
                  </svg>
                )
              }
              {
                (figureConcepts[index] ?? "") === "observable" && (
                  <svg viewBox="0 0 320 220" class="micro-diagram" role="presentation">
                    <g stroke="currentColor" fill="none" stroke-width="1.7">
                      <polygon points="160,88 188,104 188,136 160,152 132,136 132,104" />
                    </g>
                    <g stroke="currentColor" fill="none" opacity="0.78">
                      <ellipse cx="160" cy="120" rx="56" ry="40" stroke-width="1.4" />
                      <ellipse cx="160" cy="120" rx="80" ry="58" stroke-width="1.2" />
                      <ellipse cx="160" cy="120" rx="104" ry="76" stroke-width="1" />
                    </g>
                    <g stroke="currentColor" stroke-width="1" opacity="0.65">
                      <line x1="160" y1="44" x2="160" y2="76" />
                      <line x1="252" y1="120" x2="220" y2="120" />
                      <line x1="160" y1="196" x2="160" y2="164" />
                      <line x1="68" y1="120" x2="100" y2="120" />
                    </g>
                  </svg>
                )
              }
            </div>
            <h3 class="mt-6 text-[24px] font-semibold leading-[1.02] tracking-[-0.02em] text-text md:text-[26px]">{pillar.title}</h3>
            <p class="mt-3 max-w-[34ch] text-[16px] leading-[1.45] tracking-[-0.01em] text-muted/94 md:text-[17px]">{pillar.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
