---
import type { PortfolioContent } from "../../content/types";
import { Icon } from "astro-icon/components";

interface Props {
  id: string;
  stack: PortfolioContent["stack"];
  overline: string;
}

const { id, stack, overline } = Astro.props;

const stackIconMap: Record<PortfolioContent["stack"]["categories"][number]["icon"], string> = {
  code: "lucide:code",
  db: "lucide:database",
  gear: "lucide:cog",
  shield: "lucide:shield-check",
};
---

<section id={id} class="section-space border-t border-border/50">
  <div class="container-shell pt-8 md:pt-12">
    <p class="micro-label mb-5" data-reveal="up">{overline}</p>
    <h2 class="max-w-[760px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]" data-reveal="up">
      {stack.headingPrimary}
      <br />
      <span class="text-muted">{stack.headingSecondary}</span>
    </h2>
    <p class="mt-7 max-w-[780px] text-base leading-relaxed text-muted md:text-lg" data-reveal="up">{stack.intro}</p>

    <div class="mt-12 overflow-hidden rounded-2xl border border-border/60 bg-black/28" data-reveal="zoom" data-reveal-delay="80">
      <div
        class="grid md:grid-cols-2 xl:grid-cols-4"
        data-reveal-group
        data-reveal-stagger-mobile="72"
        data-reveal-stagger-desktop="56"
      >
        {
          stack.categories.map((category) => (
            <article
              class="border-b border-border/60 p-7 md:border-r md:[&:nth-child(2n)]:border-r-0 xl:min-h-[360px] xl:border-b-0 xl:[&:nth-child(2n)]:border-r xl:[&:nth-child(4n)]:border-r-0 hover:bg-stone-300/10"
              data-reveal="up"
            >
              <div class="mb-8 inline-flex items-center gap-3">
                <span class="h-5 w-5 text-[#b5c0cc]">
                  <Icon name={stackIconMap[category.icon]} class="h-5 w-5" aria-hidden="true" />
                </span>
                <h3 class="text-lg font-semibold leading-none tracking-[-0.02em] text-text md:text-xl">{category.category}</h3>
              </div>

              <ul class="space-y-4">
                {category.items.map((item) => <li>
                  <p class="text-base font-semibold leading-tight tracking-[-0.02em] text-text md:text-lg">{item.name}</p>
                  <p class="mt-1 text-xs leading-snug text-[#7a8592] md:text-sm">{item.hint}</p>
                </li>)}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
