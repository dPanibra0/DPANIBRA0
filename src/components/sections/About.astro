---
import type { AboutContent } from "../../content/types";

interface Props {
  id: string;
  about: AboutContent;
  overline: string;
}

const { id, about, overline } = Astro.props;
const isEnglish = about.title.toLowerCase().includes("about");

const capabilityCards = isEnglish
  ? [
      {
        title: "Corporate Backend",
        subtitle: "Java · Spring Boot · Oracle",
        icon: "backend",
      },
      {
        title: "Transactional Systems",
        subtitle: "Integrity · Consistency · Batch",
        icon: "database",
      },
      {
        title: "Distributed Teams",
        subtitle: "Remote · International · Agile",
        icon: "globe",
      },
      {
        title: "Enterprise Standards",
        subtitle: "SOX · Clean Code · CI/CD",
        icon: "shield",
      },
    ]
  : [
      {
        title: "Backend Corporativo",
        subtitle: "Java · Spring Boot · Oracle",
        icon: "backend",
      },
      {
        title: "Sistemas Transaccionales",
        subtitle: "Integridad · Consistencia · Batch",
        icon: "database",
      },
      {
        title: "Equipos Distribuidos",
        subtitle: "Remoto · Internacional · Agile",
        icon: "globe",
      },
      {
        title: "Estandares Corporativos",
        subtitle: "SOX · Clean Code · CI/CD",
        icon: "shield",
      },
    ];
---

<section id={id} class="section-space border-t border-border/50">
  <div class="container-shell pt-8 md:pt-12">
    <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:gap-12">
      <div>
        <p class="micro-label mb-5">{overline}</p>
        <h2 class="max-w-[640px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]">
          {isEnglish ? "Backend Engineer for" : "Backend Engineer para"}
          <br />
          <span class="text-muted">
            {isEnglish ? "critical enterprise environments" : "entornos empresariales criticos"}
          </span>
        </h2>
        <div class="mt-8 max-w-[620px] space-y-6 text-base leading-relaxed text-muted md:text-lg">
          <p>{about.paragraphs[0]}</p>
          <p>{about.paragraphs[1]}</p>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 sm:gap-5 lg:self-center">
        {
          capabilityCards.map((card) => (
            <article class="min-h-[160px] rounded-2xl border border-border/60 bg-black/28 px-6 py-6 md:min-h-[172px] md:px-7 md:py-7">
              <div class="mb-8 h-5 w-5 text-[#9ea8b4]">
                {card.icon === "backend" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <rect x="5" y="4" width="14" height="16" rx="2"></rect>
                    <path d="M8 8h8"></path>
                    <path d="M8 12h8"></path>
                  </svg>
                )}
                {card.icon === "database" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <ellipse cx="12" cy="6" rx="6.5" ry="2.7"></ellipse>
                    <path d="M5.5 6v7c0 1.5 2.9 2.7 6.5 2.7s6.5-1.2 6.5-2.7V6"></path>
                  </svg>
                )}
                {card.icon === "globe" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <circle cx="12" cy="12" r="7"></circle>
                    <path d="M5 12h14"></path>
                    <path d="M12 5a11 11 0 0 1 0 14"></path>
                    <path d="M12 5a11 11 0 0 0 0 14"></path>
                  </svg>
                )}
                {card.icon === "shield" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <path d="M12 3l6 2.4v6.1c0 4.1-2.4 7.7-6 9.5-3.6-1.8-6-5.4-6-9.5V5.4L12 3Z"></path>
                    <path d="m9.5 12 1.8 1.9 3.3-3.7"></path>
                  </svg>
                )}
              </div>
              <h3 class="text-base font-semibold leading-tight tracking-[-0.02em] text-text md:text-lg">{card.title}</h3>
              <p class="mt-2 text-sm leading-snug tracking-[-0.01em] text-[#7a8592] md:text-sm">{card.subtitle}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
