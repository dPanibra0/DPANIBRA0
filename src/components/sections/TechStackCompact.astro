---
import type { PortfolioContent } from "../../content/types";

interface Props {
  id: string;
  stack: PortfolioContent["stack"];
  overline: string;
}

const { id, stack, overline } = Astro.props;
---

<section id={id} class="section-space border-t border-border/50">
  <div class="container-shell pt-8 md:pt-12">
    <p class="micro-label mb-5" data-reveal="up">{overline}</p>
    <h2 class="max-w-[760px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]" data-reveal="up">
      {stack.headingPrimary}
      <br />
      <span class="text-muted">{stack.headingSecondary}</span>
    </h2>

    <div class="mt-10 grid gap-4 md:grid-cols-2" data-reveal-group data-reveal-stagger-mobile="62" data-reveal-stagger-desktop="48">
      {
        stack.categories.map((category) => (
          <article class="border border-border/60 bg-black/20 p-5 md:p-6" data-reveal="up">
            <h3 class="text-base font-semibold tracking-[-0.01em] text-text md:text-lg">{category.category}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted">{category.items.map((item) => item.name).join(" · ")}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
