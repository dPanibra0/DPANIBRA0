---
import type { PortfolioContent, PortfolioUiTranslations } from "../../content/types";
import TechnologyCarousel from "../ui/TechnologyCarousel.astro";
import { Icon } from "astro-icon/components";

interface Props {
  id: string;
  stack: PortfolioContent["stack"];
  overline: string;
  ui: PortfolioUiTranslations["techCarousel"];
}

interface StackTechnology {
  name: string;
  hint: string;
  icon: string;
}

const { id, stack, overline, ui } = Astro.props as Props;

const technologySet = new Set<string>();
const marqueeTechnologies = stack.categories
  .flatMap((category) => category.items as StackTechnology[])
  .filter((item) => {
    if (technologySet.has(item.name)) {
      return false;
    }

    technologySet.add(item.name);
    return true;
  })
  .map((item) => ({
    label: item.name,
    icon: item.icon,
  }));

const atmosphericSlice = marqueeTechnologies.filter((_, index) => index % 2 === 0);
const atmosphericTechnologies = atmosphericSlice.length > 5
  ? [...atmosphericSlice.slice(2), ...atmosphericSlice.slice(0, 2)]
  : marqueeTechnologies;

---

<section id={id} class="section-space overflow-x-hidden border-t border-border/50">
  <div class="container-shell pt-8 md:pt-12">
    <p class="micro-label mb-5" data-reveal="up">{overline}</p>
    <h2 class="max-w-[760px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]" data-reveal="up">
      {stack.headingPrimary}
      <br />
      <span class="text-muted">{stack.headingSecondary}</span>
    </h2>

    <p class="mt-6 max-w-[760px] text-sm leading-relaxed text-muted md:text-base" data-reveal="up">{stack.intro}</p>

    <div
      class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4"
      data-reveal-group
      data-reveal-stagger-mobile="62"
      data-reveal-stagger-desktop="48"
    >
      {
        stack.categories.map((category) => {
          const items = category.items as StackTechnology[];

          return (
          <details class="stack-card group border border-border/60 bg-surface/35 p-5 hover:border-border/85 hover:bg-surface/50 md:p-6" data-reveal="up" data-stack-card>
            <summary class="stack-card__summary mb-0 flex cursor-pointer list-none items-center justify-between gap-3 md:cursor-default">
              <div class="flex items-center gap-2.5">
                <span class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-border/70 bg-black/30 text-[#b5c0cc]">
                  <Icon name={category.icon} class="h-4 w-4" aria-hidden="true" />
                </span>
                <h3 class="text-[15px] font-semibold tracking-[-0.01em] text-text md:text-base">{category.category}</h3>
              </div>

              <span class="stack-card__chevron inline-flex h-8 w-8 items-center justify-center rounded-full border border-border/60 bg-black/20 text-muted md:hidden">
                <Icon name="lucide:chevron-down" class="h-4 w-4" aria-hidden="true" />
              </span>
            </summary>

            <div class="stack-card__body pt-4">
              <div class="grid grid-cols-[2rem,1fr] gap-3" data-stack-preview>
                <span class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-border/60 bg-black/25 text-[#d8e0e8]">
                  <Icon name={items[0].icon} class="h-4 w-4" aria-hidden="true" data-stack-preview-icon />
                </span>
                <div>
                  <p class="text-sm font-semibold leading-tight tracking-[-0.01em] text-text md:text-[15px]" data-stack-preview-name>{items[0].name}</p>
                  <p class="mt-1 text-xs leading-snug text-muted/80 md:text-[13px]" data-stack-preview-hint>{items[0].hint}</p>
                </div>
              </div>

              <div class="mt-4 flex flex-wrap gap-1.5">
                {
                  items.map((item, itemIndex) => (
                    <button
                      type="button"
                      class:list={[
                        "stack-card__chip selectable-chip px-2 py-1 text-[10px] font-medium uppercase tracking-[0.08em]",
                        itemIndex === 0 && "is-active",
                      ]}
                      data-stack-chip
                      data-icon={item.icon}
                      data-name={item.name}
                      data-hint={item.hint}
                      aria-pressed={itemIndex === 0 ? "true" : "false"}
                    >
                      <Icon name={item.icon} class="h-3.5 w-3.5" aria-hidden="true" />
                      {item.name}
                    </button>
                  ))
                }
              </div>
            </div>
          </details>
          );
        })
      }
    </div>
  </div>
  

    <div class="mt-12 md:mt-16 -mb-8 lg:-mb-16" data-reveal="up">
      <div class="stack-carousel-shell">
        <TechnologyCarousel ui={ui} technologies={marqueeTechnologies} />
        <div class="stack-carousel-shell__secondary" aria-hidden="true">
          <TechnologyCarousel
            ui={ui}
            technologies={atmosphericTechnologies}
            direction="reverse"
            emphasis="secondary"
            compact={true}
            mobileOnly={true}
            decorative={true}
          />
        </div>
      </div>
    </div>
</section>

<script>
  const desktopStackQuery = window.matchMedia("(min-width: 48rem)");
  const stackCards = Array.from(document.querySelectorAll("[data-stack-card]"));

  const syncPreviewIcon = (currentPreviewIcon: Element | null, activeChip: HTMLButtonElement) => {
    if (!(currentPreviewIcon instanceof SVGElement)) {
      return currentPreviewIcon;
    }

    const iconName = activeChip.dataset.icon;

    if (!iconName) {
      return currentPreviewIcon;
    }

    const previewUse = currentPreviewIcon.querySelector("use");

    if (!(previewUse instanceof SVGUseElement)) {
      return currentPreviewIcon;
    }

    const iconHref = `#ai:${iconName}`;

    currentPreviewIcon.setAttribute("data-icon", iconName);
    previewUse.setAttribute("href", iconHref);
    previewUse.setAttributeNS("http://www.w3.org/1999/xlink", "xlink:href", iconHref);

    return currentPreviewIcon;
  };

  const setActiveChip = (card: HTMLDetailsElement, activeChip: HTMLButtonElement) => {
    const previewIcon = card.querySelector("[data-stack-preview-icon]");
    const previewName = card.querySelector("[data-stack-preview-name]");
    const previewHint = card.querySelector("[data-stack-preview-hint]");

    if (!(previewName instanceof HTMLElement) || !(previewHint instanceof HTMLElement)) {
      return;
    }

    const icon = activeChip.dataset.icon;
    const name = activeChip.dataset.name;
    const hint = activeChip.dataset.hint;

    if (!icon || !name || !hint) {
      return;
    }

    syncPreviewIcon(previewIcon, activeChip);
    previewName.textContent = name;
    previewHint.textContent = hint;

    const chips = Array.from(card.querySelectorAll("[data-stack-chip]"));
    chips.forEach((chip) => {
      if (!(chip instanceof HTMLButtonElement)) {
        return;
      }

      const isActive = chip === activeChip;
      chip.classList.toggle("is-active", isActive);
      chip.setAttribute("aria-pressed", isActive ? "true" : "false");
    });
  };

  const syncStackCards = () => {
    stackCards.forEach((card) => {
      if (!(card instanceof HTMLDetailsElement)) {
        return;
      }

      if (desktopStackQuery.matches) {
        card.open = true;
        return;
      }

      card.open = false;
    });
  };

  syncStackCards();
  desktopStackQuery.addEventListener("change", syncStackCards);

  stackCards.forEach((card) => {
    if (!(card instanceof HTMLDetailsElement)) {
      return;
    }

    card.addEventListener("toggle", () => {
      if (!desktopStackQuery.matches && card.open) {
        stackCards.forEach((otherCard) => {
          if (otherCard !== card && otherCard instanceof HTMLDetailsElement) {
            otherCard.open = false;
          }
        });
      }

      if (desktopStackQuery.matches && !card.open) {
        card.open = true;
      }
    });

    const chips = Array.from(card.querySelectorAll("[data-stack-chip]"));
    const initialChip = chips.find((chip) => chip.classList.contains("is-active")) ?? chips[0];

    if (initialChip instanceof HTMLButtonElement) {
      setActiveChip(card, initialChip);
    }

    chips.forEach((chip) => {
      if (!(chip instanceof HTMLButtonElement)) {
        return;
      }

      chip.addEventListener("click", () => {
        setActiveChip(card, chip);
      });
    });
  });
</script>

<style>
  .stack-card {
    transition: border-color 180ms ease, background-color 180ms ease;
  }

  .stack-carousel-shell {
    display: grid;
    gap: 0.85rem;
  }

  .stack-carousel-shell__secondary {
    pointer-events: none;
  }

  .stack-card__summary::-webkit-details-marker {
    display: none;
  }

  .stack-card__body {
    display: none;
  }

  .stack-card[open] .stack-card__body {
    display: block;
  }

  .stack-card__chevron {
    transition: transform 180ms ease;
  }

  .stack-card[open] .stack-card__chevron {
    transform: rotate(180deg);
  }

  @media (min-width: 48rem) {
    .stack-carousel-shell {
      gap: 0;
    }

    .stack-card__summary {
      pointer-events: none;
    }

    .stack-card__body {
      display: block;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .stack-card,
    .stack-card__chevron,
    .stack-card__chip {
      transition: none;
    }
  }
</style>
