---
import { Image } from "astro:assets";
import type { HeroContent } from "../../content/types";
import heroImage from "../../assets/dpanibra0_2d_isometric_voxel_art-banner.png";

interface Props {
  id: string;
  hero: HeroContent;
}

const { id, hero } = Astro.props;
---

<section id={id} class="section-space pt-16 md:pt-20 lg:pt-24">
  <div class="container-shell">
    <div
      class="hero-glow relative overflow-hidden pb-2"
      data-reveal-group
      data-reveal-stagger-mobile="86"
      data-reveal-stagger-desktop="68"
    >
      <div class="pointer-events-none absolute -right-28 top-6 h-48 w-48 rounded-full bg-accent/14 blur-3xl"></div>
      <div
        class="availability-badge mb-5 inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3 py-1.5 text-xs text-muted"
        data-reveal="up"
      >
        <span class="availability-dot"></span>
        {hero.availability}
      </div>
      <p class="micro-label mb-4" data-reveal="up">{hero.eyebrow}</p>
      <h1
        class="max-w-4xl text-[40px] font-semibold leading-[0.98] tracking-[-0.035em] text-text md:text-[52px] lg:text-[62px]"
        data-reveal="up"
      >
        {hero.title}
      </h1>
      <p class="mt-6 max-w-3xl text-base leading-relaxed tracking-[-0.01em] text-muted md:text-lg" data-reveal="up">{hero.subtitle}</p>
      
      <!-- CTA Buttons 
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/David_Panibra-Java_Microservices_Developer-CV.pdf" class="steel-button steel-button-primary" download>{hero.ctaSecondary}</a>
      </div>
      -->
    </div>

    <div data-reveal="zoom" data-reveal-delay="120">
      <div class="hero-media-shell hero-image-frame relative mt-8 overflow-hidden md:mt-12" data-parallax-media>
        <Image
          src={heroImage}
          alt="Enterprise backend architecture visual"
          class="parallax-image block h-[420px] w-full object-cover object-[68%_center] md:h-auto md:object-center"
          widths={[640, 960, 1280, 1600]}
          sizes="(max-width: 767px) 100vw, 90vw"
          format="webp"
          quality={78}
          priority
          data-parallax-image
          data-original-src="/images/dpanibra0_2d_isometric_voxel_art-banner.png"
        />
        <div class="hero-image-overlay pointer-events-none absolute inset-0"></div>
      </div>
    </div>

    <div
      class="stats-segment mt-12 grid overflow-hidden sm:grid-cols-4 md:mt-14"
      data-reveal-group
      data-reveal-stagger-mobile="72"
      data-reveal-stagger-desktop="54"
    >
      {
        hero.stats.map((stat) => (
          <article class="stats-item px-6 py-7 text-center md:px-8 md:py-8" data-reveal="up">
            <p class="text-2xl font-semibold tracking-[-0.03em] text-text md:text-3xl">{stat.value}</p>
            <p class="mt-2 text-sm leading-snug text-muted md:text-base">{stat.label}</p>
          </article>
        ))
      }
    </div>
  </div>
 </section>

<script>
  const media = document.querySelector("[data-parallax-media]") as HTMLElement | null;
  const image = document.querySelector("[data-parallax-image]") as HTMLElement | null;
  const heroImage = document.querySelector("[data-parallax-image]") as HTMLImageElement | null;
  const originalSrc = heroImage?.dataset.originalSrc;
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const canUpgradeToOriginal = () => {
    if (!heroImage || !originalSrc) return false;
    if (window.innerWidth < 1024 || window.devicePixelRatio < 1.5) return false;

    const connection = (navigator as Navigator & { connection?: { saveData?: boolean; effectiveType?: string } }).connection;
    if (connection?.saveData) return false;
    if (connection?.effectiveType && /2g/.test(connection.effectiveType)) return false;

    return true;
  };

  const upgradeToOriginal = () => {
    if (!canUpgradeToOriginal() || !heroImage || !originalSrc) return;

    const preload = new window.Image();
    preload.decoding = "async";
    preload.src = originalSrc;

    preload.onload = () => {
      heroImage.removeAttribute("srcset");
      heroImage.removeAttribute("sizes");
      heroImage.src = originalSrc;
    };
  };

  const scheduleOriginalUpgrade = () => {
    if (!canUpgradeToOriginal()) return;

    if ("requestIdleCallback" in window) {
      (window as Window & { requestIdleCallback: (callback: () => void, options?: { timeout: number }) => void }).requestIdleCallback(
        upgradeToOriginal,
        { timeout: 2500 },
      );
    } else {
      window.setTimeout(upgradeToOriginal, 1200);
    }
  };

  if (document.readyState === "complete") {
    scheduleOriginalUpgrade();
  } else {
    window.addEventListener("load", scheduleOriginalUpgrade, { once: true });
  }

  if (media && image && !prefersReducedMotion) {
    let ticking = false;

    const updateParallax = () => {
      const rect = media.getBoundingClientRect();
      const inView = rect.bottom > 0 && rect.top < window.innerHeight;

      if (inView) {
        const centerOffset = window.innerHeight / 2 - (rect.top + rect.height / 2);
        const speed = window.innerWidth < 768 ? 0.08 : 0.12;
        const y = centerOffset * speed;
        (image as HTMLElement).style.setProperty("--parallax-offset", `${y.toFixed(2)}px`);
      }

      ticking = false;
    };

    const onScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(updateParallax);
        ticking = true;
      }
    };

    updateParallax();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
  }
</script>
