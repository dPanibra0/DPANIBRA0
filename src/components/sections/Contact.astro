---
import type { PortfolioContent } from "../../content/types";
import { Icon } from "astro-icon/components";

interface Props {
  id: string;
  contact: PortfolioContent["contact"];
  overline: string;
}

const { id, contact, overline } = Astro.props;

const primaryEmailLink = contact.links.find((link) => link.href.startsWith("mailto:")) ?? contact.links[0];
const contactEmail = (primaryEmailLink?.href ?? "mailto:").replace("mailto:", "");
const contactPlaceholders = [
  "Veamos tu próximo proyecto",
  "Cuéntame sobre tu negocio",
  "¿Qué estás construyendo hoy?",
];
---

<section id={id} class="section-space border-t border-[#cfd8e3] bg-[#f4f7fb] text-[#0b0f14]">
  <div class="container-shell pt-8 md:pt-12">
    <div class="grid gap-10 lg:grid-cols-[1.02fr_0.98fr] lg:gap-14">
      <div>
        <p class="micro-label micro-label-contact mb-5">{overline}</p>
        <h2 class="max-w-[640px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-[#0b0f14] md:text-[44px]">
          {contact.headlineTop}
          <br />
          <span class="text-[#425062]">{contact.headlineBottom}</span>
        </h2>
        <p class="mt-7 max-w-[620px] text-base leading-relaxed text-[#445364] md:text-lg">{contact.subtitle}</p>

        <div class="availability-badge mt-8 inline-flex items-center gap-2 border border-[#c3d0dd] bg-white px-3 py-1.5 text-xs text-[#4b5a69]">
          <span class="availability-dot"></span>
          <span>{contact.availability}</span>
        </div>
      </div>

      <div class="pt-1">
        <img
          src="/images/dpanibra0_contactme.png"
          alt="Portrait of David Panibra ready for contact"
          loading="lazy"
          decoding="async"
          class="contact-image w-full"
        />
      </div>
    </div>

    <div class="contact-separator" aria-hidden="true">
      <span class="contact-separator-line"></span>
      <img src="/android-chrome-192x192.png" alt="" class="contact-separator-logo rounded-full" loading="lazy" decoding="async" />
      <span class="contact-separator-line"></span>
    </div>

    <form
      class="contact-form mt-9 md:mt-11"
      data-contact-form
      data-contact-email={contactEmail}
      aria-label="Formulario de contacto por email"
    >
      <label class="sr-only" for="contact-project-input">Cuéntame sobre tu proyecto</label>
      <div class="contact-field-wrap">
        <input
          id="contact-project-input"
          name="contactProject"
          type="text"
          required
          autocomplete="off"
          maxlength="180"
          class="contact-input"
          placeholder={contactPlaceholders[0]}
          data-rotating-placeholder
        />
        <button type="submit" class="contact-submit-button">
          <span class="technical-accent">Enviar</span>
          <Icon name="lucide:arrow-up-right" class="h-4 w-4" aria-hidden="true" />
        </button>
      </div>
    </form>
  </div>
</section>

<script define:vars={{ contactPlaceholders }}>
  const form = document.querySelector("[data-contact-form]");
  const input = form?.querySelector("[data-rotating-placeholder]");
  const email = form?.getAttribute("data-contact-email") ?? "";
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (form instanceof HTMLFormElement && input instanceof HTMLInputElement) {
    let placeholderIndex = 0;
    let rotationTimer = 0;
    let fadeTimer = 0;

    const rotatePlaceholder = () => {
      input.classList.add("is-placeholder-fading");
      window.clearTimeout(fadeTimer);

      fadeTimer = window.setTimeout(() => {
        placeholderIndex = (placeholderIndex + 1) % contactPlaceholders.length;
        input.placeholder = contactPlaceholders[placeholderIndex];
        input.classList.remove("is-placeholder-fading");
      }, 170);
    };

    const stopRotation = () => {
      window.clearInterval(rotationTimer);
      window.clearTimeout(fadeTimer);
      input.classList.remove("is-placeholder-fading");
    };

    const startRotation = () => {
      stopRotation();
      rotationTimer = window.setInterval(rotatePlaceholder, 5000);
    };

    const onFocus = () => {
      stopRotation();
    };

    const onBlur = () => {
      startRotation();
    };

    const onPageHide = () => {
      stopRotation();
      input.removeEventListener("focus", onFocus);
      input.removeEventListener("blur", onBlur);
      window.removeEventListener("pagehide", onPageHide);
    };

    if (!reduceMotion) {
      startRotation();
      input.addEventListener("focus", onFocus);
      input.addEventListener("blur", onBlur);
      window.addEventListener("pagehide", onPageHide);
    }

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const projectBrief = input.value.trim();
      if (!projectBrief || !email) return;

      const subject = encodeURIComponent("Nuevo proyecto desde dpanibra.com");
      const body = encodeURIComponent(`Hola David,%0D%0A%0D%0A${projectBrief}%0D%0A%0D%0AGracias.`);
      window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;
    });
  }
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .micro-label-contact {
    color: #5d6c7b;
  }

  .contact-form {
    width: 100%;
  }

  .contact-separator {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 34px;
  }

  .contact-separator-line {
    height: 1px;
    flex: 1;
    background: #cfd8e3;
  }

  .contact-separator-logo {
    width: 52px;
    height: 52px;
    object-fit: contain;
  }

  .contact-field-wrap {
    position: relative;
    overflow: hidden;
    border: 1px solid #cfd8e3;
    background: linear-gradient(180deg, #ffffff, #f6f9fc);
    padding: 8px;
    padding-left: 14px;
    box-shadow: 0 16px 34px -30px rgba(14, 28, 43, 0.34);
    transition:
      box-shadow 420ms cubic-bezier(0.22, 1, 0.36, 1) 60ms,
      background-color 300ms ease 40ms,
      border-color 300ms ease 40ms,
      outline-color 300ms ease 40ms;
  }

  .contact-image {
    display: block;
    height: auto;
    max-width: 100%;
  }

  .contact-input {
    width: 100%;
    min-height: 58px;
    border: 0;
    background: transparent;
    padding: 0 140px 0 0;
    color: #0b0f14;
    font-size: 16px;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .contact-input::placeholder {
    color: #697a8c;
    opacity: 1;
    font-size: 18px;
    transition: opacity 260ms ease;
  }

  .contact-input.is-placeholder-fading::placeholder {
    opacity: 0;
  }

  .contact-input:focus {
    outline: none;
  }

  .contact-submit-button {
    position: absolute;
    right: 8px;
    top: 8px;
    bottom: 8px;
    display: inline-flex;
    min-width: 120px;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: 1px solid #cfd8e3;
    background: linear-gradient(140deg, #1a2a3b, #0b0f14);
    color: #f7fbff;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    transition:
      transform 300ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 300ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 240ms ease;
  }

  .contact-field-wrap:focus-within {
    border-color: #aebfd0;
    box-shadow:
      0 24px 46px -34px rgba(20, 38, 56, 0.42),
      0 0 0 2px rgba(47, 85, 118, 0.26);
  }

  .contact-submit-button:focus-visible {
    outline: 2px solid #2f5576;
    outline-offset: -2px;
  }

  .contact-submit-button:active {
    transform: translateY(0) scale(0.995);
  }

  @media (max-width: 767px) {
    .contact-field-wrap {
      padding: 8px;
      padding-top: 10px;
      padding-left: 14px;
    }

    .contact-input {
      min-height: 48px;
      padding-right: 0;
    }

    .contact-submit-button {
      position: static;
      margin-top: 8px;
      min-height: 44px;
      width: 100%;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-field-wrap,
    .contact-input::placeholder,
    .contact-submit-button {
      transition: none;
    }

    .contact-field-wrap:hover,
    .contact-field-wrap:focus-within,
    .contact-submit-button:hover,
    .contact-submit-button:focus-visible,
    .contact-submit-button:active {
      transform: none;
    }
  }
</style>
