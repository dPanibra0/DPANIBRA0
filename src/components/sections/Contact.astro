---
import type { PortfolioContent } from "../../content/types";
import { Icon } from "astro-icon/components";

interface Props {
  id: string;
  contact: PortfolioContent["contact"];
  overline: string;
}

const { id, contact, overline } = Astro.props;

const resolveContactIcon = (label: string) => {
  const lowerLabel = label.toLowerCase();

  if (lowerLabel.includes("email")) {
    return { name: "simple-icons:gmail", key: "gmail" };
  }

  if (lowerLabel.includes("linkedin")) {
    return { name: "simple-icons:linkedin", key: "linkedin" };
  }

  if (lowerLabel.includes("github")) {
    return { name: "simple-icons:github", key: "github" };
  }

  return { name: "lucide:link", key: "default" };
};
---

<section id={id} class="section-space border-t border-border/50">
  <div class="container-shell pt-8 md:pt-12">
    <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:gap-16">
      <div>
        <p class="micro-label mb-5">{overline}</p>
        <h2 class="max-w-[640px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]">
          {contact.headlineTop}
          <br />
          <span class="text-muted">{contact.headlineBottom}</span>
        </h2>
        <p class="mt-7 max-w-[620px] text-base leading-relaxed text-muted md:text-lg">{contact.subtitle}</p>

        <div class="availability-badge mt-8 inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3 py-1.5 text-xs text-muted">
          <span class="availability-dot"></span>
          <span>{contact.availability}</span>
        </div>

        {/* <article class="mt-10 rounded-2xl bg-black/15 p-7 md:p-8">
          <div class="flex items-start gap-4">
            <span class="mt-1 h-10 w-10 text-[#9ea8b4]">
              <Icon name="lucide:globe" class="h-6 w-6" aria-hidden="true" />
            </span>
            <div>
              <h3 class="text-lg font-semibold tracking-[-0.02em] text-text md:text-xl">{contact.supportTitle}</h3>
              <p class="mt-2.5 text-sm leading-relaxed text-muted md:text-base">{contact.supportText}</p>
            </div>
          </div>
        </article>
      
*/}


      </div>

      <div class="space-y-4 pt-2">
        {
          contact.links.map((link) => {
            const icon = resolveContactIcon(link.label);

            return (
              <a
                href={link.href}
                target="_blank"
                rel="noreferrer"
                data-contact-link
                data-channel={icon.key}
                class="contact-link-card group block rounded-2xl border border-white/60 bg-[#f7f9fc] p-6 text-[#0b0f14] md:p-7"
              >
                <div class="flex items-start justify-between gap-4">
                  <div class="flex items-start gap-4">
                    <span
                      class="contact-link-icon-chip inline-flex h-12 w-12 items-center justify-center rounded-xl"
                      data-icon={icon.key}
                    >
                      <Icon name={icon.name} class="h-5 w-5" aria-hidden="true" />
                    </span>
                    <div>
                      <p class="text-base font-semibold tracking-[-0.02em] text-[#0b0f14] md:text-lg">{link.value}</p>
                      <p class="mt-2 text-sm text-[#4b5a69] md:text-base">{link.sublabel}</p>
                    </div>
                  </div>
                  <span class="contact-link-arrow mt-0.5 inline-flex h-8 w-8 items-center justify-center rounded-full bg-[#e8edf3] text-[#4f5e6d]">
                    <Icon name="lucide:arrow-up-right" class="h-4 w-4" aria-hidden="true" />
                  </span>
                </div>
              </a>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<style>
  .contact-link-card {
    position: relative;
    overflow: hidden;
    --channel-color: #8ea0b3;
    transform: translateY(0);
    box-shadow: 0 10px 22px -20px rgba(255, 255, 255, 0.78);
    transition:
      transform 420ms cubic-bezier(0.22, 1, 0.36, 1) 60ms,
      box-shadow 420ms cubic-bezier(0.22, 1, 0.36, 1) 60ms,
      background-color 300ms ease 40ms,
      border-color 300ms ease 40ms,
      outline-color 300ms ease 40ms;
    will-change: transform, box-shadow;
  }

  .contact-link-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: linear-gradient(180deg, color-mix(in oklab, var(--channel-color), white 12%), color-mix(in oklab, var(--channel-color), black 16%));
    opacity: 0.52;
    transition: opacity 300ms ease;
  }

  .contact-link-card[data-channel="gmail"] {
    --channel-color: #ea4335;
  }

  .contact-link-card[data-channel="linkedin"] {
    --channel-color: #0a66c2;
  }

  .contact-link-card[data-channel="github"] {
    --channel-color: #9fb3c8;
  }

  @media (hover: hover) and (pointer: fine) {
    .contact-link-card:hover,
    .contact-link-card:focus-visible {
      transform: translateY(-6px);
      border-color: rgba(255, 255, 255, 0.95);
      background-color: #ffffff;
      box-shadow:
        0 18px 36px -22px rgba(255, 255, 255, 0.88),
        0 0 0 1px color-mix(in oklab, var(--channel-color), white 64%);
    }

    .contact-link-card:hover::before,
    .contact-link-card:focus-visible::before {
      opacity: 0.9;
    }
  }

  .contact-link-card:focus-visible {
    transform: translateY(-6px);
    border-color: rgba(255, 255, 255, 0.95);
    background-color: #ffffff;
    box-shadow:
      0 18px 36px -22px rgba(255, 255, 255, 0.88),
      0 0 0 1px color-mix(in oklab, var(--channel-color), white 64%);
  }

  .contact-link-card:active,
  .contact-link-card.is-pressing {
    transform: translateY(-0.35px) scale(0.994);
    transition-duration: 190ms;
    transition-delay: 0ms;
    box-shadow: 0 12px 28px -20px rgba(255, 255, 255, 0.85);
  }

  @media (hover: none), (pointer: coarse) {
    .contact-link-card:active,
    .contact-link-card.is-pressing {
      border-color: rgba(255, 255, 255, 0.95);
      background-color: #ffffff;
      box-shadow:
        0 16px 30px -22px rgba(255, 255, 255, 0.84),
        0 0 0 1px color-mix(in oklab, var(--channel-color), white 64%);
    }

    .contact-link-card:active::before,
    .contact-link-card.is-pressing::before {
      opacity: 0.9;
    }

    .contact-link-card:active .contact-link-icon-chip,
    .contact-link-card.is-pressing .contact-link-icon-chip {
      background-color: color-mix(in oklab, var(--channel-color), white 90%);
      border-color: color-mix(in oklab, var(--channel-color), white 68%);
    }

    .contact-link-card:active .contact-link-arrow,
    .contact-link-card.is-pressing .contact-link-arrow {
      transform: translate3d(3px, -1px, 0);
      background-color: #dce5ef;
      color: #0b0f14;
    }
  }

  .contact-link-icon-chip {
    background-color: #eef3f8;
    border: 1px solid #d8e0e9;
    color: #445467;
    transition:
      background-color 260ms ease 70ms,
      transform 260ms ease 70ms,
      border-color 260ms ease 70ms;
  }

  .contact-link-icon-chip[data-icon="gmail"] {
    color: #ea4335;
  }

  .contact-link-icon-chip[data-icon="linkedin"] {
    color: #0a66c2;
  }

  .contact-link-icon-chip[data-icon="github"] {
    color: #111827;
  }

  .contact-link-arrow {
    transition:
      transform 300ms cubic-bezier(0.22, 1, 0.36, 1) 80ms,
      background-color 260ms ease 80ms,
      color 260ms ease 80ms;
  }

  @media (hover: hover) and (pointer: fine) {
    .contact-link-card:hover .contact-link-icon-chip,
    .contact-link-card:focus-visible .contact-link-icon-chip {
      background-color: color-mix(in oklab, var(--channel-color), white 90%);
      border-color: color-mix(in oklab, var(--channel-color), white 68%);
      transform: translateY(-1px);
    }

    .contact-link-card:hover .contact-link-arrow,
    .contact-link-card:focus-visible .contact-link-arrow {
      transform: translate3d(3px, -1px, 0);
      background-color: #dce5ef;
      color: #0b0f14;
    }
  }

  .contact-link-card:focus-visible .contact-link-icon-chip {
    background-color: #111b27;
    transform: translateY(-1px);
  }

  .contact-link-card:focus-visible .contact-link-arrow {
    transform: translate3d(3px, -1px, 0);
    background-color: #dce5ef;
    color: #0b0f14;
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-link-card,
    .contact-link-icon-chip,
    .contact-link-arrow {
      transition: none;
    }
  }
</style>

<script>
  const contactLinks = document.querySelectorAll<HTMLAnchorElement>("[data-contact-link]");

  const openExternalAfterPress = (href: string) => {
    const pendingTab = window.open("", "_blank");

    if (pendingTab) {
      pendingTab.opener = null;
      pendingTab.location.assign(href);
      return;
    }

    window.open(href, "_blank");
  };

  contactLinks.forEach((link) => {
    link.addEventListener("click", (event: MouseEvent) => {
      if (
        event.defaultPrevented ||
        event.button !== 0 ||
        event.metaKey ||
        event.ctrlKey ||
        event.shiftKey ||
        event.altKey ||
        link.dataset.animating === "true"
      ) {
        return;
      }

      event.preventDefault();
      link.dataset.animating = "true";
      link.classList.add("is-pressing");

      const href = link.getAttribute("href");
      const isEmailLink = href?.startsWith("mailto:") ?? false;

      window.setTimeout(() => {
        if (href) {
          if (isEmailLink) {
            window.location.href = href;
          } else {
            openExternalAfterPress(href);
          }
        }

        link.classList.remove("is-pressing");
        delete link.dataset.animating;
      }, 210);
    });
  });
</script>
