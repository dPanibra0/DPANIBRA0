---
import type { PortfolioContent } from "../../content/types";

interface Props {
  id: string;
  contact: PortfolioContent["contact"];
  overline: string;
}

const { id, contact, overline } = Astro.props;
const headlineTop = "Hablemos sobre";
const headlineBottom = "tu próximo proyecto";

const supportTitle = "Trabajo Remoto Internacional";
const supportText = "Experiencia con equipos distribuidos en multiples zonas horarias. Adaptabilidad a culturas corporativas y metodologias globales.";

const sublabelByType = (label: string) => {
  const lower = label.toLowerCase();
  if (lower.includes("email")) return "Respuesta en menos de 24h";
  if (lower.includes("linkedin")) return "Perfil profesional completo";
  return "Proyectos y contribuciones";
};
---

<section id={id} class="section-space border-t border-border/50">
  <div class="container-shell pt-8 md:pt-12">
    <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:gap-16">
      <div>
        <p class="micro-label mb-5">{overline}</p>
        <h2 class="max-w-[640px] text-[32px] font-semibold leading-[1.02] tracking-[-0.03em] text-text md:text-[44px]">
          {headlineTop}
          <br />
          <span class="text-muted">{headlineBottom}</span>
        </h2>
        <p class="mt-7 max-w-[620px] text-base leading-relaxed text-muted md:text-lg">{contact.subtitle}</p>

        <div class="availability-badge mt-8 inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3 py-1.5 text-xs text-muted">
          <span class="availability-dot"></span>
          <span>{contact.availability}</span>
        </div>

        <article class="mt-10 rounded-2xl bg-black/15 p-7 md:p-8">
          <div class="flex items-start gap-4">
            <span class="mt-1 h-10 w-10 text-[#9ea8b4]">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="7"></circle>
                <path d="M5 12h14"></path>
                <path d="M12 5a11 11 0 0 1 0 14"></path>
                <path d="M12 5a11 11 0 0 0 0 14"></path>
              </svg>
            </span>
            <div>
              <h3 class="text-lg font-semibold tracking-[-0.02em] text-text md:text-xl">{supportTitle}</h3>
              <p class="mt-2.5 text-sm leading-relaxed text-muted md:text-base">{supportText}</p>
            </div>
          </div>
        </article>
      </div>

      <div class="space-y-4 pt-2">
        {
          contact.links.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noreferrer"
              class="group block rounded-2xl bg-[#0f1217] p-6 transition hover:bg-[#151b22] md:p-7"
            >
              <div class="flex items-start justify-between gap-4">
                <div class="flex items-start gap-4">
                  <span class="inline-flex h-11 w-11 items-center justify-center rounded-lg bg-surface/25 text-[#9ea8b4]">
                  {link.label.toLowerCase().includes("email") && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-6 w-6" aria-hidden="true">
                      <path d="M4 7h16v10H4z"></path>
                      <path d="m5 8 7 6 7-6"></path>
                    </svg>
                  )}
                  {link.label.toLowerCase().includes("linkedin") && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-6 w-6" aria-hidden="true">
                      <rect x="4" y="4" width="16" height="16"></rect>
                      <path d="M8 11v5"></path>
                      <path d="M8 8h.01"></path>
                      <path d="M12 16v-3a2 2 0 0 1 4 0v3"></path>
                    </svg>
                  )}
                  {link.label.toLowerCase().includes("github") && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-6 w-6" aria-hidden="true">
                      <path d="M9 19c-4.5 1.5-4.5-2.5-6-3m12 6v-3.9a3.4 3.4 0 0 0-.9-2.6c3-.3 6-1.5 6-6.8A5.3 5.3 0 0 0 18.7 5 4.9 4.9 0 0 0 18.6 1S17.5.7 15 2.4a13.4 13.4 0 0 0-6 0C6.5.7 5.4 1 5.4 1a4.9 4.9 0 0 0-.1 4A5.3 5.3 0 0 0 4 8.7c0 5.3 3 6.5 6 6.8a3.4 3.4 0 0 0-1 2.6V22"></path>
                    </svg>
                  )}
                  </span>
                  <div>
                    <p class="text-base font-semibold tracking-[-0.02em] text-text md:text-lg">{link.value}</p>
                    <p class="mt-2 text-sm text-muted md:text-base">{sublabelByType(link.label)}</p>
                  </div>
                </div>
                <span class="mt-1 text-muted transition group-hover:translate-x-0.5 group-hover:text-text">↗</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
