---
interface Props {
  figureLabel: string;
  title: string;
  description: string;
  motionConfig?: string;
  animCard?: "scalability" | "resilient" | "observable";
  animFigure?: "scalability";
}

const { figureLabel, title, description, motionConfig, animCard, animFigure } = Astro.props as Props;
---

<article
  class="micro-card border-b border-border/40 p-5 md:border-b-0 md:px-7 md:py-6"
  data-reveal="up"
  data-motion-config={motionConfig}
  data-anim-card={animCard}
>
  <p class="micro-card-label text-[12px] uppercase tracking-[0.12em] text-muted/60">{figureLabel}</p>
  <div class="micro-figure mt-4" aria-hidden="true" data-anim-figure={animFigure}>
    <slot name="figure" />
  </div>
  <h3 class="mt-6 text-[24px] font-semibold leading-[1.02] tracking-[-0.02em] text-text md:text-[26px]">{title}</h3>
  <p class="mt-3 max-w-[34ch] text-[16px] leading-[1.45] tracking-[-0.01em] text-muted/94 md:text-[17px]">{description}</p>
</article>
