---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  lang: "es" | "en";
}

const { title, description, lang } = Astro.props;
const baseUrl = Astro.site ?? new URL("https://davidpanibra.dev");
const canonicalUrl = new URL(Astro.url.pathname, baseUrl).toString();
const socialImageUrl = new URL("/images/og-1200x630.png", baseUrl).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta name="description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="David Panibra - Software Engineer" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content="David Panibra - Software Engineer" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document.documentElement.classList.add("motion-enabled");
      }
    </script>
  </head>
  <body>
    <slot />
    <script is:inline>
      (() => {
        const supportsIO = "IntersectionObserver" in window;
        const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
        const revealElements = Array.from(document.querySelectorAll("[data-reveal]"));

        if (!revealElements.length) return;

        const revealNow = (element) => {
          element.classList.add("is-revealed");
        };

        if (!supportsIO || reducedMotion.matches) {
          revealElements.forEach(revealNow);
          return;
        }

        const staggerGroups = new Map();

        revealElements.forEach((element) => {
          const parent = element.closest("[data-reveal-group]");
          const explicitDelay = Number(element.dataset.revealDelay ?? "");

          if (Number.isFinite(explicitDelay) && explicitDelay >= 0) {
            element.style.setProperty("--reveal-delay", `${explicitDelay}ms`);
            return;
          }

          if (!parent) return;

          const isDesktop = window.matchMedia("(min-width: 1024px)").matches;
          const rawStep =
            (isDesktop ? parent.dataset.revealStaggerDesktop : parent.dataset.revealStaggerMobile) ??
            parent.dataset.revealStagger ??
            "50";
          const step = Number(rawStep);
          const safeStep = Number.isFinite(step) && step >= 0 ? step : 50;
          const nextIndex = staggerGroups.get(parent) ?? 0;
          staggerGroups.set(parent, nextIndex + 1);
          element.style.setProperty("--reveal-delay", `${nextIndex * safeStep}ms`);
        });

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const element = entry.target;
              const revealOnce = element.dataset.revealOnce !== "false";

              if (entry.isIntersecting) {
                revealNow(element);
                if (revealOnce) {
                  observer.unobserve(element);
                }
              } else if (!revealOnce) {
                element.classList.remove("is-revealed");
              }
            });
          },
          {
            root: null,
            rootMargin: "0px 0px -8% 0px",
            threshold: 0.16,
          },
        );

        revealElements.forEach((element) => observer.observe(element));
      })();
    </script>
    <script>
      const path = window.location.pathname;
      const browserLang = navigator.language.toLowerCase();

      if (path === "/" && browserLang.startsWith("en")) {
        window.location.replace("/en");
      }
    </script>
  </body>
</html>
