---
import "../styles/global.css";
import type { Language } from "../content/types";

interface Props {
  title: string;
  description: string;
  lang: Language;
  seo?: {
    type?: "website" | "article";
    canonicalPath?: string;
    image?: {
      src: string;
      alt: string;
      width?: number;
      height?: number;
      type?: string;
    };
    article?: {
      publishedTime: string;
      modifiedTime?: string;
      author: string;
      section?: string;
      tags?: string[];
    };
  };
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { title, description, lang, seo, structuredData } = Astro.props;
const baseUrl = Astro.site ?? new URL("https://davidpanibra.dev");
const canonicalUrl = new URL(seo?.canonicalPath ?? Astro.url.pathname, baseUrl).toString();
const socialImage = seo?.image ?? {
  src: "/images/og-1200x630.png",
  alt: "David Panibra - Backend Java Microservices Engineer",
  width: 1200,
  height: 630,
  type: "image/png",
};
const socialImageUrl = new URL(socialImage.src, baseUrl).toString();
const socialImageType = socialImage.type ?? "image/png";
const socialImageWidth = String(socialImage.width ?? 1200);
const socialImageHeight = String(socialImage.height ?? 630);
const ogType = seo?.type ?? "website";
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta name="description" content={description} />
    <meta name="author" content={seo?.article?.author ?? "David Panibra"} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:type" content={socialImageType} />
    <meta property="og:image:width" content={socialImageWidth} />
    <meta property="og:image:height" content={socialImageHeight} />
    <meta property="og:image:alt" content={socialImage.alt} />
    {
      seo?.article?.publishedTime && <meta property="article:published_time" content={seo.article.publishedTime} />
    }
    {seo?.article?.modifiedTime && <meta property="article:modified_time" content={seo.article.modifiedTime} />}
    {seo?.article?.author && <meta property="article:author" content={seo.article.author} />}
    {seo?.article?.section && <meta property="article:section" content={seo.article.section} />}
    {seo?.article?.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={socialImage.alt} />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Afacad+Flux:wght@100..1000&family=Fira+Code:wght@400..700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document.documentElement.classList.add("motion-enabled");
      }
    </script>
    {structuredDataItems.map((item) => <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />)}
  </head>
  <body>
    <slot />
    <script is:inline>
      (() => {
        const supportsIO = "IntersectionObserver" in window;
        const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
        const revealElements = Array.from(document.querySelectorAll("[data-reveal]"));

        if (!revealElements.length) return;

        const revealNow = (element) => {
          element.classList.add("is-revealed");
        };

        if (!supportsIO || reducedMotion.matches) {
          revealElements.forEach(revealNow);
          return;
        }

        const staggerGroups = new Map();

        revealElements.forEach((element) => {
          const parent = element.closest("[data-reveal-group]");
          const explicitDelay = Number(element.dataset.revealDelay ?? "");

          if (Number.isFinite(explicitDelay) && explicitDelay >= 0) {
            element.style.setProperty("--reveal-delay", `${explicitDelay}ms`);
            return;
          }

          if (!parent) return;

          const isDesktop = window.matchMedia("(min-width: 1024px)").matches;
          const rawStep =
            (isDesktop ? parent.dataset.revealStaggerDesktop : parent.dataset.revealStaggerMobile) ??
            parent.dataset.revealStagger ??
            "50";
          const step = Number(rawStep);
          const safeStep = Number.isFinite(step) && step >= 0 ? step : 50;
          const nextIndex = staggerGroups.get(parent) ?? 0;
          staggerGroups.set(parent, nextIndex + 1);
          element.style.setProperty("--reveal-delay", `${nextIndex * safeStep}ms`);
        });

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const element = entry.target;
              const revealOnce = element.dataset.revealOnce !== "false";

              if (entry.isIntersecting) {
                revealNow(element);
                if (revealOnce) {
                  observer.unobserve(element);
                }
              } else if (!revealOnce) {
                element.classList.remove("is-revealed");
              }
            });
          },
          {
            root: null,
            rootMargin: "0px 0px -8% 0px",
            threshold: 0.16,
          },
        );

        revealElements.forEach((element) => observer.observe(element));
      })();
    </script>
  </body>
</html>
